-1 text-sm text-muted-foreground\",\"children\":\"Optionally downscale to 1080p, 720p, 480p, or 360p while maintaining aspect ratio. Great for cutting file size further.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"H.264 + AAC Output\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Output is MP4 with H.264 video and AAC audio — the most universally compatible format for web, mobile, and social media.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"100% Private\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"All processing happens in your browser using WebAssembly. Your video never leaves your device — no uploads, no servers.\"}]]}]]}]\n20:[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L2b\",null,{}]}]\n21:[\"$\",\"div\",null,{\"className\":\"my-8 flex justify-center\",\"children\":[\"$\",\"$L17\",null,{\"slot\":\"mid-content\"}]}]\n22:[\"$\",\"section\",null,{\"className\":\"prose prose-sm dark:prose-invert max-w-none\",\"children\":[[\"$\",\"$L2c\",null,{\"className\":\"my-8\"}],[\"$\",\"div\",null,{\"className\":\"not-prose mb-10\"}],[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Free Video Compressor — Reduce Video Size Online\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-muted-foreground\",\"children\":\"The Free Video Compressor lets you reduce video file size directly in your browser using H.264 (libx264) encoding via WebAssembly. Choose a quality preset or fine-tune with custom CRF and resolution settings. Your video never leaves your device — no uploads, no sign-up, no file size limits.\"}],[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-sem