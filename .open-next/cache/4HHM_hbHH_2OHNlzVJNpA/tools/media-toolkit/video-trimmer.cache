t points before exporting\\\",{\\\"className\\\":\\\"flex gap-3 rounded-lg border border-border bg-card p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L5\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"iconNode\\\":\\\"$2e:0:props:children:2:props:children:0:props:children:0:props:iconNode\\\",\\\"className\\\":\\\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-semibold\\\",\\\"children\\\":\\\"Scrub to confirm the cut points before exporting\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"mt-1 text-sm text-muted-foreground\\\",\\\"children\\\":\\\"The timeline shows where the cuts land. Scrub through both endpoints before exporting — a cut that looks right at second 5.0 may need to be at 5.4 to land at the natural pause.\\\"}]]}]]}],[\\\"$\\\",\\\"li\\\",\\\"Keep the original file until the trim is verified\\\",{\\\"className\\\":\\\"flex gap-3 rounded-lg border border-border bg-card p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L5\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"iconNode\\\":\\\"$2e:0:props:children:2:props:children:0:props:children:0:props:iconNode\\\",\\\"className\\\":\\\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-semibold\\\",\\\"children\\\":\\\"Keep the original file until the trim is verified\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"mt-1 text-sm text-muted-foreground\\\",\\\"children\\\":\\\"Trimming exports a new file; the source is untouched. Keep the source until you've played back the trimmed output end-to-end and confirmed the cuts are right.\\\"}]]}]]}]]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"aria-labelledby\\\":\\\"tool-insights-mistakes\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"id\\\":\\\"tool-insights-mistakes\\\",\\\"className\\\":\\\"text-2xl font-semibold tracking-tight