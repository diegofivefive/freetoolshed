,\"rel\":\"author\",\"children\":\"James Nicolaus\"}],\"$undefined\"]}]]\n1e:[\"$\",\"section\",null,{\"aria-label\":\"Summary\",\"className\":\"mt-6 rounded-lg border border-brand/30 bg-brand/5 p-4\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm leading-relaxed text-foreground\",\"children\":\"Cut and trim video clips with a frame-accurate timeline — drag the start and end handles, scrub to confirm, and export. Stream-copy mode trims in seconds without re-encoding when format and codec allow. Supports MP4, MOV, MKV, and WebM. No upload, no sign-up — a free alternative to Clipchamp, VEED, and Adobe Premiere Rush.\"}]}]\n1f:[\"$\",\"div\",null,{\"className\":\"mt-6 grid gap-4 sm:grid-cols-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Instant Stream Copy\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"No re-encoding means near-instant trimming with zero quality loss. Cut a 2-hour movie in seconds, not minutes.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Trim or Split\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Trim mode extracts a single clip. Split mode cuts at multiple time markers, producing separate files for each segment.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Video Preview\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Preview your video and scrub to the exact timestamp before cutting. Verify start and end points visually.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\