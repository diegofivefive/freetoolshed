arge_image\"/><meta name=\"twitter:title\" content=\"Free Video Converter Online — No Sign Up | Free Tool Shed\"/><meta name=\"twitter:description\" content=\"Convert videos between MP4, WebM, MOV, AVI, and GIF. Browser-based, no uploads, no sign-up. A free alternative to Adobe Media Encoder. No sign up required.\"/><meta name=\"twitter:image\" content=\"https://freetoolshed.com/screenshots/media-toolkit-video-converter.png\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/favicon.ico\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\",\"logo\":\"https://freetoolshed.com/og-image.png\",\"description\":\"Free, browser-based tools that replace paid software. No sign up, no downloads, no servers — every tool runs client-side.\",\"founder\":{\"@type\":\"Person\",\"name\":\"James Nicolaus\",\"url\":\"https://freetoolshed.com/about\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Free Tool Shed\"}}</script><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"flex min-h-full flex-col antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><script>((a,b,c,d,e,f,g,h)=>{let i=document.documentElement,j=[\"light\",\"dark\"];function k(b){var c;(Array.isArray(a)?a:[a]).forEach(a=>{let c=\"class\"===a,d=c&&f?e.map(a=>f[a]||a):e;c?(i.classList.remove(...d),i.classList.add(f&&f[b]?f[b]:b)):i.setAttribute(a,b)}),c=b,h&&j.includes(c)&&(i.style.colorScheme=c)}if(d)k(d);else try{let a=localStorage.getItem(b)||c,d=g&&\"system\"===a?window.matchMedia(\"(prefers-color-scheme: dark)\").matches?\"dark\":\"light\":a;k(d)}catch(a){}})(\"class\",\"theme\",\"system\",null,[\"l