l,{\"iconNode\":\"$19:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Pick FLAC or WAV only if you'll edit the audio\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Lossless formats are larger and only make sense if you're re-editing. For listening, AAC or MP3 at the source bitrate sounds the same and downloads faster.\"}]]}]]}],[\"$\",\"li\",\"Check the video's audio track count before extracting\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":\"$19:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Check the video's audio track count before extracting\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Some videos (DVD rips, multi-language releases) have several audio tracks. The tool surfaces them — pick the right one rather than guessing.\"}]]}]]}]]}]]}],[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-mistakes\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-mistakes\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Common Mistakes to Avoid\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Re-encoding to MP3 from a video with AAC audio\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":[[\"path\",{\"d\":\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\",\"key\":\"wmoenq\"}],[\"path\",{\"d\":\"M12 9v4\",\"key\":\"juzpu7\"