ips\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":[\"Tips from Building \",\"the Audio Extractor\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Stream-copy when the source codec is already what you want\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\",\"key\":\"1gvzjb\"}],[\"path\",{\"d\":\"M9 18h6\",\"key\":\"x1upvd\"}],[\"path\",{\"d\":\"M10 22h4\",\"key\":\"ceow96\"}]],\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Stream-copy when the source codec is already what you want\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"If you're pulling AAC audio out of an MP4, exporting as M4A lets ffmpeg copy the audio stream without re-encoding — same quality, fraction of the time.\"}]]}]]}],[\"$\",\"li\",\"Match output bitrate to the source's audio bitrate\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$32:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Match output bitrate to the source's audio bitrate\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"If the video's audio is encoded at 128 kbps, exporting at 320 kbps doesn't add quality — it just adds bytes. The bitrate ceiling is whatever the source actually contains.\"}]]}]]}],[\"$\",\"li\",\"Pick FLAC or WAV only if you'll edit the audio\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$32:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Pick FLAC or WAV only if you'll edit the audio\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Lossless formats are larger and only make sense if you're re-editing. For listening, AAC or MP3 at the source bitrate sounds the same and downloads faster.\"}]]}]]}],[\"$\",\"li\",\"Check the video's audio track count before extracting\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$32:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Check the video's audio track count before extracting\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Some videos (DVD rips, multi-language releases) have several audio tracks. The tool surfaces them — pick the right one rather than guessing.\"}]]}]]}]]}]]}],[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-mistakes\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-mistakes\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Common Mistakes to Avoid\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Re-encoding to MP3 from a video with AAC audio\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\",\"key\":\"wmoenq\"}],[\"path\",{\"d\":\"M12 9v4\",\"key\":\"juzpu7\"}],[\"path\",{\"d\":\"M12 17h.01\",\"key\":\"p32p05\"}]],\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],\"$L37\"]}],\"$L38\",\"$L39\"]}]]}],\"$L3a\"]\n33:[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Frequently Asked Questions\"}]\n34:[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-4 text-muted-foreground\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"When should I use \\\"Original\\\" vs. a specific format?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Use Original when you want the fastest extraction with no quality loss — the audio is copied byte-for-byte. Choose a specific format when you need compatibility (e.g. MP3 for older devices) or want to change the codec.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Why did stream copy fail and fall back to AAC?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Stream copy requires the original audio codec to be compatible with the output container. If the video uses an uncommon codec, the tool automatically falls back to AAC re-encoding to ensure you get a working output file.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Can I extract from very large video files?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Yes, but the entire file must be loaded into browser memory via WebAssembly. Files up to ~2 GB work well on most modern machines. The loading step may take a moment for large files.\"}]]}]]}]\n37:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Re-encoding to MP3 from a video with AAC audio\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Forcing MP3 output when the source is AAC means lossy-to-lossy conversion. Keep AAC (M4A) unless a specific destination requires MP3.\"}]]}]\n38:[\"$\",\"li\",\"Extracting audio from a screen recording you'll re-encode\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$32:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Extracting audio from a screen recording you'll re-encode\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"If you'll edit and re-export anyway, extracting first is an extra round-trip. Keep the source video, extract once on final export.\"}]]}]]}]\n39:[\"$\",\"li\",\"Choosing 48 kHz sample rate for music that's 44.1 kHz\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$32:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Choosing 48 kHz sample rate for music that's 44.1 kHz\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-