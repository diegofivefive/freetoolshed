{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/tools/layout,_N_T_/tools/media-toolkit/layout,_N_T_/tools/media-toolkit/audio-extractor/layout,_N_T_/tools/media-toolkit/audio-extractor/page,_N_T_/tools/media-toolkit/audio-extractor"},"segmentPaths":["/_tree","/_full","/tools/media-toolkit/audio-extractor/__PAGE__","/tools/media-toolkit/audio-extractor","/tools/media-toolkit","/tools","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable h-full\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.09zddjkbdep5a.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.09~u27dqhyhd6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/123doanyjnwwq.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/04uuf1716ltqa.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0eyplc079uusk.js\"/><script src=\"/_next/static/chunks/0tszvp5wpnn-t.js\" async=\"\"></script><script src=\"/_next/static/chunks/0bss4aof7q0cj.js\" async=\"\"></script><script src=\"/_next/static/chunks/0hi511ipeys_s.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-13rn3bqw7ype6.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zif8_3mgcc0x.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zv.me6xdrdsz.js\" async=\"\"></script><script src=\"/_next/static/chunks/0ag6f0zogt0qg.js\" async=\"\"></script><script src=\"/_next/static/chunks/04p0ygcx_g620.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0_pa1c_tsbiw0.js\" async=\"\"></script><script src=\"/_next/static/chunks/10nuyoal1pib2.js\" async=\"\"></script><script src=\"/_next/static/chunks/11~hh-yuwxxvh.js\" async=\"\"></script><script src=\"/_next/static/chunks/12gkftktoszi8.js\" async=\"\"></script><link rel=\"preconnect\" href=\"https://www.highperformanceformat.com\" crossorigin=\"anonymous\"/><link rel=\"dns-prefetch\" href=\"https://www.highperformanceformat.com\"/><link rel=\"preconnect\" href=\"https://pl29142630.profitablecpmratenetwork.com\" crossorigin=\"anonymous\"/><link rel=\"dns-prefetch\" href=\"https://pl29142630.profitablecpmratenetwork.com\"/><meta name=\"next-size-adjust\" content=\"\"/><title>Free Audio Extractor Online — No Sign Up | Free Tool Shed</title><meta name=\"description\" content=\"Extract audio tracks from video files. Convert to MP3, M4A, WAV, OGG, or FLAC — or keep the original codec. A free alternative to Adobe Premiere Pro. No sign up required.\"/><meta name=\"google-adsense-account\" content=\"ca-pub-7700405385978151\"/><link rel=\"canonical\" href=\"https://freetoolshed.com/tools/media-toolkit/audio-extractor\"/><meta property=\"og:title\" content=\"Free Audio Extractor Online — No Sign Up | Free Tool Shed\"/><meta property=\"og:description\" content=\"Extract audio tracks from video files. Convert to MP3, M4A, WAV, OGG, or FLAC — or keep the original codec. A free alternative to Adobe Premiere Pro. No sign up required.\"/><meta property=\"og:url\" content=\"https://freetoolshed.com/tools/media-toolkit/audio-extractor\"/><meta property=\"og:site_name\" content=\"Free Tool Shed\"/><meta property=\"og:image\" content=\"https://freetoolshed.com/screenshots/media-toolkit-audio-extractor.png\"/><meta property=\"og:image:width\" content=\"1440\"/><meta property=\"og:image:height\" content=\"900\"/><meta property=\"og:image:alt\" content=\"Audio Extractor workspace screenshot\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twit