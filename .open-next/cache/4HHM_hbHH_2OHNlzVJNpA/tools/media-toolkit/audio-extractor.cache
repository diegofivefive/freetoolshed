e audio\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$32:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Pick FLAC or WAV only if you'll edit the audio\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Lossless formats are larger and only make sense if you're re-editing. For listening, AAC or MP3 at the source bitrate sounds the same and downloads faster.\"}]]}]]}],[\"$\",\"li\",\"Check the video's audio track count before extracting\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$32:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Check the video's audio track count before extracting\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Some videos (DVD rips, multi-language releases) have several audio tracks. The tool surfaces them — pick the right one rather than guessing.\"}]]}]]}]]}]]}],[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-mistakes\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-mistakes\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Common Mistakes to Avoid\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Re-encoding to MP3 from a video with AAC audio\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\",\"key\":\"wmoenq\"}],[\"path\",{\"d\":\"M12 9v4\",\"key\":\"juzpu7\"}],[\"path\",{\"d\":\"M12 17h.01\",\"key\":\"p32p05\"}]],\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],\"$L37\"]}],\"$L38\",\"$L39\"]}]]}],\"$L3a\"]\n33:[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Frequently Asked Questions\"}]\n34:[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-4 text-muted-foreground\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"When should I use \\\"Original\\\" vs. a specific format?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Use Original when you want the fastest extraction with no quality loss — the audio is copied byte-for-byte. Choose a specific format when you need compatibility (e.g. MP3 for older devices) or want to change the codec.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Why did stream copy fail and fall back to AAC?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Stream copy requires the original audio codec to be compatible with the output container. If the video uses an uncommon codec, the tool automatically falls back to AAC re-encoding to ensure you get a working output file.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Can I extract from very large video files?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Yes, but the entire file must be loaded into browser memory via WebAssembly. Files up to ~2 GB work well on most modern machines. The loading step may take a moment for large files.\"}]]}]]}]\n37:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"tex