\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"What's Natural Sort?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Natural Sort orders files the way humans expect: Chapter 1, Chapter 2, Chapter 10 — not Chapter 1, Chapter 10, Chapter 2. It uses your system's locale-aware numeric collation for correct ordering of numbered filenames.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Do chapter markers work in all players?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Chapter markers are embedded in M4A files using the standard ffmetadata format. They work in Apple Books, VLC, iTunes, foobar2000, and most audiobook players. MP3 and OGG outputs do not support chapter markers.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Can I use this on my phone?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Technically yes, but the tool is optimized for desktop browsers. Mobile browsers have tighter memory limits and smaller screens, which makes managing hundreds of files impractical. For best results, use a desktop or laptop.\"}]]}]]}]\n20:null\n","/tools/media-toolkit/audio-merger":"1:\"$Sreact.fragment\"\n2:I[39756,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\"],\"default\"]\n3:I[37457,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\"],\"default