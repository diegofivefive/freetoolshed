"children\":\"Installation\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4 text-brand\",\"children\":\"None\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Desktop app install\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"None\"}]]}]]}]]}]}]\n35:[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Frequently Asked Questions\"}]\n36:[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-4 text-muted-foreground\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Can I merge different audio formats together?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Yes. You can mix MP3, M4A, WAV, OGG, FLAC, AAC, and WebM files in the same merge. Each file is decoded and then re-encoded to your chosen output format, so format differences don't matter.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"How long does merging take?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"It depends on the total duration and your chosen bitrate. The first merge takes longer because ffmpeg.wasm (~30 MB) needs to download. After that, merging a typical audiobook (10-20 hours) takes 2-5 minutes on a modern desktop. The progress bar shows real-time status.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"What's Natural Sort?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Natural Sort orders files the way humans expect: Chapter 1, Chapter 2, Chapter 10 — not Chapter 1, Chapter 10, Chapter 2. It uses your system's locale-aware numeric collation for correct ordering of numbered filenames.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Do chapter markers work in all players?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Chapter markers are embedded in M4A files using the standard ffmetadata format. They work in Apple Books, VLC, iTunes, foobar2000, and most audiobook players. MP3 and OGG outputs do not support chapter markers.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Can I use this on my phone?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Technically yes, but the tool is optimized for desktop browsers. Mobile browsers have tighter memory limits and smaller screens, which makes managing hundreds of files impractical. For best results, use a desktop or laptop.\"}]]}]]}]\n27:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n39:I[27201,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\"],\"IconMark\"]\n2a:[[\"$\",\"title\",\"0\",{\"children\":\"Free Audio Merger Online — No Sign Up | Free Tool Shed\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Combine multiple MP3, M4A, WAV, OGG, or FLAC files into a single audio file with chapter markers. Perfect for audiobooks. A free alternative to Adobe Audition. No sign up required.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"google-adsense-account\",\"content\":\"ca-pub-7700405385978151\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://freetoolshed.com/tools/media-toolkit/audio-merger\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"Free Audio Merger Online — No Sign Up | Free Tool Shed\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"Combine multiple MP3, M4A, WAV, OGG, or FLAC fil