xpanded:bg-muted aria-expanded:text-foreground dark:hover:bg-muted/50 size-8\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sun size-4 scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><path d=\"M12 2v2\"></path><path d=\"M12 20v2\"></path><path d=\"m4.93 4.93 1.41 1.41\"></path><path d=\"m17.66 17.66 1.41 1.41\"></path><path d=\"M2 12h2\"></path><path d=\"M20 12h2\"></path><path d=\"m6.34 17.66-1.41 1.41\"></path><path d=\"m19.07 4.93-1.41 1.41\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-moon absolute size-4 scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0\" aria-hidden=\"true\"><path d=\"M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401\"></path></svg></button></div></div></nav><div class=\"flex flex-1 flex-col\"><div class=\"mx-auto w-full max-w-7xl flex-1 px-4 py-6 sm:px-6 lg:px-8\"><div class=\"flex gap-6\"><main class=\"min-w-0 flex-1\"><div class=\"mb-4 hidden justify-center lg:flex\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:728px;height:90px;max-width:100%\" data-ad-slot=\"leaderboard\"></div></div><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"Free Subtitle Extractor\",\"description\":\"Extract subtitle tracks from video files. Export to SRT, ASS, or VTT format. Supports multiple tracks and languages.\",\"url\":\"https://freetoolshed.com/tools/media-toolkit/subtitle-extractor\",\"applicationCategory\":\"UtilitiesApplication\",\"operatingSystem\":\"Web\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"HowTo\",\"name\":\"How to Extract Subtitles\",\"description\":\"Extract embedded subtitle tracks from a video file and export them as SRT, ASS, or VTT.\",\"url\":\"https://freetoolshed.com/tools/media-toolkit/subtitle-extractor\",\"step\":[{\"@type\":\"HowToStep\",\"position\":1,\"name\":\"Add a video\",\"text\":\"Drag and drop a video file into the upload area, or click to browse. MKV, MP4, WebM, MOV, and AVI are supported.\"},{\"@type\":\"HowToStep\",\"position\":2,\"name\":\"Choose format\",\"text\":\"Select your desired subtitle format: SRT, ASS, or VTT.\"},{\"@type\":\"HowToStep\",\"position\":3,\"name\":\"Scan\",\"text\":\"Click \\\"Scan for Subtitles\\\" to probe the video for embedded subtitle tracks.\"},{\"@type\":\"HowToStep\",\"position\":4,\"name\":\"Extract\",\"text\":\"Click \\\"Extract\\\" on a specific track, or \\\"Extract All\\\" to get every track at once.\"},{\"@type\":\"HowToStep\",\"position\":5,\"name\":\"Download\",\"text\":\"Download your subtitle file(s).\"}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Is this subtitle extractor free?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, completely free. No sign-up, no file limits. The tool is ad-supported to stay free for everyone.\"}},{\"@type\":\"Question\",\"name\":\"What video formats are supported?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"MP4, MKV, WebM, MOV, and AVI are supported. MKV files are the most common source for embedded subtitles.\"}},{\"@type\":\"Question\",\"name\":\"What subtitle formats can I export to?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"SRT (SubRip), ASS (Advanced SubStation Alpha), and VTT (WebVTT). SRT is the most widely compatible format.\"}},{\"@type\":\"Question\",\"name\":\"Can I extract multiple subtitle tracks at once?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. The tool probes the video for all embedded subtitle tracks and lets you extract individual tracks or all of them at once with a single click.\"}},{\"@type\":\"Question\",\"name\":\"Do my files get uploaded?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. Everything runs client-side using ffmpeg.wasm. Your files never leave your device.\"}},{\"@type\":\"Question\",\"name\":\"Why were no subtitles found in my video?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Not all videos have embedded subtitle tracks. MP4 files from streaming services often use separate subtitle files or burned-in (hardcoded) subtitles that cannot be extracted. MKV files are the most common format for embedded subtitles.\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://freetoolshed.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Media Toolkit\",\"item\":\"https://freetoolshed.com/tools/media-toolkit\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Subtitle Extractor\"}]}</script><nav aria-label=\"Breadcrumb\" class=\"mb-4\"><ol class=\"flex items-center gap-1 text-sm text-muted-foreground\"><li class=\"flex items-center gap-1\"><a class=\"transition-colors hover:text-foreground\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right size-3.5 shrink-0\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg><a class=\"transition-colors hover:text-foreground\" href=\"/tools/media-toolkit\">Media Toolkit</a></li><li class=\"flex items-center gap-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right size-3.5 shrink-0\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg><span class=\"text-foreground\">Subtitle Extractor</span></li></ol></nav><h1 class=\"text-3xl font-bold tracking-tight\">Free Subtitle Extractor — Pull Subtitles from Video</h1><p class=\"mt-2 text-lg text-muted-foreground\">Extract embedded subtitle tracks from MKV, MP4, and other video files — a free alternative to HandBrake. No sign-up required.</p><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"James Nicolaus\",\"jobTitle\":\"Builder & Maintainer, Free Tool Shed\",\"description\":\"James Nicolaus builds and maintains every tool on Free Tool Shed. Each tool is designed, tested in real browsers across desktop and mobile, and shipped only after handling the messy edge cases — large files, slow connections, unusual inputs — that paid alternatives often hide behind sign-up walls.\",\"url\":\"https://freetoolshed.com/about\",\"worksFor\":{\"@type\":\"Organization\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\"}}</script><p class=\"mt-3 text-xs text-muted-foreground\">Built and maintained by<!-- --> <a class=\"font-medium text-foreground underline-offset-4 hover:underline\" rel=\"author\" href=\"/about\">James Nicolaus</a></p><section aria-label=\"Summary\" class=\"mt-6 rounded-lg border border-brand/30 bg-brand/5 p-4\"><p class=\"text-sm leading-relaxed text-foreground\">Extract embedded subtitle tracks from MKV, MP4, and WebM files into SRT, VTT, or ASS format — entirely in your browser via ffmpeg.wasm. Auto-detects every subtitle stream with language and codec; pick which to export, no upload required. No sign-up — a free alternative to Subtitle Edit&#x27;s online services and Happy Scribe.</p></section><div class=\"mt-6 grid gap-4 sm:grid-cols-2\"><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">Auto-Detect Tracks</h2><p class=\"mt-1 text-sm text-muted-foreground\">Automatically probes the video and lists all embedded subtitle tracks with language and codec info.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">3 Output Formats</h2><p class=\"mt-1 text-sm text-muted-foreground\">Export to SRT, ASS, or WebVTT. SRT is the most widely compatible. ASS preserves styling. VTT is for web players.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">Batch Extract</h2><p class=\"mt-1 text-sm text-muted-foreground\">Extract a single track or all tracks at once. Each track downloads as a separate file with language tags.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">100% Private</h2><p class=\"mt-1 text-sm text-muted-foreground\">All processing happens in your browser using WebAssembly. Your files never leave your device.</p></div></div><div class=\"mt-8\"><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--></div><div class=\"my-8 flex justify-center\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:728px;height:90px;max-width:100%\" data-ad-slot=\"mid-content\"></div></div><section class=\"prose prose-sm dark:prose-invert max-w-none\"><div data-orientation=\"horizontal\" role=\"separator\" aria-orientation=\"horizontal\" data-slot=\"separator\" class=\"shrink-0 bg-border data-horizontal:h-px data-horizontal:w-full data-vertical:w-px data-vertical:self-stretch my-8\"></div><div class=\"not-prose mb-10\"></div><h2 class=\"text-2xl font-semibold tracking-tight\">Free Subtitle Extractor — Pull Subtitles from Video Files Online</h2><p class=\"mt-4 text-muted-foreground\">The Free Subtitle Extractor lets you pull embedded subtitle tracks from any video file — directly in your browser. Export to SRT, ASS, or WebVTT format. Supports multiple tracks and languages. No sign-up, no uploads, no file size limits.</p><h2 class=\"mt-10 text-2xl font-semibold tracking-tight\">Features</h2><ul class=\"mt-4 space-y-2 text-muted-foreground\"><li><strong>Auto-detect subtitle tracks</strong> — Probes the video container and lists all embedded subtitle streams with language codes and codec information.</li><li><strong>3 output formats</strong> — SRT (SubRip) for maximum compatibility, ASS (Advanced SubStation Alpha) for styled subtitles, and VTT (WebVTT) for HTML5 video players.</li><li><strong>Single or batch extract</strong> — Extract one specific track or all tracks at once. Each track downloads as a separate file tagged with its stream index and language code.</li><li><strong>Language detection</strong> — Displays language codes (eng, spa, jpn, etc.) from the video metadata so you can identify which track to extract.</li><li><strong>100% client-side</strong> — Uses ffmpeg.wasm (WebAssembly). Your files never leave your device.</li></ul><h2 class=\"mt-10 text-2xl font-semibold tracking-tight\">How to Extract Subtitles</h2><ol class=\"mt-4 space-y-2 text-muted-foreground\"><li><strong>1. Add a video</strong> — Drag and drop a video file into the upload area, or click to browse. MKV, MP4, WebM, MOV, and AVI are supported.</li><li><strong>2. Choose format</strong> — Select your desired subtitle format: SRT, ASS, or VTT.</li><li><strong>3. Scan</strong>— Click &quot;Scan for Subtitles&quot; to probe the video for embedded subtitle tracks.</li><li><strong>4. Extract</strong>— Click &quot;Extract&quot; on a specific track, or &quot;Extract All&quot; to get every track at once.</li><li><strong>5. Download</strong> — Download your subtitle file(s).</li></ol><h2 class=\"mt-10 text-2xl font-semibold tracking-tight\">Subtitle Extractor vs. HandBrake</h2><div class=\"mt-4 overflow-x-auto\"><table class=\"w-full text-sm\"><thead><tr class=\"border-b border-border\"><th class=\"py-2 pr-4 text-left font-semibold\">Feature</th><th class=\"py-2 pr-4 text-left font-semibold\">Subtitle Extractor</th><th class=\"py-2 pr-4 text-left font-semibold\">HandBrake</th></tr></thead><tbody class=\"text-muted-foreground\"><tr class=\"border-b border-border\"><td class=\"py-2 pr-4 font-medium\">Price</td><td class=\"py-2 pr-4\">Free (browser)</td><td class=\"py-2 pr-4\">Free (desktop app)</td></tr><tr class=\"border-b border-border\"><td class=\"py-2 pr-4 font-medium\">Purpose</td><td class=\"py-2 pr-4\">Extract subtitle tracks only</td><td class=\"py-2 pr-4\">Full video transcoder</td></tr><tr class=\"border-b border-border\"><td class=\"py-2 pr-4 font-medium\">Install required</td><td class=\"py-2 pr-4\">No — runs in browser</td><td class=\"py-2 pr-4\">Yes (desktop download)</td></tr><tr class=\"border-b border-border\"><td class=\"py-2 pr-4 font-medium\">Batch extract</td><td class=\"py-2 pr-4\">Yes — all tracks at once</td><td class=\"py-2 pr-4\">One at a time via export</td></tr><tr class=\"border-b border-border\"><td class=\"py-2 pr-4 font-medium\">Output formats</td><td class=\"py-2 pr-4\">SRT, ASS, VTT</td><td class=\"py-2 pr-4\">SRT (passthrough)</td></tr><tr class=\"border-b border-border\"><td class=\"py-2 pr-4 font-medium\">Privacy</td><td class=\"py-2 pr-4\">100% browser-based</td><td class=\"py-2 pr-4\">Desktop app (local)</td></tr></tbody></table></div><section aria-labelledby=\"tool-insights-tips\"><h2 id=\"tool-insights-tips\" class=\"text-2xl font-semibold tracking-tight\">Tips from Building <!-- -->the Subtitle Extractor</h2><p class=\"mt-3 max-w-3xl text-muted-foreground\">Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.</p><ul class=\"mt-4 grid max-w-3xl gap-3\"><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Check the codec before picking the output format</h3><p class=\"mt-1 text-sm text-muted-foreground\">Subtitle tracks come in different formats — SRT, ASS, PGS, VobSub. Text-based formats (SRT, ASS) extract cleanly; bitmap subtitles (PGS, VobSub) need OCR. The tool surfaces the codec so you know what to expect.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">SRT is the most portable format</h3><p class=\"mt-1 text-sm text-muted-foreground\">Most video players and platforms accept SRT. VTT is the web-native format (used by HTML5 video). ASS preserves styling and positioning. Pick by destination, default to SRT.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Language codes matter for streaming</h3><p class=\"mt-1 text-sm text-muted-foreground\">YouTube, Vimeo, and most streaming platforms expect ISO 639 language codes (en, es, fr) in the filename. The tool preserves track language metadata — use it to name files correctly.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Multiple subtitle tracks export separately</h3><p class=\"mt-1 text-sm text-muted-foreground\">Don&#x27;t try to merge English and Spanish into one file. Export each track separately and let the player decide which to display.</p></div></li></ul></section><section aria-labelledby=\"tool-insights-mistakes\"><h2 id=\"tool-insights-mistakes\" class=\"text-2xl font-semibold tracking-tight\">Common Mistakes to Avoid</h2><ul class=\"mt-4 grid max-w-3xl gap-3\"><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Expecting bitmap subtitles to come out as text</h3><p class=\"mt-1 text-sm text-muted-foreground\">PGS and VobSub subtitles are images, not text. Extracting them yields an image stream, not characters. For text, you need OCR — outside the scope of this tool.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Picking the wrong track in a multi-language file</h3><p class=\"mt-1 text-sm text-muted-foreground\">Many MKVs ship with several language tracks. The tool lists each one with its language code; pick the one you actually want before exporting.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Forgetting to check timing offsets</h3><p class=\"mt-1 text-sm text-muted-foreground\">Subtitles sometimes lag or lead the audio by a fixed offset. After extracting, play the result alongside the video to verify timing before considering the file done.</p></div></li></ul></section><section aria-labelledby=\"tool-insights-takeaways\" class=\"rounded-lg border border-brand/30 bg-brand/5 p-5\"><h2 id=\"tool-insights-takeaways\" class=\"text-lg font-semibold tracking-tight\">Key Takeaways</h2><ul class=\"mt-3 space-y-2\"><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">The Subtitle Extractor pulls embedded subtitle tracks from MKV, MP4, and WebM files.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">Outputs to SRT, VTT, or ASS depending on the source codec.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">Auto-detects every subtitle stream with language and codec; pick which to export.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">It is a free alternative to Subtitle Edit&#x27;s online services and Happy Scribe.</span></li></ul></section><h2 class=\"mt-10 text-2xl font-semibold tracking-tight\">Frequently Asked Questions</h2><div class=\"mt-4 space-y-4 text-muted-foreground\"><div><h3 class=\"font-semibold text-foreground\">Why were no subtitles found?</h3><p class=\"mt-1\">Not all videos have embedded subtitle tracks. Many MP4 files from streaming services use burned-in (hardcoded) subtitles that are rendered directly into the video frames — these cannot be extracted. MKV files from media libraries are the most common source for extractable embedded subtitles.</p></div><div><h3 class=\"font-semibold text-foreground\">What&#x27;s the difference between SRT, ASS, and VTT?</h3><p class=\"mt-1\"><strong>SRT</strong> is the simplest and most widely compatible format — plain text with timestamps. <strong>ASS</strong> supports rich styling, fonts, colors, and positioning. <strong>VTT</strong> <!-- -->is the web standard used by HTML5<!-- --> <code>&lt;track&gt;</code> elements. For most use cases, SRT is the safest choice.</p></div><div><h3 class=\"font-semibold text-foreground\">Can I extract subtitles from a DVD or Blu-ray?</h3><p class=\"mt-1\">DVD subtitles (VOBsub) and Blu-ray subtitles (PGS) are image-based, not text-based. While ffmpeg can extract them, the result is a series of bitmap images, not editable text. This tool works best with text-based subtitle formats like SRT, ASS, and MOV text tracks.</p></div></div></section><!--$--><!--/$--></main><aside class=\"hidden w-[300px] shrink-0 lg:block\"><div class=\"sticky top-20\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:300px;height:250px;max-width:100%\" data-ad-slot=\"sidebar\"></div><div id=\"tool-guide-portal\"></div></div></aside></div></div></div><footer class=\"border-t border-border bg-muted/40\"><div class=\"mx-auto flex max-w-7xl flex-col items-center gap-4 px-4 py-8 sm:flex-row sm:justify-between sm:px-6 lg:px-8\"><p class=\"text-sm text-muted-foreground\">© <!-- -->2026<!-- --> Free Tool Shed. All rights reserved.</p><nav class=\"flex gap-4 text-sm text-muted-foreground\"><a class=\"transition-colors hover:text-foreground\" href=\"/about\">About</a><a class=\"transition-colors hover:text-foreground\" href=\"/contact\">Contact</a><a class=\"transition-colors hover:text-foreground\" href=\"/privacy\">Privacy</a><a class=\"transition-colors hover:text-foreground\" href=\"/terms\">Terms</a></nav></div></footer><script src=\"/_next/static/chunks/0eyplc079uusk.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[83661,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\\"/_next/static/chunks/0zv.me6xdrdsz.js\\\",\\\"/_next/static/chunks/0ag6f0zogt0qg.js\\\",\\\"/_next/static/chunks/04p0ygcx_g620.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/0_pa1c_tsbiw0.js\\\",\\\"/_next/static/chunks/10nuyoal1pib2.js\\\"],\\\"ThemeProvider\\\"]\\n3:I[46798,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\\"/_next/static/chunks/0zv.me6xdrdsz.js\\\",\\\"/_next/static/chunks/0ag6f0zogt0qg.js\\\",\\\"/_next/static/chunks/04p0ygcx_g620.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/0_pa1c_tsbiw0.js\\\",\\\"/_next/static/chunks/10nuyoal1pib2.js\\\"],\\\"TooltipProvider\\\"]\\n4:I[22016,[\\\"/_next/static/chunks/0zif8_