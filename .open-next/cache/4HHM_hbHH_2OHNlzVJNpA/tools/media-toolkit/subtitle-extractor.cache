etInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"Person\\\",\\\"name\\\":\\\"James Nicolaus\\\",\\\"jobTitle\\\":\\\"Builder & Maintainer, Free Tool Shed\\\",\\\"description\\\":\\\"James Nicolaus builds and maintains every tool on Free Tool Shed. Each tool is designed, tested in real browsers across desktop and mobile, and shipped only after handling the messy edge cases — large files, slow connections, unusual inputs — that paid alternatives often hide behind sign-up walls.\\\",\\\"url\\\":\\\"https://freetoolshed.com/about\\\",\\\"worksFor\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"Free Tool Shed\\\",\\\"url\\\":\\\"https://freetoolshed.com\\\"}}\"}}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-xs text-muted-foreground\",\"children\":[\"Built and maintained by\",\" \",[\"$\",\"$Le\",null,{\"href\":\"/about\",\"className\":\"font-medium text-foreground underline-offset-4 hover:underline\",\"rel\":\"author\",\"children\":\"James Nicolaus\"}],\"$undefined\"]}]]\n7:[\"$\",\"section\",null,{\"aria-label\":\"Summary\",\"className\":\"mt-6 rounded-lg border border-brand/30 bg-brand/5 p-4\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm leading-relaxed text-foreground\",\"children\":\"Extract embedded subtitle tracks from MKV, MP4, and WebM files into SRT, VTT, or ASS format — entirely in your browser via ffmpeg.wasm. Auto-detects every subtitle stream with language and codec; pick which to export, no upload required. No sign-up — a free alternative to Subtitle Edit's online services and Happy Scribe.\"}]}]\n8:[\"$\",\"div\",null,{\"className\":\"mt-6 grid gap-4 sm:grid-cols-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Auto-Detect Tracks\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Automatically probes the video and lists all embedded subtitle tracks with language and codec info.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"3 Output Formats\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Export to SRT, ASS, or WebVTT. SRT is the most widely compatible. ASS preserves styling. VTT is for web players.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Batch Extract\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Extract a single track or all tracks at once. Each track downloads as a separate file with language tags.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"100% Private\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"All processing happens in your browser using WebAssembly. Your files never leave your device.\"}]]}]]}]\n9:[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L10\",null,{}]}]\na:[\"$\",\"div\",null,{\"className\":\"my-8 flex justify-center\",\"children\":[\"$\",\"$L11\",null,{\"slot\":\"mid-content\"}]}]\nb:[\"$\",\"section\",null,{\"className\":\"prose prose-sm dark:prose-invert max-w-none\",\"children\":[[\"$\",\"$L12\",null,{\"className\":\"my-8\"}],[\"$\",\"div\",null,{\"className\":\"not-prose mb-10\"}],[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Free Subtitle Extractor — Pull Subtitles from Video Files Online\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-muted-foreground\",\"children\":\"The Free Subtitle Extractor lets you pull embedded subtitle tracks from any video file — directly in your browser. Export to SRT, ASS, or WebVTT format. Supports multiple tracks and languages. No sign-up, no uploads, no file size limits.\"}],[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Features\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 space-y-2 text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Auto-detect subtitle tracks\"}],\" — Probes the video container and lists all embedded subtitle streams with language codes and codec information.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"3 output formats\"}],\" — SRT (SubRip) for maximum compatibility, ASS (Advanced SubStation Alpha) for styled subtitles, and VTT (WebVTT) for HTML5 video players.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Single or batch extract\"}],\" — Extract one specific track or all tracks at once. Each track downloads as a separate file tagged with its stream index and language code.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Language detection\"}],\" — Displays language codes (eng, spa, jpn, etc.) from the video metadata so you can identify which track to extract.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"100% client-side\"}],\" — Uses ffmpeg.wasm (WebAssembly). Your files never leave your device.\"]}]]}],[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"How to Extract Subtitles\"}],[\"$\",\"ol\",null,{\"className\":\"mt-4 space-y-2 text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"1. Add a video\"}],\" — Drag and drop a video file into the upload area, or click to browse. MKV, MP4, WebM, MOV, and AVI are supported.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"2. Choose format\"}],\" — Select your desi