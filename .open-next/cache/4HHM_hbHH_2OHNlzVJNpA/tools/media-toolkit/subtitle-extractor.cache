ull,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Check the codec before picking the output format\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$Lf\",null,{\"iconNode\":[[\"path\",{\"d\":\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\",\"key\":\"1gvzjb\"}],[\"path\",{\"d\":\"M9 18h6\",\"key\":\"x1upvd\"}],[\"path\",{\"d\":\"M10 22h4\",\"key\":\"ceow96\"}]],\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Check the codec before picking the output format\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Subtitle tracks come in different formats — SRT, ASS, PGS, VobSub. Text-based formats (SRT, ASS) extract cleanly; bitmap subtitles (PGS, VobSub) need OCR. The tool surfaces the codec so you know what to expect.\"}]]}]]}],[\"$\",\"li\",\"SRT is the most portable format\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$Lf\",null,{\"iconNode\":\"$19:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"SRT is the most portable format\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Most video players and platforms accept SRT. VTT is the web-native format (used by HTML5 video). ASS preserves styling and positioning. Pick by destination, default to SRT.\"}]]}]]}],[\"$\",\"li\",\"Language codes matter for streaming\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$Lf\",null,{\"iconNode\":\"$19:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Language codes matter for streaming\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"YouTube, Vimeo, and most streaming platforms expect ISO 639 language codes (en, es, fr) in the filename. The tool preserves track language metadata — use it to name files correctly.\"}]]}]]}],[\"$\",\"li\",\"Multiple subtitle tracks export separately\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$Lf\",null,{\"iconNode\":\"$19:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Multiple subtitle tracks export separately\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Don't try to merge English and Spanish into one file. Export each track separately and let the player decide which to display.\"}]]}]]}]]}]]}],[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-mistakes\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-mistakes\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Common Mistakes to Avoid\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Expecting bitmap subtitles to come out as text\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$Lf\",null,{\"iconNode\":[[\"path\",{\"d\":\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\",\"key\":\"wmoenq\"}],[\"path\",{\"d\":\"M12 9v4\",\"key\":\"juzpu7\"}],[\"path\",{\"d\":\"M12 17h.01\",\"key\":\"p32p05\"}]],\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],\"$L1f\"]}],\"$L20\",\"$L21\"]}]]}],\"$L22\"]\n1a:[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Frequently Asked Questions\"}]\n1b:[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-4 text-muted-foreground\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Why were no subtitles found?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Not all videos have embedded subtitle tracks. Many MP4 files from streaming services use burned-in (hardcoded) subtitles that are rendered directly into the video frames — these cannot be extracted. MKV files from media libraries are the most common source for extractable embedded subtitles.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"What's the difference between SRT, ASS, and VTT?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":[[\"$\",\"strong\",null,{\"children\":\"SRT\"}],\" is the simplest and most widely compatible format — plain text with timestamps. \",[\"$\",\"strong\",null,{\"children\":\"ASS\"}],\" supports rich styling, fonts, colors, and positioning. \",[\"$\",\"strong\",null,{\"children\":\"VTT\"}],\" \",\"is the web standard used by HTML5\",\" \",[\"$\",\"code\",null,{\"children\":\"<track>\"}],\" elements. For most use cases, SRT is the safest choice.\"]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Can I extract subtitles from a DVD or Blu-ray?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"DVD subtitles (VOBsub) and Blu-ray subtitles (PGS) are image-based, not text-based. While ffmpeg can extract them, the result is a series of bitmap images, not editable text. This tool works best with text-based subtitle formats like SRT, ASS, and MOV text tracks.\"}]]}]]}]\n1e:null\n1f:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Expecting bitmap subtitles to come out as text\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"PGS and VobSub subtitles are images, not text. Extracting them yields an image stream, not characters. For text, you need OCR — outside the scope of this tool.\"}]]}]\n20:[\"$\",\"li\",\"Picking the wrong track in a multi-language file\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$Lf\",null,{\"iconNode\":\"$19:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Picking the wrong track in a multi-language file\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Many MKVs ship with several language tracks. The tool lists each one with its language code; pick the one you actually want before exporting.\"}]]}]]}]\n21:[\"$\",\"li\",\"Forgetting to check timing offsets\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$Lf\",null,{\"iconNode\":\"$19:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Forgetting to check timing offsets\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Subtitles sometimes lag or lead the audio by a fixed offset. After extracting, play the result alongside the video to verify timing before considering the file done.\"}]]}]]}]\n22:[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-takeaways\",\"className\":\"rounded-lg border border-brand/30 bg-brand/5 p-5\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-takeaways\",\"className\":\"text-lg font-semibold tracking-tight\",\"children\":\"Key Takeaways\"}],[\"$\",\"ul\",null,{\"className\":\"mt-3 space-y-2\",\"children\":[[\"$\",\"li\",\"The Subtitle Extractor pulls embedded subtitle tracks from MKV, MP4, and WebM files.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$Lf\",null,{\"iconNode\":[[\"circle\",{\"cx\":\"12\",\"cy\":\"12\",\"r\":\"10\",\"key\":\"1mglay\"}],[\"path\",{\"d\":\"m9 12 2 2 4-4\",\"key\":\"dzmm74\"}]],\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"The Subtitle Extractor pulls embedded subtitle tracks from MKV, MP4, and WebM files.\"}]]}],[\"$\",\"li\",\"Outputs to SRT, VTT, or ASS depending on the source codec.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$Lf\",null,{\"iconNode\":\"$22:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"Outputs to SRT, VTT, or ASS depending on the source codec.\"}]]}],[\"$\",\"li\",\"Auto-detects every subtitle stream with language and codec; pick which to export.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$Lf\",null,{\"iconNode\":\"$22:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"cla