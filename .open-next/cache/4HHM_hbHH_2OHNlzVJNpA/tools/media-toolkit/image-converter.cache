$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Screenshots, graphics, logos, icons\"}]]}],[\"$\",\"tr\",null,{\"className\":\"border-b border-border\",\"children\":[[\"$\",\"td\",null,{\"className\":\"py-2 pr-4 font-medium\",\"children\":\"JPG\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Lossy\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"No\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Small\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Photos, social media, email attachments\"}]]}],[\"$\",\"tr\",null,{\"className\":\"border-b border-border\",\"children\":[[\"$\",\"td\",null,{\"className\":\"py-2 pr-4 font-medium\",\"children\":\"WebP\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Both\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Yes\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Smaller\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Web images, replacing both PNG and JPG\"}]]}],[\"$\",\"tr\",null,{\"className\":\"border-b border-border\",\"children\":[[\"$\",\"td\",null,{\"className\":\"py-2 pr-4 font-medium\",\"children\":\"AVIF\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Both\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Yes\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Smallest\"}],[\"$\",\"td\",null,{\"className\":\"py-2 pr-4\",\"children\":\"Next-gen web images, maximum compression\"}]]}]]}]]}]}]\n1c:[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Frequently Asked Questions\"}]\n1d:[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-4 text-muted-foreground\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Will converting JPG to PNG improve image quality?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"No. Once an image has been saved as JPG, the lossy compression has already discarded some data. Converting to PNG preserves what remains without further loss, but it won't recover the original quality. The PNG file will likely be larger too. Convert from your original source if you need the best quality.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"What happens to transparency when converting to JPG?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"JPG doesn't support transparency. Any transparent areas in your image are filled with a white background. If you need to preserve transparency, convert to PNG or WebP instead.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Should I use WebP or AVIF for my website?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Both are excellent choices. WebP is supported in all modern browsers and offers 25-35% smaller files than JPG. AVIF achieves even better compression (about 20% smaller than WebP) but encoding is slower and support in older browsers is limited. For maximum compatibility, use WebP. For bleeding-edge optimization, use AVIF with a WebP fallback.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Why is AVIF greyed out in the format dropdown?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"AVIF encoding requires browser support. If the AVIF option is disabled, your browser cannot encode AVIF images. Chrome, Edge, and recent Firefox versions support AVIF encoding. Safari support is still limited.\"}]]}]]}]\n20:null\n","/tools/media-toolkit/image-converter":"1:\"$Sreact.fragment\"\n2:I[39756,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/