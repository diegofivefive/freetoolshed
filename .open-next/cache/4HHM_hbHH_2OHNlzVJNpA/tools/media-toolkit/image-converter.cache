,\"rel\":\"author\",\"children\":\"James Nicolaus\"}],\"$undefined\"]}]]\n1e:[\"$\",\"section\",null,{\"aria-label\":\"Summary\",\"className\":\"mt-6 rounded-lg border border-brand/30 bg-brand/5 p-4\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm leading-relaxed text-foreground\",\"children\":\"Convert images between JPEG, PNG, WebP, AVIF, BMP, and TIFF in your browser — adjust quality, dimensions, and format per file, and process a whole batch in one pass. No upload, no sign-up — a free alternative to TinyPNG Pro, CloudConvert, and Squoosh batch tooling.\"}]}]\n1f:[\"$\",\"div\",null,{\"className\":\"mt-6 grid gap-4 sm:grid-cols-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"4 Output Formats\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Convert to PNG, JPG, WebP, or AVIF. Lossy formats include quality control.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Batch Convert\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Drop multiple images and convert them all at once. Download individually or all at once.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Resize on Convert\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Optionally set a max dimension to scale down large images while preserving aspect ratio.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"100% Client-Side\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Uses browser Canvas API — your images never leave your device. No uploads, no file limits.\"}]]}]]}]\n20:[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L2b\",null,{}]}]\n21:[\"$\",\"div\",null,{\"className\":\"my-8 flex justify-center\",\"children\":[\"$\",\"$L17\",null,{\"slot\":\"mid-content\"}]}]\n22:[\"$\",\"section\",null,{\"className\":\"prose prose-sm dark:prose-invert max-w-none\",\"children\":[[\"$\",\"$L2c\",null,{\"className\":\"my-8\"}],[\"$\",\"div\",null,{\"className\":\"not-prose mb-10\"}],[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Free Image Converter — Change Image Formats Online\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-muted-foreground\",\"children\":\"The Free Image Converter lets you convert images between PNG, JPG, WebP, and AVIF directly in your browser. Batch convert entire folders of images, adjust quality, and optionally resize — all without sign-ups, uploads, or file size limits. Your images never leave your device.\"}],[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Features\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 space-y-2 text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"4 output formats\"}],\" — PNG (lossless), JPG (lossy), WebP (modern lossy/lossless), and AVIF (next-gen lossy). Accepts PNG, JPG, WebP, AVIF, BMP, GIF, TIFF, and SVG as input.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Quality control\"}],\" — Adjust quality from 1-100% for lossy formats. Find the perfect balance between file size and visual quality for your use case.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Optional resize\"}],\" — Set a max dimension to automatically scale down images while preserving aspect ratio. Perfect for preparing images for web or social media.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Batch conversion\"}],\" — Add as many images as you want and convert them all at once. Each file gets a thumbnail preview and individual download button.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"100% client-side\"}],\"— Uses the browser's Canvas API. No server uploads, no external dependencies, no file size limits.\"]}]]}],[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"How to Convert Images\"}],[\"$\",\"ol\",null,{\"className\":\"mt-4 space-y-2 text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"1. Add images\"}],\" — Drag and drop image files into the upload area, or click to browse. Add files in multiple batches if needed.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"2. Choose format\"}],\" — Select your target format: PNG, JPG, WebP, or AVIF.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"3. Set quality\"}],\" — For lossy formats, adjust the quality slider (1-100%). Higher values produce better quality but larger files. PNG is always lossless.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"4. Optional resize\"}],\" — Enter a max dimension in pixels to scale down large images. Leave blank to keep the original size.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"5. Convert & download\"}],\" — Click Convert and download each file individually, or use Download All for the entire batch.\"]}]]}],[[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-tips\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-tips\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":[\"Tips from Building \",\"the Image Converter\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"WebP and AVIF are smaller than JPEG at the same quality\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\",\"key\":\"1gvzjb\"}],[\"path\",{\"d\":\"M9 18h6\",\"key\":\"x1upvd\"}],[\"path\",{\"d\":\"M10 22h4\",\"key\":\"ceow96\"}]],\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],\"$L2d\"]}],\"$L2e\",\"$L2f\",\"$L30\"]}]]}],\"$L31\",\"$L32\"],\"$L33\",\"$L34\",\"$L35\",\"$L36\"]}]\n23:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0my44zep2qx-6.js\",\"async\":true,\"nonce\":\"$undefined\"}]\n24:[\"$\",\"$L37\",null,{\"children\":[\"$\",\"$29\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@38\"}]}]\n2d:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"WebP and AVIF are smaller than JPEG at the same quality\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"For web use, WebP is ~25–35% smaller than JPEG at visually identical quality; AVIF is ~50% smaller. Browser support is now universal — there's little reason to ship JPEG for new web work.\"}]]}]\n2e:[\"$\",\"li\",\"PNG only for graphics with sharp edges or transparency\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$22:props:children:8:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"PNG only for graphics with sharp edges or transparency\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"PNG is lossless but huge for photographs. Use it for screenshots, logos, and UI elements; use JPEG/WebP/AVIF for photos. Mixing them up is the most common reason images load slowly.\"}]]}]]}]\n2f:[\"$\",\"li\",\"Resize before compressing for max savings\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$22:props:children:8:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Resize before compressing for max savings\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"A 4000×3000 photo at quality 60 is bigger than a 1600×1200 photo at quality 85. Most web destinations don't need 4K source resolution — downsize first, compress second.\"}]]}]]}]\n30:[\"$\",\"li\",\"Batch with consistent settings, then spot-check\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$22:props:children:8:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Batch with consistent settings, then spot-check\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"When converting many images, set one tuning (quality, max dimensions) for the whole batch. Then spot-check 2–3 representative outputs before publishing.\"}]]}]]}]\n31:[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-mistakes\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-mistakes\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Common Mistakes to Avoid\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Setting JPEG quality to 100\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\",\"key\":\"wmoenq\"}],[\"path\",{\"d\":\"M12 9v4\",\"key\":\"juzpu7\"}],[\"path\",{\"d\":\"M12 17h.01\",\"key\":\"p32p05\"}]],\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Setting JPEG quality to 100\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Quality 100 is barely distinguishable from 92–95 to the eye but produces a much larger file. The sweet spot for web JPEG is usually 75–85.\"}]]}]]}],[\"$\",\"li\",\"Converting screenshots to JPEG\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$31:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Converting screenshots to JPEG\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"JPEG's compression smears sharp pixel boundaries — exactly what screenshots are made of. Use PNG or WebP for screenshots; JPEG makes them look fuzzy and adds