;size-&#x27;])]:size-4 hover:bg-muted hover:text-foreground aria-expanded:bg-muted aria-expanded:text-foreground dark:hover:bg-muted/50 size-8\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sun size-4 scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><path d=\"M12 2v2\"></path><path d=\"M12 20v2\"></path><path d=\"m4.93 4.93 1.41 1.41\"></path><path d=\"m17.66 17.66 1.41 1.41\"></path><path d=\"M2 12h2\"></path><path d=\"M20 12h2\"></path><path d=\"m6.34 17.66-1.41 1.41\"></path><path d=\"m19.07 4.93-1.41 1.41\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-moon absolute size-4 scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0\" aria-hidden=\"true\"><path d=\"M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401\"></path></svg></button></div></div></nav><div class=\"flex flex-1 flex-col\"><div class=\"mx-auto w-full max-w-7xl flex-1 px-4 py-6 sm:px-6 lg:px-8\"><div class=\"flex gap-6\"><main class=\"min-w-0 flex-1\"><div class=\"mb-4 hidden justify-center lg:flex\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:728px;height:90px;max-width:100%\" data-ad-slot=\"leaderboard\"></div></div><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"Free Image Converter\",\"description\":\"Convert images between PNG, JPG, WebP, and AVIF with quality controls. Bulk convert, resize, and download — free, no sign-up, 100% browser-based.\",\"url\":\"https://freetoolshed.com/tools/media-toolkit/image-converter\",\"applicationCategory\":\"UtilitiesApplication\",\"operatingSystem\":\"Web\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"HowTo\",\"name\":\"How to Convert Images\",\"description\":\"Convert images between PNG, JPG, WebP, and AVIF with quality control and optional resizing.\",\"url\":\"https://freetoolshed.com/tools/media-toolkit/image-converter\",\"step\":[{\"@type\":\"HowToStep\",\"position\":1,\"name\":\"Add images\",\"text\":\"Drag and drop image files into the upload area, or click to browse. Add files in multiple batches if needed.\"},{\"@type\":\"HowToStep\",\"position\":2,\"name\":\"Choose format\",\"text\":\"Select your target format: PNG, JPG, WebP, or AVIF.\"},{\"@type\":\"HowToStep\",\"position\":3,\"name\":\"Set quality\",\"text\":\"For lossy formats, adjust the quality slider (1-100%). Higher values produce better quality but larger files. PNG is always lossless.\"},{\"@type\":\"HowToStep\",\"position\":4,\"name\":\"Optional resize\",\"text\":\"Enter a max dimension in pixels to scale down large images. Leave blank to keep the original size.\"},{\"@type\":\"HowToStep\",\"position\":5,\"name\":\"Convert & download\",\"text\":\"Click Convert and download each file individually, or use Download All for the entire batch.\"}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Can I convert PNG to WebP for free?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Drop your PNG files in, select WebP as the output format, set quality, and click Convert. All processing happens in your browser — no sign-up or uploads needed.\"}},{\"@type\":\"Question\",\"name\":\"Does converting to JPG remove transparency?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. JPG doesn't support transparency. Transparent areas are filled with white. If you need transparency, use PNG or WebP instead.\"}},{\"@type\":\"Question\",\"name\":\"What is WebP and why should I use it?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"WebP is a modern image format by Google that offers 25-35% smaller file sizes than JPG at the same quality. It supports both lossy and lossless compression plus transparency. All modern browsers support it.\"}},{\"@type\":\"Question\",\"name\":\"Is AVIF better than WebP?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"AVIF typically achieves 20% smaller files than WebP at similar quality, with better handling of fine detail. However, AVIF encoding is slower and browser support is slightly less universal. Both are excellent modern formats.\"}},{\"@type\":\"Question\",\"name\":\"Can I resize images while converting?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Set a max dimension (e.g. 1920px) and images larger than that will be scaled down proportionally. Smaller images are left at their original size.\"}},{\"@type\":\"Question\",\"name\":\"Is there a file size limit?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No hard limit. Since everything runs in your browser, the only constraint is your device's available memory. Most devices handle images up to 50-100 megapixels without issues.\"}},{\"@type\":\"Question\",\"name\":\"Are my images uploaded anywhere?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. The converter runs entirely in your browser using the Canvas API. Your images never leave your device — there are no server uploads at all.\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://freetoolshed.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Media Toolkit\",\"item\":\"https://freetoolshed.com/tools/media-toolkit\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Image Converter\"}]}</script><nav aria-label=\"Breadcrumb\" class=\"mb-4\"><ol class=\"flex items-center gap-1 text-sm text-muted-foreground\"><li class=\"flex items-center gap-1\"><a class=\"transition-colors hover:text-foreground\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right size-3.5 shrink-0\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg><a class=\"transition-colors hover:text-foreground\" href=\"/tools/media-toolkit\">Media Toolkit</a></li><li class=\"flex items-center gap-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right size-3.5 shrink-0\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg><span class=\"text-foreground\">Image Converter</span></li></ol></nav><h1 class=\"text-3xl font-bold tracking-tight\">Free Image Converter</h1><p class=\"mt-2 text-lg text-muted-foreground\">Bulk convert images between PNG, JPG, WebP, and AVIF — a free alternative to Adobe Photoshop&#x27;s batch export. No sign-up required.</p><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"James Nicolaus\",\"jobTitle\":\"Builder & Maintainer, Free Tool Shed\",\"description\":\"James Nicolaus builds and maintains every tool on Free Tool Shed. Each tool is designed, tested in real browsers across desktop and mobile, and shipped only after handling the messy edge cases — large files, slow connections, unusual inputs — that paid alternatives often hide behind sign-up walls.\",\"url\":\"https://freetoolshed.com/about\",\"worksFor\":{\"@type\":\"Organization\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\"}}</script><p class=\"mt-3 text-xs text-muted-foreground\">Built and maintained by<!-- --> <a class=\"font-medium text-foreground underline-offset-4 hover:underline\" rel=\"author\" href=\"/about\">James Nicolaus</a></p><section aria-label=\"Summary\" class=\"mt-6 rounded-lg border border-brand/30 bg-brand/5 p-4\"><p class=\"text-sm leading-relaxed text-foreground\">Convert images between JPEG, PNG, WebP, AVIF, BMP, and TIFF in your browser — adjust quality, dimensions, and format per file, and process a whole batch in one pass. No upload, no sign-up — a free alternative to TinyPNG Pro, CloudConvert, and Squoosh batch tooling.</p></section><div class=\"mt-6 grid gap-4 sm:grid-cols-2\"><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">4 Output Formats</h2><p class=\"mt-1 text-sm text-muted-foreground\">Convert to PNG, JPG, WebP, or AVIF. Lossy formats include quality control.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">Batch Convert</h2><p class=\"mt-1 text-sm text-muted-foreground\">Drop multiple images and convert them all at once. Download individually or all at once.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">Resize on Convert</h2><p class=\"mt-1 text-sm text-muted-foreground\">Optionally set a max dimension to scale down large images while preserving aspect ratio.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">100% Client-Side</h2><p class=\"mt-1 text-sm text-muted-foreground\">Uses browser Canvas API — your images never leave your device. No uploads, no file limits.</p></div></div><div class=\"mt-8\"><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--></div><div class=\"my-8 flex justify-center\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:728px;height:90px;max-width:100%\" data-ad-slot=\"mid-content\"></div></div><section class=\"prose prose-sm dark:prose-invert max-w-none\"><div data-orientation=\"horizontal\" role=\"separator\" aria-orientation=\"horizontal\" data-slot=\"separator\" class=\"shrink-0 bg-border data-horizontal:h-px data-horizontal:w-full data-vertical:w-px data-vertical:self-stretch my-8\"></div><div class=\"not-prose mb-10\"></div><h2 class=\"text-2xl font-semibold tracking-tight\">Free Image Converter — Change Image Formats Online</h2><p class=\"mt-4 text-muted-foreground\">The Free Image Converter lets you convert images between PNG, JPG, WebP, and AVIF directly in your browser. Batch convert entire folders of images, adjust quality, and optionally resize — all without sign-ups, uploads, or file size limits. Your images never leave your device.</p><h2 class=\"mt-10 text-2xl font-semibold tracking-tight\">Features</h2><ul class=\"mt-4 space-y-2 text-muted-foreground\"><li><strong>4 output formats</strong> — PNG (lossless), JPG (lossy), WebP (modern lossy/lossless), and AVIF (next-gen lossy). Accepts PNG, JPG, WebP, AVIF, BMP, GIF, TIFF, and SVG as input.</li><li><strong>Quality control</strong> — Adjust quality from 1-100% for lossy formats. Find the perfect balance between file size and visual quality for your use case.</li><li><strong>Optional resize</strong> — Set a max dimension to automatically scale down images while preserving aspect ratio. Perfect for preparing images for web or social media.</li><li><strong>Batch conversion</strong> — Add as many images as you want and convert them all at once. Each file gets a thumbnail preview and individual download button.</li><li><strong>100% client-side</strong>— Uses the browser&#x27;s Canvas API. No server uploads, no external dependencies, no file size limits.</li></ul><h2 class=\"mt-10 text-2xl font-semibold tracking-tight\">How to Convert Images</h2><ol class=\"mt-4 space-y-2 text-muted-foreground\"><li><strong>1. Add images</strong> — Drag and drop image files into the upload area, or click to browse. Add files in multiple batches if needed.</li><li><strong>2. Choose format</strong> — Select your target format: PNG, JPG, WebP, or AVIF.</li><li><strong>3. Set quality</strong> — For lossy formats, adjust the quality slider (1-100%). Higher values produce better quality but larger files. PNG is always lossless.</li><li><strong>4. Optional resize</strong> — Enter a max dimension in pixels to scale down large images. Leave blank to keep the original size.</li><li><strong>5. Convert &amp; download</strong> — Click Convert and download each file individually, or use Download All for the entire batch.</li></ol><section aria-labelledby=\"tool-insights-tips\"><h2 id=\"tool-insights-tips\" class=\"text-2xl font-semibold tracking-tight\">Tips from Building <!-- -->the Image Converter</h2><p class=\"mt-3 max-w-3xl text-muted-foreground\">Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.</p><ul class=\"mt-4 grid max-w-3xl gap-3\"><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">WebP and AVIF are smaller than JPEG at the same quality</h3><p class=\"mt-1 text-sm text-muted-foreground\">For web use, WebP is ~25–35% smaller than JPEG at visually identical quality; AVIF is ~50% smaller. Browser support is now universal — there&#x27;s little reason to ship JPEG for new web work.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">PNG only for graphics with sharp edges or transparency</h3><p class=\"mt-1 text-sm text-muted-foreground\">PNG is lossless but huge for photographs. Use it for screenshots, logos, and UI elements; use JPEG/WebP/AVIF for photos. Mixing them up is the most common reason images load slowly.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Resize before compressing for max savings</h3><p class=\"mt-1 text-sm text-muted-foreground\">A 4000×3000 photo at quality 60 is bigger than a 1600×1200 photo at quality 85. Most web destinations don&#x27;t need 4K source resolution — downsize first, compress second.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Batch with consistent settings, then spot-check</h3><p class=\"mt-1 text-sm text-muted-foreground\">When converting many images, set one tuning (quality, max dimensions) for the whole batch. Then spot-check 2–3 representative outputs before publishing.</p></div></li></ul></section><section aria-labelledby=\"tool-insights-mistakes\"><h2 id=\"tool-insights-mistakes\" class=\"text-2xl font-semibold tracking-tight\">Common Mistakes to Avoid</h2><ul class=\"mt-4 grid max-w-3xl gap-3\"><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Setting JPEG quality to 100</h3><p class=\"mt-1 text-sm text-muted-foreground\">Quality 100 is barely distinguishable from 92–95 to the eye but produces a much larger file. The sweet spot for web JPEG is usually 75–85.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Converting screenshots to JPEG</h3><p class=\"mt-1 text-sm text-muted-foreground\">JPEG&#x27;s compression smears sharp pixel boundaries — exactly what screenshots are made of. Use PNG or WebP for screenshots; JPEG makes them look fuzzy and adds compression artifacts around text.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Forgetting to strip EXIF metadata</h3><p class=\"mt-1 text-sm text-muted-foreground\">Photos from phones embed GPS coordinates, device info, and timestamps in EXIF. Strip metadata before publishing photos online unless that data is intentional.</p></div></li></ul></section><section aria-labelledby=\"tool-insights-takeaways\" class=\"rounded-lg border border-brand/30 bg-brand/5 p-5\"><h2 id=\"tool-insights-takeaways\" class=\"text-lg font-semibold tracking-tight\">Key Takeaways</h2><ul class=\"mt-3 space-y-2\"><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">The Image Converter handles JPEG, PNG, WebP, AVIF, BMP, and TIFF with per-file quality and resize settings.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">Batch mode converts multiple files at once with a shared or per-file configuration.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">All processing runs locally; image data never uploads.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">It is a free alternative to TinyPNG Pro, CloudConvert, and Squoosh batch tooling.</span></li></ul></section><h2 class=\"mt-10 text-2xl font-semibold tracking-tight\">Image Format Comparison</h2><div class=\"mt-4 overflow-x-auto\"><table class=\"w-full text-sm\"><thead><tr class=\"border-b border-border\"><th class=\"py-2 pr-4 text-left font-semibold\">Format</th><th class=\"py-2 pr-4 text-left font-semibold\">Type</th><th class=\"py-2 pr-4 text-left font-semibold\">Transparency</th><th class=\"py-2 pr-4 text-left font-semibold\">File Size</th><th class=\"py-2 pr-4 text-left font-semibold\">Best For</th></tr></thead><tbody class=\"text-muted-foreground\"><tr class=\"border-b border-border\"><td class=\"py-2 pr-4 font-medium\">PNG</td><td class=\"py-2 pr-4\">Lossless</td><td class=\"py-2 pr-4\">Yes</td><td class=\"py-2 pr-4\">Large</td><td class=\"py-2 pr-4\">Screenshots, graphics, logos, icons</td></tr><tr class=\"border-b border-border\"><td class=\"py-2 pr-4 font-medium\">JPG</td><td class=\"py-2 pr-4\">Lossy</td><td class=\"py-2 pr-4\">No</td><td class=\"py-2 pr-4\">Small</td><td class=\"py-2 pr-4\">Photos, social media, email attachments</td></tr><tr class=\"border-b border-border\"><td class=\"py-2 pr-4 font-medium\">WebP</td><td class=\"py-2 pr-4\">Both</td><td class=\"py-2 pr-4\">Yes</td><td class=\"py-2 pr-4\">Smaller</td><td class=\"py-2 pr-4\">Web images, replacing both PNG and JPG</td></tr><tr class=\"border-b border-border\"><td class=\"py-2 pr-4 font-medium\">AVIF</td><td class=\"py-2 pr-4\">Both</td><td class=\"py-2 pr-4\">Yes</td><td class=\"py-2 pr-4\">Smallest</td><td class=\"py-2 pr-4\">Next-gen web images, maximum compression</td></tr></tbody></table></div><h2 class=\"mt-10 text-2xl font-semibold tracking-tight\">Frequently Asked Questions</h2><div class=\"mt-4 space-y-4 text-muted-foreground\"><div><h3 class=\"font-semibold text-foreground\">Will converting JPG to PNG improve image quality?</h3><p class=\"mt-1\">No. Once an image has been saved as JPG, the lossy compression has already discarded some data. Converting to PNG preserves what remains without further loss, but it won&#x27;t recover the original quality. The PNG file will likely be larger too. Convert from your original source if you need the best quality.</p></div><div><h3 class=\"font-semibold text-foreground\">What happens to transparency when converting to JPG?</h3><p class=\"mt-1\">JPG doesn&#x27;t support transparency. Any transparent areas in your image are filled with a white background. If you need to preserve transparency, convert to PNG or WebP instead.</p></div><div><h3 class=\"font-semibold text-foreground\">Should I use WebP or AVIF for my website?</h3><p class=\"mt-1\">Both are excellent choices. WebP is supported in all modern browsers and offers 25-35% smaller files than JPG. AVIF achieves even better compression (about 20% smaller than WebP) but encoding is slower and support in older browsers is limited. For maximum compatibility, use WebP. For bleeding-edge optimization, use AVIF with a WebP fallback.</p></div><div><h3 class=\"font-semibold text-foreground\">Why is AVIF greyed out in the format dropdown?</h3><p class=\"mt-1\">AVIF encoding requires browser support. If the AVIF option is disabled, your browser cannot encode AVIF images. Chrome, Edge, and recent Firefox versions support AVIF encoding. Safari support is still limited.</p></div></div></section><!--$--><!--/$--></main><aside class=\"hidden w-[300px] shrink-0 lg:block\"><div class=\"sticky top-20\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:300px;height:250px;max-width:100%\" data-ad-slot=\"sidebar\"></div><div id=\"tool-guide-portal\"></div></div></aside></div></div></div><footer class=\"border-t border-border bg-muted/40\"><div class=\"mx-auto flex max-w-7xl flex-col items-center gap-4 px-4 py-8 sm:flex-row sm:justify-between sm:px-6 lg:px-8\"><p class=\"text-sm text-muted-foreground\">© <!-- -->2026<!-- --> Free Tool Shed. All rights reserved.</p><nav class=\"flex gap-4 text-sm text-muted-foreground\"><a class=\"transition-colors hover:text-foreground\" href=\"/about\">About</a><a class=\"transition-colors hover:text-foreground\" href=\"/contact\">Contact</a><a class=\"transition-colors hover:text-foreground\" href=\"/privacy\">Privacy</a><a class=\"transition-colors hover:text-foreground\" href=\"/terms\">Terms</a></nav></div></footer><script src=\"/_next/static/chunks/0eyplc079uusk.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[83661,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\\"/_next/static/chunks/0zv.me6xdrdsz.js\\\",\\\"/_next/static/chunks/0ag6f0zogt0qg.js\\\",\\\"/_next/static/chunks/04p0ygcx_g620.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/0_pa1c_tsbiw0.js\\\",\\\"/_next/static/chunks/10nuyoal1pib2.js\\\"],\\\"ThemeProvider\\\"]\\n3:I[46798,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\\"/_next/static/chunks/0zv.me6xdrdsz.js\\\",\\\"/_next/static/chunks/0ag6f0zogt0qg.js\\\",\\\"/_next/static/chunks/04p0ygcx_g620.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/0_pa1c_tsbiw0.js\\\",\\\"/_next/static/chunks/10nuyoal1pib2.js\\\"],\\\"TooltipProvider\\\"]\\n4:I[22016,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\\"/_next/static/chunks/0zv.me6xdrdsz.js\\\",\\\"/_next/static/chunks/0ag6f0zogt0qg.js\\\",\\\"/_next/static/chunks/04p0ygcx_g620.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/0_pa1c_tsbiw0.js\\\",\\\"/_next/static/chunks/10nuyoal1pib2.js\\\",\\\"/_next/static/chunks/11~hh-yuwxxvh.js\\\",\\\"/_next/static/chunks/0my44zep2qx-6.js\\\"],\\\"\\\"]\\n5:I[58541,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\\"/_next/static/chunks/0zv.me6xdrdsz.js\\\",\\\"/_next/static/chunks/0ag6f0zogt0qg.js\\\",\\\"/_next/static/chunks/04p0ygcx_g620.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/0_pa1c_tsbiw0.js\\\",\\\"/_next/static/chunks/10nuyoal1pib2.js\\\",\\\"/_next/static/chunks/11~hh-yuwxxvh.js\\\",\\\"/_next/static/chunks/0my44zep2qx-6.js\\\"],\\\"default\\\"]\\n6:I[50444,[\\\"/_next/stati