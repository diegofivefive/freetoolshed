r-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Is this pay stub generator really free?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes, completely free with no hidden fees, no premium tiers, and no per-stub charges. The tool is ad-supported so it can remain free for everyone.\"}]]}],[\"$\",\"details\",\"Do I need to create an account?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Do I need to create an account?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"No. You can start generating pay stubs immediately without signing up or providing any personal information.\"}]]}],[\"$\",\"details\",\"Is my data private and secure?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Is my data private and secure?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. All processing happens locally in your browser. Your employer details, employee information, and pay data never leave your device. Nothing is uploaded to any server.\"}]]}],[\"$\",\"details\",\"Does it support hourly and salaried employees?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Does it support hourly and salaried employees?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. Toggle between hourly and salary mode. For hourly workers, enter hours and rate and the amount calculates automatically. For salaried employees, enter the flat pay amount directly.\"}]]}],[\"$\",\"details\",\"What deductions are included?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"What deductions are included?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"One-click setup for 6 standard US deductions: Federal Income Tax, State Income Tax, Social Security, Medicare, 401(k), and Health Insurance. You can also add custom deductions for dental/vision, HSA/FSA, Roth 401(k), life insurance, garnishments, union dues, and more.\"}]]}],[\"$\",\"details\",\"What PDF templates are available?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"What PDF templates are available?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Three templates: Standard (traditional table layout with borders), Modern (accent-colored header with card-based sections), and Compact (dense layout for minimal page usage). All templates support custom accent colors and company logos.\"}]]}],[\"$\",\"details\",\"Can I track year-to-date totals?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Can I track year-to-date totals?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. Enter YTD amounts for each earnings and deduction row. YTD totals appear on the PDF when present. When you duplicate a stub from history for a new pay period, YTD values carry over.\"}]]}],\"$L33\",\"$L34\",\"$L35\"]}]]}]\n23:null\n24:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Mixing gross and net in the same column\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"A pay stub lists gross pay, then deductions, then net pay — in that order. Putting net in the earnings column makes the math look wrong to anyone (lender, landlord, accountant) reviewing the stub.\"}]]}]\n25:[\"$\",\"li\",\"Forgetting employer contributions\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":\"$1e:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Forgetting employer contributions\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Employer-side contributions (employer 401(k) match, FICA) don't reduce employee net pay but should appear on the stub for completeness. Adding them avoids questions later.\"}]]}]]}]\n26:[\"$\",\"li\",\"Using a generic deduction label\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":\"$1e:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Using a generic deduction label\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Labels like \\\"Other\\\" or \\\"Misc\\\" raise flags during income verification. Use specific labels — Health, Dental, 401(k), HSA — so the stub matches a payroll record.\"}]]}]]}]\n27:[\"$\",\"li\",\"Not previewing before exporting\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":\"$1e:1:p