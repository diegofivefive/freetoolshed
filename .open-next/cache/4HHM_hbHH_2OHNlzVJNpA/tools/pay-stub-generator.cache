ull,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Frequently Asked Questions\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 max-w-3xl space-y-2\",\"children\":[[\"$\",\"details\",\"Is this pay stub generator really free?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Is this pay stub generator really free?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes, completely free with no hidden fees, no premium tiers, and no per-stub charges. The tool is ad-supported so it can remain free for everyone.\"}]]}],[\"$\",\"details\",\"Do I need to create an account?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Do I need to create an account?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"No. You can start generating pay stubs immediately without signing up or providing any personal information.\"}]]}],[\"$\",\"details\",\"Is my data private and secure?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Is my data private and secure?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. All processing happens locally in your browser. Your employer details, employee information, and pay data never leave your device. Nothing is uploaded to any server.\"}]]}],[\"$\",\"details\",\"Does it support hourly and salaried employees?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Does it support hourly and salaried employees?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. Toggle between hourly and salary mode. For hourly workers, enter hours and rate and the amount calculates automatically. For salaried employees, enter the flat pay amount directly.\"}]]}],[\"$\",\"details\",\"What deductions are included?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"What deductions are included?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"One-click setup for 6 standard US deductions: Federal Income Tax, State Income Tax, Social Security, Medicare, 401(k), and Health Insurance. You can also add custom deductions for dental/vision, HSA/FSA, Roth 401(k), life insurance, garnishments, union dues, and more.\"}]]}],[\"$\",\"details\",\"What PDF templates are available?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"What PDF templates are available?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Three templates: Standard (traditional table layout with borders), Modern (accent-colored header with card-based sections), and Compact (dense layout for minimal page usage). All templates support custom accent colors and company logos.\"}]]}],[\"$\",\"details\",\"Can I track year-to-date totals?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Can I track year-to-date totals?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. Enter YTD amounts for each earnings 