{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/tools/layout,_N_T_/tools/periodic-table/layout,_N_T_/tools/periodic-table/page,_N_T_/tools/periodic-table"},"segmentPaths":["/_tree","/_full","/tools/periodic-table/__PAGE__","/tools/periodic-table","/tools","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable h-full\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.09zddjkbdep5a.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.09~u27dqhyhd6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/123doanyjnwwq.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/04uuf1716ltqa.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0eyplc079uusk.js\"/><script src=\"/_next/static/chunks/0tszvp5wpnn-t.js\" async=\"\"></script><script src=\"/_next/static/chunks/0bss4aof7q0cj.js\" async=\"\"></script><script src=\"/_next/static/chunks/0hi511ipeys_s.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-13rn3bqw7ype6.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zif8_3mgcc0x.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zv.me6xdrdsz.js\" async=\"\"></script><script src=\"/_next/static/chunks/0ag6f0zogt0qg.js\" async=\"\"></script><script src=\"/_next/static/chunks/04p0ygcx_g620.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0_pa1c_tsbiw0.js\" async=\"\"></script><script src=\"/_next/static/chunks/10nuyoal1pib2.js\" async=\"\"></script><script src=\"/_next/static/chunks/11~hh-yuwxxvh.js\" async=\"\"></script><script src=\"/_next/static/chunks/0wr50gw_ro7db.js\" async=\"\"></script><link rel=\"preconnect\" href=\"https://www.highperformanceformat.com\" crossorigin=\"anonymous\"/><link rel=\"dns-prefetch\" href=\"https://www.highperformanceformat.com\"/><link rel=\"preconnect\" href=\"https://pl29142630.profitablecpmratenetwork.com\" crossorigin=\"anonymous\"/><link rel=\"dns-prefetch\" href=\"https://pl29142630.profitablecpmratenetwork.com\"/><meta name=\"next-size-adjust\" content=\"\"/><title>Free Interactive Periodic Table Online — No Sign Up | Free Tool Shed</title><meta name=\"description\" content=\"Explore all 118 elements with interactive visualizations, temperature phase changes, property heatmaps, and a molar mass calculator. A free alternative to Merck PTE. No sign up required.\"/><meta name=\"google-adsense-account\" content=\"ca-pub-7700405385978151\"/><link rel=\"canonical\" href=\"https://freetoolshed.com/tools/periodic-table\"/><meta property=\"og:title\" content=\"Free Interactive Periodic Table Online — No Sign Up | Free Tool Shed\"/><meta property=\"og:description\" content=\"Explore all 118 elements with interactive visualizations, temperature phase changes, property heatmaps, and a molar mass calculator. A free alternative to Merck PTE. No sign up required.\"/><meta property=\"og:url\" content=\"https://freetoolshed.com/tools/periodic-table\"/><meta property=\"og:site_name\" content=\"Free Tool Shed\"/><meta property=\"og:image\" content=\"https://freetoolshed.com/screenshots/periodic-table.png\"/><meta property=\"og:image:width\" content=\"1440\"/><meta property=\"og:image:height\" content=\"900\"/><meta property=\"og:image:alt\" content=\"Interactive Periodic Table workspace screenshot\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Free Interactive Periodic Table Online — No Sign Up | Free Tool Shed\"/><meta name=\"twitter:description\" content=\"Explore all 118 elements with interactive visualizations, temperature phase changes, property heatmaps, and a molar mass calculator. A free alternative to Merck PTE. No sign up required.\"/><meta name=\"twitter:image\" content=\"https://freetoolshed.com/screenshots/periodic-table.png\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/favicon.ico\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\",\"logo\":\"https://freetoolshed.com/og-image.png\",\"description\":\"Free, browser-based tools that replace paid software. No sign up, no downloads, no servers — every tool runs client-side.\",\"founder\":{\"@type\":\"Person\",\"name\":\"James Nicolaus\",\"url\":\"https://freetoolshed.com/about\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Free Tool Shed\"}}</script><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"flex min-h-full flex-col antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><script>((a,b,c,d,e,f,g,h)=>{let i=document.documentElement,j=[\"light\",\"dark\"];function k(b){var c;(Array.isArray(a)?a:[a]).forEach(a=>{let c=\"class\"===a,d=c&&f?e.map(a=>f[a]||a):e;c?(i.classList.remove(...d),i.classList.add(f&&f[b]?f[b]:b)):i.setAttribute(a,b)}),c=b,h&&j.includes(c)&&(i.style.colorScheme=c)}if(d)k(d);else try{let a=localStorage.getItem(b)||c,d=g&&\"system\"===a?window.matchMedia(\"(prefers-color-scheme: dark)\").matches?\"dark\":\"light\":a;k(d)}catch(a){}})(\"class\",\"theme\",\"system\",null,[\"light\",\"dark\"],null,true,true)</script><nav class=\"