ild]:rounded-b-xl relative h-full transition-colors hover:border-brand/50 hover:bg-muted/50\",\"children\":[\"$\",\"div\",null,{\"data-slot\":\"card-header\",\"className\":\"group/card-header @container/card-header grid auto-rows-min items-start gap-1 rounded-t-xl px-4 group-data-[size=sm]/card:px-3 has-data-[slot=card-action]:grid-cols-[1fr_auto] has-data-[slot=card-description]:grid-rows-[auto_auto] [.border-b]:pb-4 group-data-[size=sm]/card:[.border-b]:pb-3\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center justify-between\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2\",\"children\":[[\"$\",\"$L3\",null,{\"iconNode\":[[\"path\",{\"d\":\"M13.172 2a2 2 0 0 1 1.414.586l6.71 6.71a2.4 2.4 0 0 1 0 3.408l-4.592 4.592a2.4 2.4 0 0 1-3.408 0l-6.71-6.71A2 2 0 0 1 6 9.172V3a1 1 0 0 1 1-1z\",\"key\":\"16rjxf\"}],[\"path\",{\"d\":\"M2 7v6.172a2 2 0 0 0 .586 1.414l6.71 6.71a2.4 2.4 0 0 0 3.191.193\",\"key\":\"178nd4\"}],[\"circle\",{\"cx\":\"10.5\",\"cy\":\"6.5\",\"r\":\".5\",\"fill\":\"currentColor\",\"key\":\"12ikhr\"}]],\"className\":\"lucide-tags size-4 text-brand\"}],[\"$\",\"div\",null,{\"data-slot\":\"card-title\",\"className\":\"font-heading font-medium group-data-[size=sm]/card:text-sm text-base\",\"children\":\"Metadata Editor\"}]]}],false]}],[\"$\",\"div\",null,{\"data-slot\":\"card-description\",\"className\":\"text-sm text-muted-foreground\",\"children\":\"View, edit, and strip metadata tags from audio and video files.\"}]]}]}]}]\ne:[\"$\",\"div\",null,{\"className\":\"my-8 flex justify-center\",\"children\":[\"$\",\"$L12\",null,{\"slot\":\"mid-content\"}]}]\nf:[\"$\",\"section\",null,{\"className\":\"prose prose-sm dark:prose-invert max-w-none\",\"children\":[[\"$\",\"$L13\",null,{\"className\":\"my-8\"}],[\"$\",\"div\",null,{\"className\":\"not-prose mb-10\"}],[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"What Is the Free Media Toolkit?\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-muted-foreground\",\"children\":\"The Free Media Toolkit is a growing collection of browser-based tools for working with audio and video files. Every tool runs entirely in your browser using WebAssembly (ffmpeg.wasm) — your files never leave your device, there's nothing to install, and no account is required.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-muted-foreground\",\"children\":\"Whether you need to merge hundreds of audiobook chapters into a single M4A, convert between audio formats, compress a video before sharing, or trim a clip, the Media Toolkit has a dedicated sub-tool for the job. Each tool is individually optimized for its task, so you get a focused, fast experience instead of a bloated all-in-one editor.\"}],[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Available Tools\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 space-y-2 text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Audio Merger\"}],\" — Combine MP3, M4A, WAV, OGG, or FLAC files into a single output file with optional chapter markers. Ideal for audiobooks and podcast compilations.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Audio Converter\"}],\" (coming soon) — Convert between audio formats with configurable quality. Single file or batch mode.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Video Compressor\"}],\" (coming soon) — Reduce video file size with quality presets while maintaining visual clarity.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Video Converter\"}],\" (coming soon) — Convert between MP4, WebM, MOV, AVI, and GIF formats.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Audio Trimmer\"}],\" (coming soon) — Trim audio files or split them at precise time markers.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Image Converter\"}],\" (coming soon) — Bulk convert images between PNG, JPG, WebP, and AVIF.\"]}]]}],[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Why Use Browser-Based Media Tools?\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 text-muted-foreground\",\"children\":[\"$\",\"ul\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Privacy\"}],\" — Your files stay on your device. No uploads, no cloud processing, no data retention policies to worry about.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"No installation\"}],\"— Works on any modern browser including Chromebooks and locked-down work machines where you can't install software.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"No sign-up\"}],\" — Most online media tools require an account or limit free usage. Every tool here is completely free with no restrictions.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"No file size limits\"}],\"— The only limit is your browser's available memory (typically 1-2 GB on desktop).\"]}]]}]}],[[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-tips\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-tips\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":[\"Tips from Building \",\"the Media Toolkit\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[\"$L14\",\"$L15\",\"$L16\",\"$L17\"]}]]}],\"$L18\",\"$L19\"],\"$L1a\",\"$L1b\"]}]\n10:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/