 3.191.193\",\"key\":\"178nd4\"}],[\"circle\",{\"cx\":\"10.5\",\"cy\":\"6.5\",\"r\":\".5\",\"fill\":\"currentColor\",\"key\":\"12ikhr\"}]],\"className\":\"lucide-tags size-4 text-brand\"}],[\"$\",\"div\",null,{\"data-slot\":\"card-title\",\"className\":\"font-heading font-medium group-data-[size=sm]/card:text-sm text-base\",\"children\":\"Metadata Editor\"}]]}],false]}],[\"$\",\"div\",null,{\"data-slot\":\"card-description\",\"className\":\"text-sm text-muted-foreground\",\"children\":\"View, edit, and strip metadata tags from audio and video files.\"}]]}]}]}]\n21:[\"$\",\"div\",null,{\"className\":\"my-8 flex justify-center\",\"children\":[\"$\",\"$L16\",null,{\"slot\":\"mid-content\"}]}]\n22:[\"$\",\"section\",null,{\"className\":\"prose prose-sm dark:prose-invert max-w-none\",\"children\":[[\"$\",\"$L2b\",null,{\"className\":\"my-8\"}],[\"$\",\"div\",null,{\"className\":\"not-prose mb-10\"}],[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"What Is the Free Media Toolkit?\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-muted-foreground\",\"children\":\"The Free Media Toolkit is a growing collection of browser-based tools for working with audio and video files. Every tool runs entirely in your browser using WebAssembly (ffmpeg.wasm) — your files never leave your device, there's nothing to install, and no account is required.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-muted-foreground\",\"children\":\"Whether you need to merge hundreds of audiobook chapters into a single M4A, convert between audio formats, compress a video before sharing, or trim a clip, the Media Toolkit has a dedicated sub-tool for the job. Each tool is individually optimized for its task, so you get a focused, fast experience instead of a bloated all-in-one editor.\"}],[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Available Tools\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 space-y-2 text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Audio Merger\"}],\" — Combine MP3, M4A, WAV, OGG, or FLAC files into a single output file with optional chapter markers. Ideal for audiobooks and podcast compilations.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Audio Converter\"}],\" (coming soon) — Convert between audio formats with configurable quality. Single file or batch mode.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Video Compressor\"}],\" (coming soon) — Reduce video file size with quality presets while maintaining visual clarity.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Video Converter\"}],\" (coming soon) — Convert between MP4, WebM, MOV, AVI, and GIF formats.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Audio Trimmer\"}],\" (coming soon) — Trim audio files or split them at precise time markers.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Image Converter\"}],\" (coming soon) — Bulk convert images between PNG, JPG, WebP, and AVIF.\"]}]]}],[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Why Use Browser-Based Media Tools?\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 text-muted-foreground\",\"children\":[\"$\",\"ul\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Privacy\"}],\" — Your files stay on your device. No uploads, no cloud processing, no data retention policies to worry about.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"No installation\"}],\"— Works on any modern browser including Chromebooks and locked-down work machines where you can't install software.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"No sign-up\"}],\" — Most online media tools require an account or limit free usage. Every tool here is completely free with no restrictions.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"No file size limits\"}],\"— The only limit is your browser's available memory (typically 1-2 GB on desktop).\"]}]]}]}],[[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-tips\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-tips\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":[\"Tips from Building \",\"the Media Toolkit\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[\"$L2c\",\"$L2d\",\"$L2e\",\"$L2f\"]}]]}],\"$L30\",\"$L31\"],\"$L32\",\"$L33\"]}]\n23:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/064cw2la3d-ye.js\",\"async\":true,\"nonce\":\"$undefined\"}]\n24:[\"$\",\"$L34\",null,{\"children\":[\"$\",\"$29\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@35\"}]}]\n2c:[\"$\",\"li\",\"Pick the tool by the job, not the file type\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\",\"key\":\"1gvzjb\"}],[\"path\",{\"d\":\"M9 18h6\",\"key\":\"x1upvd\"}],[\"path\",{\"d\":\"M10 22h4\",\"key\":\"ceow96\"}]],\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Pick the tool by the job, not the file type\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Many file types overlap several tools. A video can be converted, compressed, trimmed, or have its audio extracted — pick by what you're trying to accomplish, not by the file extension you happen to have.\"}]]}]]}]\n2d:[\"$\",\"li\",\"Run heavy jobs on a desktop, not a phone\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2c:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Run heavy jobs on a desktop, not a phone\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"ffmpeg.wasm runs the same code in any browser, but it scales with available CPU and memory. A 4K video compression that takes 90 seconds on a desktop can take 10+ minutes on a phone — or fail entirely.\"}]]}]]}]\n2e:[\"$\",\"li\",\"Chain tools when one pass isn't enough\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2c:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Chain tools when one pass isn't enough\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Extract audio with one tool, then trim it with another. Convert video, then compress the result. Each tool does one thing well; chain them for compound workflows.\"}]]}]]}]\n2f:[\"$\",\"li\",\"Files never leave your browser tab\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2c:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Files never leave your browser tab\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Every tool in the kit processes locally via ffmpeg.wasm. Closing the tab discards the work; refreshing reloads the runtime. Export what you need before navigating away.\"}]]}]]}]\n30:[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-mistakes\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-mistakes\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Common Mistakes to Avoid\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Using the converter when the trimmer is what you need\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\",\"key\":\"wmoenq\"}],[\"path\",{\"d\":\"M12 9v4\",\"key\":\"juzpu7\"}],[\"path\",{\"d\":\"M12 17h.01\",\"key\":\"p32p05\"}]],\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Using the converter when the trimmer is what you need\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Re-encoding to change a few seconds of a video is wasteful. If you only need to cut, use the trimmer — it can often stream-copy without re-encoding.\"}]]}]]}],[\"$\",\"li\",\"Loading multi-gigabyte files on a low-memory machine\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$30:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Loading multi-gigabyte files on a low-memory machine\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"ffmpeg.wasm holds decoded streams in memory. For very large files, work in smaller pieces or use the tool on a machine with more RAM.\"}]]}]]}],[\"$\",\"li\",\"Expecting cloud-grade speed from in-browser processing\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$30:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Expecting cloud-grade speed from in-browser processing\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Cloud-based converters offload work to powerful servers. The toolkit runs on your CPU. The trade-off is privacy and zero upload — at the cost of slower processing for the heaviest jobs.\"}]]}]]}]]}]]}]\n31:[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-takeaways\",\"className\":\"rounded-lg border border-brand/30 bg-brand/5 p-5\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-takeaways\",\"className\":\"text-lg font-semibold tracking-tight\",\"children\":\"Key Takeaways\"}],[\"$\",\"ul\",null,{\"className\":\"mt-3 space-y-2\",\"children\":[[\"$\",\"li\",\"The Media Toolkit is a browser-based suite for audio, video, and image work — ten tools in one collection.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"circle\",{\"cx\":\"12\",\"cy\":\"12\",\"r\":\"10\",\"key\":\"1mglay\"}],[\"path\",{\"d\":\"m9 12 2 2 4-4\",\"key\":\"dzmm74\"}]],\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"The Media Toolkit is a browser-based suite for audio, video, and image work — ten tools in one collection.\"}]]}],[\"$\",\"li\",\"Every tool runs locally via ffmpeg.wasm; no upload, no sign-up, no file-size cap beyond your machine's memory.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$31:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"Every tool runs locally via ffmpeg.wasm; no upload, no sign-up, no file-size cap beyond your machine's memory.\"}]]}],[\"$\",\"li\",\"Chain tools together (extract → trim → convert) for compound workflows without leaving the browser.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$31:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"Chain tools together (extract → trim → convert) for compound workflows without leaving the browser.\"}]]}],[\"$\",\"li\",\"It is a free alternative to Adobe Media Encoder, HandBrake Online, and CloudConvert.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$31:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"It is a free alternative to Adobe Media Encoder, HandBrake Online, and CloudConvert.\"}]]}]]}]]}]\n32:[\"$\",\"h2\",null,{\"className\":\"mt-10 text-2xl font-semibold tracking-tight\",\"children\":\"Frequently Asked Questions\"}]\n33:[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-4 text-muted-foreground\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"How does this work without uploading my files?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"The Media Toolkit uses ffmpeg.wasm — a WebAssembly port of the industry-standard ffmpeg library. It runs entirely in your browser tab. Your files are read from disk into browser memory, processed by the WASM engine, and the output is downloaded directly to your device.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Is there a file size limit?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"There's no artificial limit. The practical limit is your browser's available memory — typically 1-2 GB for the combined size of all input files. A warning appears if your files exceed 1 GB total.\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-semibold text-foreground\",\"children\":\"Which browsers are supported?\"}],[\"$\",\"p\",null,{\"className\":\"mt-1\",\"children\":\"Any modern Chromium-based browser (Chrome, Edge, Brave, Opera) and Firefox. Safari has limited WebAssembly support and may not work with all tools. Desktop browsers are recommended for the best performance.\"}]]}]]}]\n27:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n36:I[27201,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/