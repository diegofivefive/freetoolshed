"p\",null,{\"className\":\"mt-2 text-lg text-muted-foreground\",\"children\":\"Build professional, ATS-friendly resumes with multiple templates and instant PDF download — a free alternative to Resume.io, Zety, and Novoresume. No sign-up required.\"}]\n1c:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"Person\\\",\\\"name\\\":\\\"James Nicolaus\\\",\\\"jobTitle\\\":\\\"Builder & Maintainer, Free Tool Shed\\\",\\\"description\\\":\\\"James Nicolaus builds and maintains every tool on Free Tool Shed. Each tool is designed, tested in real browsers across desktop and mobile, and shipped only after handling the messy edge cases — large files, slow connections, unusual inputs — that paid alternatives often hide behind sign-up walls.\\\",\\\"url\\\":\\\"https://freetoolshed.com/about\\\",\\\"worksFor\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"Free Tool Shed\\\",\\\"url\\\":\\\"https://freetoolshed.com\\\"}}\"}}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-xs text-muted-foreground\",\"children\":[\"Built and maintained by\",\" \",[\"$\",\"$L4\",null,{\"href\":\"/about\",\"className\":\"font-medium text-foreground underline-offset-4 hover:underline\",\"rel\":\"author\",\"children\":\"James Nicolaus\"}],\"$undefined\"]}]]\n1d:[\"$\",\"section\",null,{\"aria-label\":\"Summary\",\"className\":\"mt-6 rounded-lg border border-brand/30 bg-brand/5 p-4\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm leading-relaxed text-foreground\",\"children\":\"Free Tool Shed's Resume Builder generates ATS-friendly PDF resumes from a guided form — multiple templates, drag-to-reorder sections, live preview, and one-click PDF export. Your draft auto-saves to your browser's local storage; nothing uploads. Built to pass applicant tracking systems without sacrificing visual polish. A free alternative to Resume.io, Zety, and Canva Pro.\"}]}]\n1e:[\"$\",\"div\",null,{\"className\":\"mt-6 grid gap-4 sm:grid-cols-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"4 ATS-Friendly Templates\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Choose from Modern, Classic, Professional, or Minimal layouts. Every template is optimized for Applicant Tracking Systems.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Instant PDF Download\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Download watermark-free PDF resumes in one click. Your data never leaves your browser — everything is processed locally on your device.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Drag-and-Drop Sections\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Reorder sections, show or hide them, and add from 11 section types including Skills, Certifications, Languages, Projects, and more.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Multiple Resumes & Backup\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Save resumes to local history, duplicate and rename them, and export/import JSON backups. Auto-save keeps your current draft safe.\"}]]}]]}]\n1f:[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L2a\",null,{}]}]\n20:[\"$\",\"div\",null,{\"className\":\"my-8 flex justify-center\",\"children\":[\"$\",\"$L16\",null,{\"slot\":\"mid-content\"}]}]\n21:[\"$\",\"div\",null,{\"className\":\"mt-16 space-y-12\",\"children\":[[\"$\",\"$L2b\",null,{}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold\",\"children\":\"Free Resume Builder Online\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Create a professional, ATS-friendly resume in minutes with Free Tool Shed's Resume Builder. Unlike Resume.io, Zety, and Novoresume — which let you build for free then charge $25+/month to download — our tool gives you instant, watermark-free PDF export at no cost. No sign-up, no account, no hidden fees. Your data stays in your browser and is never sent to a server.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Features\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid gap-x-8 gap-y-2 text-sm text-muted-foreground sm:grid-cols-2\",\"children\":[[\"$\",\"li\",null,{\"children\":\"4 ATS-friendly PDF templates (Modern, Classic, Professional, Minimal)\"}],[\"$\",\"li\",null,{\"children\":\"Instant PDF download — no watermark, no paywall\"}],[\"$\",\"li\",null,{\"children\":\"Real-time split-pane preview as you type\"}],[\"$\",\"li\",null,{\"children\":\"Drag-and-drop section reordering\"}],[\"$\",\"li\",null,{\"children\":\"Show/hide sections without losing data\"}],[\"$\",\"li\",null,{\"children\":\"Professional photo upload support\"}],[\"$\",\"li\",null,{\"children\":\"Customizable accent colors and fonts\"}],[\"$\",\"li\",null,{\"children\":\"Multiple font size presets (Compact, Standard, Spacious)\"}],[\"$\",\"li\",null,{\"children\":\"Save multiple resumes to local history\"}],[\"$\",\"li\",null,{\"children\":\"Duplicate, rename, and manage saved resumes\"}],[\"$\",\"li\",null,{\"children\":\"JSON export/import for backup and migration\"}],[\"$\",\"li\",null,{\"children\":\"Print-ready output via browser print dialog\"}],[\"$\",\"li\",null,{\"children\":\"11 section types: Summary, Experience, Education, Skills, Certifications, Languages, Projects, Volunteer, Awards, Publications, References\"}],[\"$\",\"li\",null,{\"children\":\"Bullet-point editor for work experience entries\"}],[\"$\",\"li\",null,{\"children\":\"Flexible date formatting (Jan 2024, 01/2024, 2024)\"}],[\"$\",\"li\",null,{\"children\":\"Client-side only — data never leaves your browser\"}]]}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"How to Build Your Resume\"}],[\"$\",\"ol\",null,{\"className\":\"mt-4 space-y-4\",\"children\":[[\"$\",\"li\",\"1. Enter your personal information\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"1. Enter your personal information\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Add your name, job title, email, phone, location, and optionally upload a professional photo.\"}]]}],[\"$\",\"li\",\"2. Fill in your experience and education\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"2. Fill in your experience and education\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Add your work history with bullet points for achievements, plus your education details. Use the 'Current role' toggle for your present job.\"}]]}],[\"$\",\"li\",\"3. Add skills and optional sections\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"3. Add skills and optional sections\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"List your skills with proficiency levels. Add certifications, languages, projects, volunteer work, awards, publications, or references as needed.\"}]]}],[\"$\",\"li\",\"4. Customize the design\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"4. Customize the design\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Choose from 4 professional templates, pick an accent color, select a font family, and adjust the font size to fit your content.\"}]]}],[\"$\",\"li\",\"5. Download your PDF\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"5. Download your PDF\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Click 'Download PDF' for an instant, watermark-free resume file. You can also print directly or save to history for later editing.\"}]]}]]}]]}],\"$L2c\",\"$L2d\",\"$L2e\"]}]\n22:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0fpp02.-61_bj.js\",\"async\":true,\"nonce\":\"$undefined\"}]\n23:[\"$\",\"$L2f\",null,{\"children\":[\"$\",\"$28\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@30\"}]}]\n2c:[[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-tips\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-tips\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":[\"Tips from Building \",\"the Resume Builder\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Write for the ATS first, the human second\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\",\"key\":\"1gvzjb\"}],[\"path\",{\"d\":\"M9 18h6\",\"key\":\"x1upvd\"}],[\"path\",{\"d\":\"M10 22h4\",\"key\":\"ceow96\"}]],\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children