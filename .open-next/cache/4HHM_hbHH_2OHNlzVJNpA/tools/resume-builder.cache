rand/5 p-4\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm leading-relaxed text-foreground\",\"children\":\"Free Tool Shed's Resume Builder generates ATS-friendly PDF resumes from a guided form — multiple templates, drag-to-reorder sections, live preview, and one-click PDF export. Your draft auto-saves to your browser's local storage; nothing uploads. Built to pass applicant tracking systems without sacrificing visual polish. A free alternative to Resume.io, Zety, and Canva Pro.\"}]}]\n1e:[\"$\",\"div\",null,{\"className\":\"mt-6 grid gap-4 sm:grid-cols-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"4 ATS-Friendly Templates\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Choose from Modern, Classic, Professional, or Minimal layouts. Every template is optimized for Applicant Tracking Systems.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Instant PDF Download\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Download watermark-free PDF resumes in one click. Your data never leaves your browser — everything is processed locally on your device.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Drag-and-Drop Sections\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Reorder sections, show or hide them, and add from 11 section types including Skills, Certifications, Languages, Projects, and more.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm f