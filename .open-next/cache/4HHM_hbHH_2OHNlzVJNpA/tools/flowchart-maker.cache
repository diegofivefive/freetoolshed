cription\\\":\\\"James Nicolaus builds and maintains every tool on Free Tool Shed. Each tool is designed, tested in real browsers across desktop and mobile, and shipped only after handling the messy edge cases — large files, slow connections, unusual inputs — that paid alternatives often hide behind sign-up walls.\\\",\\\"url\\\":\\\"https://freetoolshed.com/about\\\",\\\"worksFor\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"Free Tool Shed\\\",\\\"url\\\":\\\"https://freetoolshed.com\\\"}}\"}}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-xs text-muted-foreground\",\"children\":[\"Built and maintained by\",\" \",[\"$\",\"$L4\",null,{\"href\":\"/about\",\"className\":\"font-medium text-foreground underline-offset-4 hover:underline\",\"rel\":\"author\",\"children\":\"James Nicolaus\"}],\"$undefined\"]}]]\n1c:[\"$\",\"div\",null,{\"className\":\"mt-6 grid gap-4 sm:grid-cols-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Drag & Drop Flowcharting\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Draw process, decision, terminal, and data shapes with intuitive click-to-place tools. Connect nodes with auto-routing edges.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Smart Connection Routing\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Straight, bezier, and orthogonal edge routing with automatic anchor snapping. Add labels and arrowheads to connections.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"SVG, PNG & PDF Export\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text