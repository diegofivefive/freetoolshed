",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Frequently Asked Questions\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-3\",\"children\":[[\"$\",\"details\",\"Is this flowchart maker really free?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Is this flowchart maker really free?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes, completely free. No hidden fees, no premium tiers, and no sign-up required. The tool is ad-supported so it can remain free for everyone.\"}]]}],[\"$\",\"details\",\"Do I need to create an account?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Do I need to create an account?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"No. You can start building flowcharts immediately without signing up or providing any personal information.\"}]]}],[\"$\",\"details\",\"What types of diagrams can I create?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"What types of diagrams can I create?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Flowcharts, process diagrams, decision trees, data flow diagrams, SDLC diagrams, and any box-and-arrow diagram. The tool includes 11 standard shape types covering all common flowchart symbols.\"}]]}],[\"$\",\"details\",\"Can I export my flowchart as a PDF?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Can I export my flowchart as a PDF?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes — click the export button in the top bar and select PDF. Choose between A4 and Letter paper sizes. The PDF includes a title header, and the diagram is automatically scaled to fit the page.\"}]]}],[\"$\",\"details\",\"What export formats are available?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"What export formats are available?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Four options: SVG for scalable vector graphics, PNG at 1x, 2x, or 4x resolution, PDF for print-ready documents, and clipboard copy to paste directly into other applications.\"}]]}],[\"$\",\"details\",\"Is my data private and secure?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Is my data private and secure?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Your flowchart data never leaves your browser. All processing happens client-side on your device, so your diagrams stay completely private.\"}]]}],[\"$\",\"details\",\"Can I save multiple diagrams?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Can I save multiple diagrams?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. Use File > Save to History to save snapshots of your work. Load any saved diagram from the history list. You can also export all diagrams as a JSON backup file and import them on any computer.\"}]]}],[\"$\",\"details\",\"Are there starter templates?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\