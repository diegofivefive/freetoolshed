$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"V for select, H for pan, S for add shape, C for connect, T for text. Ctrl+Z to undo, Ctrl+Shift+Z to redo, Ctrl+C/V for copy/paste, Ctrl+D to duplicate, Delete to remove, and Escape to deselect.\"}]]}]\n3b:[\"$\",\"details\",\"How does the auto-save work?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"How does the auto-save work?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Your diagram is automatically saved to your browser storage every few seconds. When you return to the tool, your last diagram is restored exactly as you left it. For permanent saves, use File > Save to History.\"}]]}]\n24:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n3c:I[27201,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\"],\"IconMark\"]\n27:[[\"$\",\"title\",\"0\",{\"children\":\"Free Flowchart Maker Online — No Sign Up | Free Tool Shed\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Create flowcharts, process diagrams, and decision trees with smart auto-routing connections. Export as SVG, PNG, or PDF. A free alternative to Lucidchart. No sign up required.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"robots\",\"content\":\"noindex, follow\"}],[\"$\",\"meta\",\"3\",{\"name\":\"google-adsense-account\",\"content\":\"ca-pub-7700405385978151\"}],[\"$\",\"link\",\"4\",{\"rel\":\"canonical\",\"href\":\"https://freetoolshed.com/tools/flowchart-maker\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:title\