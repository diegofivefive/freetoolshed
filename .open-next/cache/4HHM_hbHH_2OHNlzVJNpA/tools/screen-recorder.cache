{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/tools/layout,_N_T_/tools/screen-recorder/layout,_N_T_/tools/screen-recorder/page,_N_T_/tools/screen-recorder"},"segmentPaths":["/_tree","/_full","/tools/screen-recorder/__PAGE__","/tools/screen-recorder","/tools","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable h-full\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.09zddjkbdep5a.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.09~u27dqhyhd6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/123doanyjnwwq.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/04uuf1716ltqa.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0eyplc079uusk.js\"/><script src=\"/_next/static/chunks/0tszvp5wpnn-t.js\" async=\"\"></script><script src=\"/_next/static/chunks/0bss4aof7q0cj.js\" async=\"\"></script><script src=\"/_next/static/chunks/0hi511ipeys_s.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-13rn3bqw7ype6.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zif8_3mgcc0x.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zv.me6xdrdsz.js\" async=\"\"></script><script src=\"/_next/static/chunks/0ag6f0zogt0qg.js\" async=\"\"></script><script src=\"/_next/static/chunks/04p0ygcx_g620.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0_pa1c_tsbiw0.js\" async=\"\"></script><script src=\"/_next/static/chunks/10nuyoal1pib2.js\" async=\"\"></script><script src=\"/_next/static/chunks/11~hh-yuwxxvh.js\" async=\"\"></script><script src=\"/_next/static/chunks/0s01892_~8u82.js\" async=\"\"></script><link rel=\"preconnect\" href=\"https://www.highperformanceformat.com\" crossorigin=\"anonymous\"/><link rel=\"dns-prefetch\" href=\"https://www.highperformanceformat.com\"/><link rel=\"preconnect\" href=\"https://pl29142630.profitablecpmratenetwork.com\" crossorigin=\"anonymous\"/><link rel=\"dns-prefetch\" href=\"https://pl29142630.profitablecpmratenetwork.com\"/><meta name=\"next-size-adjust\" content=\"\"/><title>Free Screen Recorder Online — No Sign Up | Free Tool Shed</title><meta name=\"description\" content=\"Record your screen, window, or tab with webcam overlay and microphone — right in your browser. A free alternative to Loom. No sign up required.\"/><meta name=\"google-adsense-account\" content=\"ca-pub-7700405385978151\"/><link rel=\"canonical\" href=\"https://freetoolshed.com/tools/screen-recorder\"/><meta property=\"og:title\" content=\"Free Screen Recorder Online — No Sign Up | Free Tool Shed\"/><meta property=\"og:description\" content=\"Record your screen, window, or tab with webcam overlay and microphone — right in your browser. A free alternative to Loom. No sign up required.\"/><meta property=\"og:url\" content=\"https://freetoolshed.com/tools/screen-recorder\"/><meta property=\"og:site_name\" content=\"Free Tool Shed\"/><meta property=\"og:image\" content=\"https://freetoolshed.com/screenshots/screen-recorder.png\"/><meta property=\"og:image:width\" content=\"1440\"/><meta property=\"og:image:height\" content=\"900\"/><meta property=\"og:image:alt\" content=\"Screen Recorder workspace screenshot\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Free Screen Recorder Online — No Sign Up | Free Tool Shed\"/><meta name=\"twitter:description\" content=\"Record your screen, window, or tab with webcam overlay and microphone — right in your browser. A free alternative to Loom. No sign up required.\"/><meta name=\"twitter:image\" content=\"https://freetoolshed.com/screenshots/screen-recorder.png\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/favicon.ico\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\",\"logo\":\"https://freetoolshed.com/og-image.png\",\"description\":\"Free, browser-based tools that replace paid software. No sign up, no downloads, no servers — every tool runs client-side.\",\"founder\":{\"@type\":\"Person\",\"name\":\"James Nicolaus\",\"url\":\"https://freetoolshed.com/about\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Free Tool Shed\"}}</script><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"flex min-h-full flex-col antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><script>((a,b,c,d,e,f,g,h)=>{let i=document.documentElement,j=[\"light\",\"dark\"];function k(b){var c;(Array.isArray(a)?a:[a]).forEach(a=>{let c=\"class\"===a,d=c&&f?e.map(a=>f[a]||a):e;c?(i.classList.remove(...d),i.classList.add(f&&f[b]?f[b]:b)):i.setAttribute(a,b)}),c=b,h&&j.includes(c)&&(i.style.colorScheme=c)}if(d)k(d);else try{let a=localStorage.getItem(b)||c,d=g&&\"system\"===a?window.matchMedia(\"(prefers-color-scheme: dark)\").matches?\"dark\":\"light\":a;k(d)}catch(a){}})(\"class\",\"theme\",\"system\",null,[\"light\",\"dark\"],null,true,true)</script><nav class=\"sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60\"><div class=\"mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8\"><a class=\"flex items-center gap-2 font-heading text-lg font-semibold\" href=\"/\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-wrench size-5 text-brand\" aria-hidden=\"true\"><path d=\"M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z\"></path></svg><span>Free Tool Shed</span></a><div class=\"flex items-center gap-1\"><a class=\"rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground\" href=\"/about\">About</a><a class=\"rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground\" href=\"/contact\">Contact</a><button type=\"button\" tabindex=\"0\" data-slot=\"button\" aria-label=\"Toggle theme\" class=\"group/button inline-flex shrink-0 items-center justify-center rounded-lg border border-transparent bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 active:translate-y-px disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 [&amp;_svg:not([class*=&#x27;size-&#x27;])]:size-4 hover:bg-muted hover:text-foreground aria-expanded:bg-muted aria-expanded:text-foreground dark:hover:bg-muted/50 size-8\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sun size-4 scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><path d=\"M12 2v2\"></path><path d=\"M12 20v2\"></path><path d=\"m4.93 4.93 1.41 1.41\"></path><path d=\"m17.66 17.66 1.41 1.41\"></path><path d=\"M2 12h2\"></path><path d=\"M20 12h2\"></path><path d=\"m6.34 17.66-1.41 1.41\"></path><path d=\"m19.07 4.93-1.41 1.41\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-moon absolute size-4 scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0\" aria-hidden=\"true\"><path d=\"M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401\"></path></svg></button></div></div></nav><div class=\"flex flex-1 flex-col\"><div class=\"mx-auto w-full max-w-7xl flex-1 px-4 py-6 sm:px-6 lg:px-8\"><div class=\"flex gap-6\"><main class=\"min-w-0 flex-1\"><div class=\"mb-4 hidden justify-center lg:flex\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:728px;height:90px;max-width:100%\" data-ad-slot=\"leaderboard\"></div></div><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"Free Screen Recorder\",\"description\":\"Record your screen, window, or tab with webcam overlay and microphone — right in your browser.\",\"url\":\"https://freetoolshed.com/tools/screen-recorder\",\"applicationCategory\":\"UtilitiesApplication\",\"operatingSystem\":\"Web\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"HowTo\",\"name\":\"How to Record Your Screen Online\",\"description\":\"Capture a screen, window, or browser tab with audio and an optional webcam overlay, then trim and export.\",\"url\":\"https://freetoolshed.com/tools/screen-recorder\",\"step\":[{\"@type\":\"HowToStep\",\"position\":1,\"name\":\"1. Set up your recording\",\"text\":\"Pick a quality preset (720p for small files, 1080p for the sweet spot, 1440p for crisp walkthroughs). Toggle system audio, your microphone, or both. Optionally enable the webcam overlay and pick a corner, size, and shape — it'll be baked into the final video.\"},{\"@type\":\"HowToStep\",\"position\":2,\"name\":\"2. Start recording\",\"text\":\"Click Start Recording. Your browser will open its native share picker where you choose a screen, window, or browser tab to capture. In Chrome, check 'Share tab audio' if you want system sound from a tab. After a 3-second countdown, recording begins.\"},{\"@type\":\"HowToStep\",\"position\":3,\"name\":\"3. Record, pause, and stop\",\"text\":\"Click Pause to freeze the recording (the elapsed timer stops too) and Resume to pick it back up. When you're done, click Stop to finalize. There's no time limit beyond a 2-hour safety cap, and nothing is uploaded as you record — everything lives in your browser's memory.\"},{\"@type\":\"HowToStep\",\"position\":4,\"name\":\"4. Review and trim\",\"text\":\"Play back your recording with the custom video player. Drag the two green handles on the timeline to cut the start or end. Use ← / → for 0.1s nudges, or hold Shift for 1-second steps. Home and End snap to the boundaries. Hit Reset trim anytime to restore the full range.\"},{\"@type\":\"HowToStep\",\"position\":5,\"name\":\"5. Export your recording\",\"text\":\"Choose WebM for an instant download (no transcode, no waiting), MP4 for universal H.264 playback, or GIF for a palette-optimised animation. Give the file a name and click Download. MP4 and GIF lazy-load a ~30 MB ffmpeg core on first use — cached afterwards, so follow-up exports are much faster.\"}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Is this screen recorder really free?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, completely free. No hidden fees, no premium tiers, no watermarks, and no sign-up required. The tool is ad-supported, which is how it stays free for everyone. Ads only appear outside the recording workspace itself.\"}},{\"@type\":\"Question\",\"name\":\"Do I need to install anything?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. The entire recorder runs inside your browser using the MediaRecorder API, Web Audio API, and canvas compositing. There's nothing to download and nothing to uninstall. It works on any modern Chromium-based browser (Chrome, Edge, Brave, Opera) and Firefox.\"}},{\"@type\":\"Question\",\"name\":\"How long can I record?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Up to 2 hours per clip. The cap exists so the in-memory video buffer doesn't exhaust your browser's heap. For most use cases (tutorials, bug reports, walkthroughs) that's plenty of headroom. If you need multi-hour recordings, a desktop app is still the right tool.\"}},{\"@type\":\"Question\",\"name\":\"Does it record system audio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, on Chrome-based browsers you can capture tab audio or entire desktop audio. In the browser's share dialog, check 'Share tab audio' or 'Share system audio'. Firefox has more limited system audio support — microphone capture works everywhere.\"}},{\"@type\":\"Question\",\"name\":\"Can I record with my webcam in the corner like Loom?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Enable the Webcam Overlay in Setup, pick a corner, choose Small/Medium/Large, and switch between a circle or square bubble. The overlay is composited into the recording via a canvas, so it's baked into the final video — it'll look exactly the same when you download it.\"}},{\"@type\":\"Question\",\"name\":\"Can I pause and resume a recording?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Click Pause to freeze the recording — the elapsed timer stops too, and resuming picks up exactly where you left off. Most browser-based recorders don't let you pause at all.\"}},{\"@type\":\"Question\",\"name\":\"How do I trim the start or end of my recording?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"After you stop recording, drag the two green handles on the timeline. The left handle sets the new start, the right sets the new end. Use arrow keys for 0.1s nudges, Shift+arrow for 1-second steps, and Home/End to snap to a boundary. Trimming is non-destructive — hit Reset trim to restore the full range.\"}},{\"@type\":\"Question\",\"name\":\"What export formats are supported?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"WebM (instant, no transcode — your browser already recorded in this format), MP4 (H.264/AAC for universal compatibility with Quicktime, Premiere, YouTube, and social platforms), and GIF (palette-optimised, capped at 12 fps and 720p width for sane file sizes). MP4 and GIF use ffmpeg.wasm locally — no upload, no server.\"}},{\"@type\":\"Question\",\"name\":\"Why is MP4 export slow the first time?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"MP4 and GIF exports lazy-load ffmpeg.wasm on first use — that's about 30 MB of WebAssembly code served from a CDN and cached by your browser. Subsequent exports skip the download. WebM exports always skip ffmpeg entirely when the trim covers the full recording.\"}},{\"@type\":\"Question\",\"name\":\"Does my recording get uploaded anywhere?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. Everything runs client-side. The recording lives in your browser tab's memory (as a Blob), gets trimmed in-place, and downloads directly to your device. There are no servers, no cloud storage, and no analytics on the video content. Close the tab and the recording is gone.\"}},{\"@type\":\"Question\",\"name\":\"Why would I use this instead of Loom?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Loom's free plan caps you at 5 minutes per video and 25 videos total, requires an account, and uploads your video to their servers. This tool has no time cap (beyond a 2-hour safety limit), no account, and no uploads. If you need Loom's sharing and commenting features, keep using Loom. If you just need to record and download, this is faster.\"}},{\"@type\":\"Question\",\"name\":\"Can I use this on a Chromebook or a work laptop?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Because it runs entirely in the browser, it works on Chromebooks, locked-down work machines, and anywhere a desktop install isn't possible. As long as your browser supports getDisplayMedia (Chrome 72+, Edge 79+, Firefox 66+), you're good.\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://freetoolshed.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Screen Recorder\"}]}</script><nav aria-label=\"Breadcrumb\" class=\"mb-4\"><ol class=\"flex items-center gap-1 text-sm text-muted-foreground\"><li class=\"flex items-center gap-1\"><a class=\"transition-colors hover:text-foreground\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right size-3.5 shrink-0\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg><span class=\"text-foreground\">Screen Recorder</span></li></ol></nav><h1 class=\"text-3xl font-bold tracking-tight\">Free Screen Recorder — No Install, No Sign Up</h1><p class=\"mt-2 text-lg text-muted-foreground\">Record your screen, window, or tab with webcam overlay and microphone — a free alternative to Loom. Everything runs in your browser.</p><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"James Nicolaus\",\"jobTitle\":\"Builder & Maintainer, Free Tool Shed\",\"description\":\"James Nicolaus builds and maintains every tool on Free Tool Shed. Each tool is designed, tested in real browsers across desktop and mobile, and shipped only after handling the messy edge cases — large files, slow connections, unusual inputs — that paid alternatives often hide behind sign-up walls.\",\"url\":\"https://freetoolshed.com/about\",\"worksFor\":{\"@type\":\"Organization\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\"}}</script><p class=\"mt-3 text-xs text-muted-foreground\">Built and maintained by<!-- --> <a class=\"font-medium text-foreground underline-offset-4 hover:underline\" rel=\"author\" href=\"/about\">James Nicolaus</a></p><section aria-label=\"Summary\" class=\"mt-6 rounded-lg border border-brand/30 bg-brand/5 p-4\"><p class=\"text-sm leading-relaxed text-foreground\">Free Tool Shed&#x27;s Screen Recorder captures your screen, a window, or a browser tab with optional webcam picture-in-picture and microphone audio — all client-side via the MediaRecorder API. Trim the recording in-browser and export to WebM, MP4, or animated GIF. No upload, no sign-up, no time limit beyond your machine&#x27;s memory. A free alternative to Loom and Vidyard.</p></section><div class=\"mt-6 grid gap-4 sm:grid-cols-2\"><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">No Time Limits</h2><p class=\"mt-1 text-sm text-muted-foreground\">Loom&#x27;s free plan caps you at 5 minutes per video. Here there are no caps, no watermarks, and no upload queue — record as long as your browser has memory.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">Webcam Picture-in-Picture</h2><p class=\"mt-1 text-sm text-muted-foreground\">Drop your webcam into any corner as a circle or square bubble. The overlay is baked into the final video, ready to share.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">Trim &amp; Export</h2><p class=\"mt-1 text-sm text-muted-foreground\">Trim the start or end with draggable handles, then download as WebM (instant) or convert to MP4 / GIF in-browser. No uploads.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">Your Video Stays Private</h2><p class=\"mt-1 text-sm text-muted-foreground\">The recording is held in your browser tab&#x27;s memory and never uploaded. Close the tab to wipe it — no servers, no accounts.</p></div></div><div class=\"mt-8\"><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--></div><div class=\"my-8 flex justify-center\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:728px;height:90px;max-width:100%\" data-ad-slot=\"mid-content\"></div></div><div class=\"mt-16 space-y-12\"><div data-orientation=\"horizontal\" role=\"separator\" aria-orientation=\"horizontal\" data-slot=\"separator\" class=\"shrink-0 bg-border data-horizontal:h-px data-horizontal:w-full data-vertical:w-px data-vertical:self-stretch\"></div><section><h2 class=\"text-2xl font-semibold\">Free Screen Recorder Online — No Install, No Sign Up</h2><p class=\"mt-3 max-w-3xl text-muted-foreground\">You shouldn&#x27;t have to create yet another account or install a 100 MB desktop app just to record a quick walkthrough. Free Tool Shed&#x27;s Screen Recorder runs entirely in your browser — pick a quality preset, choose which audio to capture, optionally drop in a webcam overlay, and hit record. It works on Windows, macOS, Linux, Chromebooks, and even a locked-down work laptop where you can&#x27;t install anything.</p><p class=\"mt-3 max-w-3xl text-muted-foreground\">Unlike Loom (capped at 5 minutes and 25 videos on the free plan) or OBS Studio (powerful but a desktop install with a steep learning curve), this tool is built for the common case: record your screen, trim the ends, and download. Your video never leaves your browser — there are no servers, no accounts, and no upload queues. Export as WebM instantly, or convert to MP4 or GIF with an in-browser ffmpeg.wasm transcode. The whole thing is free, open, and ad-supported so it can stay that way.</p></section><section><h2 class=\"text-xl font-semibold\">Features</h2><ul class=\"mt-4 grid gap-x-8 gap-y-2 text-sm text-muted-foreground sm:grid-cols-2\"><li>Record full screen, a single window, or a browser tab</li><li>720p, 1080p, or 1440p quality presets at 30 fps</li><li>VP9 / Opus encoding when your browser supports it</li><li>System audio capture (tab audio in Chrome)</li><li>Microphone capture for narration</li><li>Mix both audio sources in a single recording</li><li>Optional webcam picture-in-picture overlay</li><li>Choose any of four corners for the overlay</li><li>Small / Medium / Large webcam sizes</li><li>Circle or square webcam shape</li><li>Overlay is baked into the final video</li><li>3-second countdown before recording starts</li><li>Pause and resume without losing the clip</li><li>Up to 2 hours per recording</li><li>Live elapsed timer during recording</li><li>Draggable trim handles on the timeline</li><li>Keyboard nudges for frame-accurate trim boundaries</li><li>Non-destructive trim — reset anytime</li><li>Playback loops inside the trim window</li><li>WebM export with zero re-encode (instant)</li><li>MP4 export via in-browser H.264 / AAC transcode</li><li>GIF export with palette-optimised 12 fps output</li><li>Auto-generated filenames with date stamps</li><li>Cancel an export mid-transcode</li><li>Client-side only — your recording never leaves your browser</li><li>No account, no sign up, no watermarks</li><li>Preferences remembered across sessions</li></ul></section><section><h2 class=\"text-xl font-semibold\">How to Record Your Screen Online (5 Steps)</h2><ol class=\"mt-4 space-y-4\"><li><p class=\"font-medium\">1. Set up your recording</p><p class=\"mt-1 text-sm text-muted-foreground\">Pick a quality preset (720p for small files, 1080p for the sweet spot, 1440p for crisp walkthroughs). Toggle system audio, your microphone, or both. Optionally enable the webcam overlay and pick a corner, size, and shape — it&#x27;ll be baked into the final video.</p></li><li><p class=\"font-medium\">2. Start recording</p><p class=\"mt-1 text-sm text-muted-foreground\">Click Start Recording. Your browser will open its native share picker where you choose a screen, window, or browser tab to capture. In Chrome, check &#x27;Share tab audio&#x27; if you want system sound from a tab. After a 3-second countdown, recording begins.</p></li><li><p class=\"font-medium\">3. Record, pause, and stop</p><p class=\"mt-1 text-sm text-muted-foreground\">Click Pause to freeze the recording (the elapsed timer stops too) and Resume to pick it back up. When you&#x27;re done, click Stop to finalize. There&#x27;s no time limit beyond a 2-hour safety cap, and nothing is uploaded as you record — everything lives in your browser&#x27;s memory.</p></li><li><p class=\"font-medium\">4. Review and trim</p><p class=\"mt-1 text-sm text-muted-foreground\">Play back your recording with the custom video player. Drag the two green handles on the timeline to cut the start or end. Use ← / → for 0.1s nudges, or hold Shift for 1-second steps. Home and End snap to the boundaries. Hit Reset trim anytime to restore the full range.</p></li><li><p class=\"font-medium\">5. Export your recording</p><p class=\"mt-1 text-sm text-muted-foreground\">Choose WebM for an instant download (no transcode, no waiting), MP4 for universal H.264 playback, or GIF for a palette-optimised animation. Give the file a name and click Download. MP4 and GIF lazy-load a ~30 MB ffmpeg core on first use — cached afterwards, so follow-up exports are much faster.</p></li></ol></section><section aria-labelledby=\"tool-insights-tips\"><h2 id=\"tool-insights-tips\" class=\"text-2xl font-semibold tracking-tight\">Tips from Building <!-- -->the Screen Recorder</h2><p class=\"mt-3 max-w-3xl text-muted-foreground\">Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.</p><ul class=\"mt-4 grid max-w-3xl gap-3\"><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Pick the smallest capture region that still tells the story</h3><p class=\"mt-1 text-sm text-muted-foreground\">Full-screen recordings are the largest, the slowest to upload, and the hardest to watch on a phone. Pick a specific window or tab when the whole screen isn&#x27;t necessary.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Enable system audio for app demos, mic for narration</h3><p class=\"mt-1 text-sm text-muted-foreground\">App demos need the application&#x27;s own sound (notifications, video output). Walk-throughs need your voice. The recorder lets you mix both — pick the right combination for your audience.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Trim before exporting</h3><p class=\"mt-1 text-sm text-muted-foreground\">The first few seconds (mouse moving to start) and last few seconds (mouse moving to stop) almost always need trimming. The built-in trim removes them without re-encoding.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Export WebM for the web, MP4 for sharing</h3><p class=\"mt-1 text-sm text-muted-foreground\">WebM is smaller and renders directly in browsers — best for embedding. MP4 is more compatible with messaging apps, social platforms, and older players.</p></div></li></ul></section><section aria-labelledby=\"tool-insights-mistakes\"><h2 id=\"tool-insights-mistakes\" class=\"text-2xl font-semibold tracking-tight\">Common Mistakes to Avoid</h2><ul class=\"mt-4 grid max-w-3xl gap-3\"><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Recording at 4K when 1080p is plenty</h3><p class=\"mt-1 text-sm text-muted-foreground\">Most viewers watch screen recordings on a 1080p display. Recording at higher resolution just creates a heavier file with no visual benefit and longer trim/export times.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Forgetting to disable notifications</h3><p class=\"mt-1 text-sm text-muted-foreground\">A Slack notification mid-demo is embarrassing and may leak private content. Enable Do Not Disturb before recording — every OS has a one-click toggle.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Exporting GIF for a 60-second recording</h3><p class=\"mt-1 text-sm text-muted-foreground\">GIF balloons in size past about 10 seconds and looks worse than equivalent video. Use MP4 or WebM for anything longer than a quick loop.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Closing the tab before saving</h3><p class=\"mt-1 text-sm text-muted-foreground\">Recordings live in memory until you export. Closing the tab discards the recording — export first, close after.</p></div></li></ul></section><section aria-labelledby=\"tool-insights-takeaways\" class=\"rounded-lg border border-brand/30 bg-brand/5 p-5\"><h2 id=\"tool-insights-takeaways\" class=\"text-lg font-semibold tracking-tight\">Key Takeaways</h2><ul class=\"mt-3 space-y-2\"><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">The Screen Recorder captures screen, window, or tab with optional webcam picture-in-picture and microphone.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">Everything runs client-side via MediaRecorder; recordings stay in your browser until you export.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">Trim in-browser and export to WebM, MP4, or animated GIF.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">It is a free alternative to Loom and Vidyard with no time limit beyond your machine&#x27;s memory.</span></li></ul></section><section><h2 class=\"text-xl font-semibold\">Free Loom Alternative</h2><div class=\"mt-4 overflow-x-auto\"><table class=\"w-full min-w-[640px] border-collapse text-sm\"><thead><tr class=\"border-b border-border text-left\"><th class=\"py-2 pr-4 font-semibold\">Feature</th><th class=\"py-2 pr-4 font-semibold\">Free Tool Shed</th><th class=\"py-2 pr-4 font-semibold\">Loom (Free)</th><th class=\"py-2 pr-4 font-semibold\">Loom (Business)</th><th class=\"py-2 pr-4 font-semibold\">OBS Studio</th><th class=\"py-2 font-semibold\">Camtasia</th></tr></thead><tbody class=\"text-muted-foreground\"><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Price</td><td class=\"py-2 pr-4 font-medium text-foreground\">Free forever</td><td class=\"py-2 pr-4 \">Free</td><td class=\"py-2 pr-4 \">$15/mo</td><td class=\"py-2 pr-4 \">Free</td><td class=\"py-2  \">$299 one-time</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Installation</td><td class=\"py-2 pr-4 font-medium text-foreground\">None (browser)</td><td class=\"py-2 pr-4 \">Desktop or extension</td><td class=\"py-2 pr-4 \">Desktop or extension</td><td class=\"py-2 pr-4 \">Desktop app</td><td class=\"py-2  \">Desktop app</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Account Required</td><td class=\"py-2 pr-4 font-medium text-foreground\">No</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">No</td><td class=\"py-2  \">No</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Recording Length</td><td class=\"py-2 pr-4 font-medium text-foreground\">2 hours</td><td class=\"py-2 pr-4 \">5 minutes</td><td class=\"py-2 pr-4 \">Unlimited</td><td class=\"py-2 pr-4 \">Unlimited</td><td class=\"py-2  \">Unlimited</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Video Count</td><td class=\"py-2 pr-4 font-medium text-foreground\">Unlimited</td><td class=\"py-2 pr-4 \">25 total</td><td class=\"py-2 pr-4 \">Unlimited</td><td class=\"py-2 pr-4 \">Unlimited</td><td class=\"py-2  \">Unlimited</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Watermark</td><td class=\"py-2 pr-4 font-medium text-foreground\">None</td><td class=\"py-2 pr-4 \">None</td><td class=\"py-2 pr-4 \">None</td><td class=\"py-2 pr-4 \">None</td><td class=\"py-2  \">None</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Record Screen / Window / Tab</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2  \">Yes</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Webcam Overlay</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes (corner / shape)</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2  \">Yes</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Microphone Audio</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2  \">Yes</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">System / Tab Audio</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2  \">Yes</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Pause / Resume</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes</td><td class=\"py-2 pr-4 \">No</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2  \">Yes</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Trim Start / End</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes (browser)</td><td class=\"py-2 pr-4 \">Basic</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2  \">Yes</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Export Formats</td><td class=\"py-2 pr-4 font-medium text-foreground\">WebM / MP4 / GIF</td><td class=\"py-2 pr-4 \">Cloud link only</td><td class=\"py-2 pr-4 \">MP4 download</td><td class=\"py-2 pr-4 \">MKV / MP4 / FLV</td><td class=\"py-2  \">MP4 / GIF / etc.</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Data Privacy</td><td class=\"py-2 pr-4 font-medium text-foreground\">Client-side only</td><td class=\"py-2 pr-4 \">Uploaded to Loom</td><td class=\"py-2 pr-4 \">Uploaded to Loom</td><td class=\"py-2 pr-4 \">Local</td><td class=\"py-2  \">Local</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Works on Chromebook</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes</td><td class=\"py-2 pr-4 \">Yes (web)</td><td class=\"py-2 pr-4 \">Yes (web)</td><td class=\"py-2 pr-4 \">No</td><td class=\"py-2  \">No</td></tr></tbody></table></div></section><section><h2 class=\"text-xl font-semibold\">Frequently Asked Questions</h2><div class=\"mt-4 space-y-3\"><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Is this screen recorder really free?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Yes, completely free. No hidden fees, no premium tiers, no watermarks, and no sign-up required. The tool is ad-supported, which is how it stays free for everyone. Ads only appear outside the recording workspace itself.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Do I need to install anything?</summary><p class=\"mt-2 text-sm text-muted-foreground\">No. The entire recorder runs inside your browser using the MediaRecorder API, Web Audio API, and canvas compositing. There&#x27;s nothing to download and nothing to uninstall. It works on any modern Chromium-based browser (Chrome, Edge, Brave, Opera) and Firefox.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">How long can I record?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Up to 2 hours per clip. The cap exists so the in-memory video buffer doesn&#x27;t exhaust your browser&#x27;s heap. For most use cases (tutorials, bug reports, walkthroughs) that&#x27;s plenty of headroom. If you need multi-hour recordings, a desktop app is still the right tool.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Does it record system audio?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Yes, on Chrome-based browsers you can capture tab audio or entire desktop audio. In the browser&#x27;s share dialog, check &#x27;Share tab audio&#x27; or &#x27;Share system audio&#x27;. Firefox has more limited system audio support — microphone capture works everywhere.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Can I record with my webcam in the corner like Loom?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Yes. Enable the Webcam Overlay in Setup, pick a corner, choose Small/Medium/Large, and switch between a circle or square bubble. The overlay is composited into the recording via a canvas, so it&#x27;s baked into the final video — it&#x27;ll look exactly the same when you download it.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Can I pause and resume a recording?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Yes. Click Pause to freeze the recording — the elapsed timer stops too, and resuming picks up exactly where you left off. Most browser-based recorders don&#x27;t let you pause at all.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">How do I trim the start or end of my recording?</summary><p class=\"mt-2 text-sm text-muted-foreground\">After you stop recording, drag the two green handles on the timeline. The left handle sets the new start, the right sets the new end. Use ← / → for 0.1s nudges, Shift+← / → for 1-second steps, and Home / End to snap to a boundary. Trimming is non-destructive — hit Reset trim to restore the full range.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">What export formats are supported?</summary><p class=\"mt-2 text-sm text-muted-foreground\">WebM (instant, no transcode — your browser already recorded in this format), MP4 (H.264/AAC for universal compatibility with Quicktime, Premiere, YouTube, and social platforms), and GIF (palette-optimised, capped at 12 fps and 720p width for sane file sizes). MP4 and GIF use ffmpeg.wasm locally — no upload, no server.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Why is MP4 export slow the first time?</summary><p class=\"mt-2 text-sm text-muted-foreground\">MP4 and GIF exports lazy-load ffmpeg.wasm on first use — that&#x27;s about 30 MB of WebAssembly code served from unpkg.com and cached by your browser. Subsequent exports skip the download. WebM exports always skip ffmpeg entirely when the trim covers the full recording.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Does my recording get uploaded anywhere?</summary><p class=\"mt-2 text-sm text-muted-foreground\">No. Everything runs client-side. The recording lives in your browser tab&#x27;s memory (as a Blob), gets trimmed in-place, and downloads directly to your device. There are no servers, no cloud storage, and no analytics on the video content. Close the tab and the recording is gone.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Why would I use this instead of Loom?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Loom&#x27;s free plan caps you at 5 minutes per video and 25 videos total, requires an account, and uploads your video to their servers. This tool has no time cap (beyond a 2-hour safety limit), no account, and no uploads. If you need Loom&#x27;s sharing and commenting features, keep using Loom. If you just need to record and download, this is faster.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Why would I use this instead of OBS Studio?</summary><p class=\"mt-2 text-sm text-muted-foreground\">OBS is vastly more powerful — scenes, sources, filters, streaming, plugins. But it&#x27;s a desktop install with a learning curve. This tool is for the common case: hit record, trim, download. No install, no setup, no scenes.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Can I use this on a Chromebook or a work laptop?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Yes. Because it runs entirely in the browser, it works on Chromebooks, locked-down work machines, and anywhere a desktop install isn&#x27;t possible. As long as your browser supports getDisplayMedia (Chrome 72+, Edge 79+, Firefox 66+), you&#x27;re good.</p></details></div></section></div><!--$--><!--/$--></main><aside class=\"hidden w-[300px] shrink-0 lg:block\"><div class=\"sticky top-20\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:300px;height:250px;max-width:100%\" data-ad-slot=\"sidebar\"></div><div id=\"tool-guide-portal\"></div></div></aside></div></div></div><footer class=\"border-t border-border bg-muted/40\"><div class=\"mx-auto flex max-w-7xl flex-col items-center gap-4 px-4 py-8 sm:flex-row sm:justify-between sm:px-6 lg:px-8\"><p class=\"text-sm text-muted-foreground\">© <!-- -->2026<!-- --> Free Tool Shed. All rights reserved.</p><nav class=\"flex gap-4 text-sm text-muted-foreground\"><a class=\"transition-colors hover:text-foreground\" href=\"/about\">About</a><a class=\"transition-colors hover:text-foreground\" href=\"/contact\">Contact</a><a class=\"transition-colors hover:text-foreground\" href=\"/privacy\">Privacy</a><a class=\"transition-colors hover:text-foreground\" href=\"/terms\">Terms</a></nav></div></footer><script src=\"/_next/static/chunks/0eyplc079uusk.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[83661,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\\"/_next/static/chunks/0zv.me6xdrdsz.js\\\",\\\"/_next/static/chunks/0ag6f0zogt0qg.js\\\",\\\"/_next/static/chunks/04p0ygcx_g620.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/0_pa1c_tsbiw0.js\\\",\\\"/_next/static/chunks/10nuyoal1pib2.js\\\"],\\\"ThemeProvider\\\"]\\n3:I[46798,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\\"/_next/static/chunks/0zv.me6xdrdsz.js\\\",\\\"/_next/static/chunks/0ag6f0zogt0qg.js\\\",\\\"/_next/static/chunks/04p0ygcx_g620.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/0_pa1c_tsbiw0.js\\\",\\\"/_next/static/chunks/10nuyoal1pib2.js\\\"],\\\"TooltipProvider\\\"]\\n4:I[22016,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\\"/_next/static/chunks/0zv.me6xdrdsz.js\\\",\\\"/_next/static/chunks/0ag6f0zogt0qg.js\\\",\\\"/_next/static/chunks/04p0ygcx_g620.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/0_pa1c_tsbiw0.js\\\",\\\"/_next/static/chunks/10nuyoal1pib2.js\\\",\\\"/_next/static/chunks/11~hh-yuwxxvh.js\\\",\\\"/_next/static/chunks/0s01892_~8u82.js\\\"],\\\"\\\"]\\n5:I[58541,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\\"/_next/static/chunks/0zv.me6xdrdsz.js\\\",\\\"/_next/static/chunks/0ag6f0zogt0qg.js\\\",\\\"/_next/static/c