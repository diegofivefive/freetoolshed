next/static/chunks/0s01892_~8u82.js\"],\"default\"]\n11:I[80811,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\",\"/_next/static/chunks/11~hh-yuwxxvh.js\",\"/_next/static/chunks/0s01892_~8u82.js\"],\"ScreenRecorderLoader\"]\n12:I[24678,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\",\"/_next/static/chunks/11~hh-yuwxxvh.js\",\"/_next/static/chunks/0s01892_~8u82.js\"],\"AdSlot\"]\n13:I[72436,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\",\"/_next/static/chunks/11~hh-yuwxxvh.js\",\"/_next/static/chunks/0s01892_~8u82.js\"],\"Separator\"]\n1b:I[97367,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\"],\"OutletBoundary\"]\n1c:\"$Sreact.suspense\"\n2:T7e0,{\"@context\":\"https://schema.org\",\"@type\":\"HowTo\",\"name\":\"How to Record Your Screen Online\",\"description\":\"Capture a screen, window, or browser tab with audio and an optional webcam overlay, then trim and export.\",\"url\":\"https://freetoolshed.com/tools/screen-recorder\",\"step\":[{\"@type\":\"HowToStep\",\"position\":1,\"name\":\"1. Set up your recording\",\"text\":\"Pick a quality preset (720p for small files, 1080p for the sweet spot, 1440p for crisp walkthroughs). Toggle system audio, your microphone, or both. Optionally enable the webcam overlay and pick a corner, size, and shape — it'll be baked into the final video.\"},{\"@type\":\"HowToStep\",\"position\":2,\"name\":\"2. Start recording\",\"text\":\"Click Start Recording. Your browser will open its native share picker where you choose a screen, window, or browser tab to capture. In Chrome, check 'Share tab audio' if you want system sound from a tab. After a 3-second countdown, recording begins.\"},{\"@type\":\"HowToStep\",\"position\":3,\"name\":\"3. Record, pause, and stop\",\"text\":\"Click Pause to freeze the recording (the elapsed timer stops too) and Resume to pick it back up. When you're done, click Stop to finalize. There's no time limit beyond a 2-hour safety cap, and nothing is uploaded as you record — everything lives in your browser's memory.\"},{\"@type\":\"HowToStep\",\"position\":4,\"name\":\"4. Review and trim\",\"text\":\"Play back your recording with the custom video player. Drag the two green handles on the timeline to cut the start or end. Use ← / → for 0.1s nudges, or hold Shift for 1-second steps. Home and End snap to the boundaries. Hit Reset trim anytime to restore the full range.\"},{\"@type\":\"HowToStep\",\"position\":5,\"name\":\"5. Export your recording\",\"text\":\"Choose WebM for an instant download (no transcode, no waiting), MP4 for universal H.264 playback, or GIF for a palette-optimised animation. Give the file a name and click Download. MP4 and GIF lazy-load a ~30 MB ffmpeg core on first use — cached afterwards, so follow-up exports are much faster.\"}]}3:T121b,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Is this screen recorder really free?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, completely free. No hidden fees, no premium tiers, no watermarks, and no sign-up required. The tool is ad-supported, which is how it stays free for everyone. Ads only appear outside the recording workspace itself.\"}},{\"@type\":\"Question\",\"name\":\"Do I need to install anything?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. The entire recorder runs inside your browser using the MediaRecorder API, Web Audio API, and canvas compositing. There's nothing to download and nothing to uninstall. It works on any modern Chromium-based browser (Chrome, Edge, Brave, Opera) and Firefox.\"}},{\"@type\":\"Question\",\"name\":\"How long can I record?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Up to 2 hours per clip. The cap exists so the in-memory video buffer doesn't exhaust your browser's heap. For most use cases (tutorials, bug reports, walkthroughs) that's plenty of headroom. If you need multi-hour recordings, a desktop app is still the right tool.\"}},{\"@type\":\"Question\",\"name\":\"Does it record system audio?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, on Chrome-based browsers you can capture tab audio or entire desktop audio. In the browser's share dialog, check 'Share tab audio' or 'Share system audio'. Firefox has more limited system audio support — microphone capture works everywhere.\"}},{\"@type\":\"Question\",\"name\":\"Can I record with my webcam in the corner like Loom?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Enable the Webcam Overlay in Setup, pick a corner, choose Small/Medium/Large, and switch between a circle or square bubble. The overlay is composited into the recording via a canvas, so it's baked into the final video — it'll look exactly the same when you download it.\"}},{\"@type\":\"Question\",\"name\":\"Can I pause and resume a recording?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Click Pause to freeze the recording — the elapsed timer stops too, and resuming picks up exactly where you left off. Most browser-based recorders don't let you pause at all.\"}},{\"@type\":\"Question\",\"name\":\"How do I trim the start or end of my recording?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"After you stop recording, drag the two green handles on the timeline. The left handle sets the new start, the right sets the new end. Use arrow keys for 0.1s nudges, Shift+arrow for 1-second steps, and Home/End to snap to a boundary. Trimming is non-destructive — hit Reset trim to restore the full range.\"}},{\"@type\":\"Question\",\"name\":\"What export formats are supported?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"WebM (instant, no transcode — your browser already recorded in this format), MP4 (H.264/AAC for universal compatibility with Quicktime, Premiere, YouTube, and social platforms), and GIF (palette-optimised, capped at 12 fps and 720p width for sane file sizes). MP4 and GIF use ffmpeg.wasm locally — no upload, no server.\"}},{\"@type\":\"Question\",\"name\":\"Why is MP4 export slow the first time?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"MP4 and GIF exports lazy-load ffmpeg.wasm on first use — that's about 30 MB of WebAssembly code served from a CDN and cached by your browser. Subsequent exports skip the download. WebM exports always skip ffmpeg entirely when the trim covers the full recording.\"}},{\"@type\":\"Question\",\"name\":\"Does my recording get uploaded anywhere?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. Everything runs client-side. The recording lives in your browser tab's memory (as a Blob), gets trimmed in-place, and downloads directly to your device. There are no servers, no cloud storage, and no analytics on the video content. Close the tab and the recording is gone.\"}},{\"@type\":\"Question\",\"name\":\"Why would I use this instead of Loom?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Loom's free plan caps you at 5 minutes per video and 25 videos total, requires an account, and uploads your video to their servers. This tool has no time cap (beyond a 2-hour safety limit), no account, and no uploads. If you need Loom's sharing and commenting features, keep using Loom. If you just need to record and download, this is faster.\"}},{\"@type\":\"Question\",\"name\":\"Can I use this on a Chromebook or a work laptop?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Because it runs entirely in the browser, it works on Chromebooks, locked-down work machines, and anywhere a desktop install isn't possible. As long as your browser supports getDisplayMedia (Chrome 72+, Edge 79+, Firefox 66+), you're good.\"}}]}0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"SoftwareApplication\\\",\\\"name\\\":\\\"Free Screen Recorder\\\",\\\"description\\\":\\\"Record your screen, window, or tab with webcam overlay and microphone — right in your browser.\\\",\\\"url\\\":\\\"https://freetoolshed.com/tools/screen-recorder\\\",\\\"applicationCategory\\\":\\\"UtilitiesApplication\\\",\\\"operatingSystem\\\":\\\"Web\\\",\\\"offers\\\":{\\\"@type\\\":\\\"Offer\\\",\\\"price\\\":\\\"0\\\",\\\"priceCurrency\\\":\\\"USD\\\"}}\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$2\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$3\"}}],\"$L4\",\"$L5\",\"$L6\",\"$L7\",\"$L8\",\"$L9\",\"$La\",\"$Lb\",\"$Lc\"],[\"$Ld\"],\"$Le\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"4HHM_hbHH_2OHNlzVJNpA\"}\n4:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://freetoolshed.com/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Screen Recorder\\\"}]}\"}}],[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"mb-4\",\"children\":[\"$\",\"ol\",null,{\"className\":\"flex items-center gap-1 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",\"0\",{\"className\":\"flex items-center gap-1\",\"children\":[false,[\"$\",\"$Lf\",null,{\"href\":\"/\",\"className\":\"transition-colors hover:text-foreground\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"1\",{\"className\":\"flex items-center gap-1\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":[[\"path\",{\"d\":\"m9 18 6-6-6-6\",\"key\":\"mthhwq\"}]],\"className\":\"lucide-chevron-right size-3.5 shrink-0\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground\",\"children\":\"Screen Recorder\"}]]}]]}]}]]\n5:[\"$\",\"h1\",null,{\"className\":\"text-3xl font-bold tracking-tight\",\"children\":\"Free Screen Recorder — No Install, No Sign Up\"}]\n6:[\"$\",\"p\",null,{\"className\":\"mt-2 text-lg text-muted-foreground\",\"children\":\"Record your screen, window, or tab with webcam overlay and microphone — a free alternative to Loom. Everything runs in your browser.\"}]\n7:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"Person\\\",\\\"name\\\":\\\"James Nicolaus\\\",\\\"jobTitle\\\":\\\"Builder & Maintainer, Free Tool Shed\\\",\\\"description\\\":\\\"James Nicolaus builds and maintains every tool on Free Tool Shed. Each tool is designed, tested in real browsers across desktop and mobile, and shipped only after handling the messy edge cases — large files, slow connections, unusual inputs — that paid alternatives often hide behind sign-up walls.\\\",\\\"url\\\":\\\"https://freetoolshed.com/about\\\",\\\"worksFor\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"Free Tool Shed\\\",\\\"url\\\":\\\"https://freetoolshed.com\\\"}}\"}}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-xs text-muted-foreground\",\"children\":[\"Built and maintained by\",\" \",[\"$\",\"$Lf\",null,{\"href\":\"/about\",\"className\":\"font-medium text-foreground underline-offset-4 hover:underline\",\"rel\":\"author\",\"children\":\"James Nicolaus\"}],\"$undefined\"]}]]\n8:[\"$\",\"section\",null,{\"aria-label\":\"Summary\",\"className\":\"mt-6 rounded-lg border border-brand/30 bg-brand/5 p-4\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm leading-relaxed text-foreground\",\"children\":\"Free Tool Shed's Screen Recorder captures your screen, a window, or a browser tab with optional webcam picture-in-picture and microphone audio — all client-side via the MediaRecorder API. Trim the recording in-browser and export to WebM, MP4, or animated GIF. No upload, no sign-up, no time limit beyond your machine's memory. A free alternative to Loom and Vidyard.\"}]}]\n9:[\"$\",\"div\",null,{\"className\":\"mt-6 grid gap-4 sm:grid-cols-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"No Time Limits\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Loom's free plan caps you at 5 minutes per video. Here there are no caps, no watermarks, and no upload queue — record as long as your browser has memory.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Webcam Picture-in-Picture\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Drop your webcam into any corner as a circle or square bubble. The overlay is baked into the final video, ready to share.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Trim & Export\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Trim the start or end with draggable handles, then download as WebM (instant) or convert to MP4 / GIF in-browser. No uploads.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Your Video Stays Private\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"The recording is held in your browser tab's memory and never uploaded. Close the tab to wipe it — no servers, no accounts.\"}]]}]]}]\na:[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L11\",null,{}]}]\nb:[\"$\",\"div\",null,{\"className\":\"my-8 flex justify-center\",\"children\":[\"$\",\"$L12\",null,{\"slot\":\"mid-content\"}]}]\nc:[\"$\",\"div\",null,{\"className\":\"mt-16 space-y-12\",\"children\":[[\"$\",\"$L13\",null,{}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold\",\"children\":\"Free Screen Recorder Online — No Install, No Sign Up\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"You shouldn't have to create yet another account or install a 100 MB desktop app just to record a quick walkthrough. Free Tool Shed's Screen Recorder runs entirely in your browser — pick a quality preset, choose which audio to capture, optionally drop in a webcam overlay, and hit record. It works on Windows, macOS, Linux, Chromebooks, and even a locked-down work laptop where you can't install anything.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Unlike Loom (capped at 5 minutes and 25 videos on the free plan) or OBS Studio (powerful but a desktop install with a steep learning curve), this tool is built for the common case: record your screen, trim the ends, and download. Your video never leaves your browser — there are no servers, no accounts, and no upload queues. Export as WebM instantly, or convert to MP4 or GIF with an in-browser ffmpeg.wasm transcode. The whole thing is free, open, and ad-supported so it can stay that way.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Features\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid gap-x-8 gap-y-2 text-sm text-muted-foreground sm:grid-cols-2\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Record full screen, a single window, or a browser tab\"}],[\"$\",\"li\",null,{\"children\":\"720p, 1080p, or 1440p quality presets at 30 fps\"}],[\"$\",\"li\",null,{\"children\":\"VP9 / Opus encoding when your browser supports it\"}],[\"$\",\"li\",null,{\"children\":\"System audio capture (tab audio in Chrome)\"}],[\"$\",\"li\",null,{\"children\":\"Microphone capture for narration\"}],[\"$\",\"li\",null,{\"children\":\"Mix both audio sources in a single recording\"}],[\"$\",\"li\",null,{\"children\":\"Optional webcam picture-in-picture overlay\"}],[\"$\",\"li\",null,{\"children\":\"Choose any of four corners for the overlay\"}],[\"$\",\"li\",null,{\"children\":\"Small / Medium / Large webcam sizes\"}],[\"$\",\"li\",null,{\"children\":\"Circle or square webcam shape\"}],[\"$\",\"li\",null,{\"children\":\"Overlay is baked into the final video\"}],[\"$\",\"li\",null,{\"children\":\"3-second countdown before recording starts\"}],[\"$\",\"li\",null,{\"children\":\"Pause and resume without losing the clip\"}],[\"$\",\"li\",null,{\"children\":\"Up to 2 hours per recording\"}],[\"$\",\"li\",null,{\"children\":\"Live elapsed timer during recording\"}],[\"$\",\"li\",null,{\"children\":\"Draggable trim handles on the timeline\"}],[\"$\",\"li\",null,{\"children\":\"Keyboard nudges for frame-accurate trim boundaries\"}],[\"$\",\"li\",null,{\"children\":\"Non-destructive trim — reset anytime\"}],[\"$\",\"li\",null,{\"children\":\"Playback loops inside the trim window\"}],[\"$\",\"li\",null,{\"children\":\"WebM export with zero re-encode (instant)\"}],[\"$\",\"li\",null,{\"children\":\"MP4 export via in-browser H.264 / AAC transcode\"}],[\"$\",\"li\",null,{\"children\":\"GIF export with palette-optimised 12 fps output\"}],[\"$\",\"li\",null,{\"children\":\"Auto-generated filenames with date stamps\"}],[\"$\",\"li\",null,{\"children\":\"Cancel an export mid-transcode\"}],[\"$\",\"li\",null,{\"children\":\"Client-side only — your recording never leaves your browser\"}],[\"$\",\"li\",null,{\"children\":\"No account, no sign up, no watermarks\"}],[\"$\",\"li\",null,{\"children\":\"Preferences remembered across sessions\"}]]}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"How to Record Your Screen Online (5 Steps)\"}],[\"$\",\"ol\",null,{\"className\":\"mt-4 space-y-4\",\"children\":[[\"$\",\"li\",\"1. Set up your recording\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"1. Set up your recording\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Pick a quality preset (720p for small files, 1080p for the sweet spot, 1440p for crisp walkthroughs). Toggle system audio, your microphone, or both. Optionally enable the webcam overlay and pick a corner, size, and shape — it'll be baked into the final video.\"}]]}],\"$L14\",\"$L15\",\"$L16\",\"$L17\"]}]]}],\"$L18\",\"$L19\",\"$L1a\"]}]\nd:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0s01892_~8u82.js\",\"async\":true}]\ne:[\"$\",\"$L1b\",null,{\"children\":[\"$\",\"$1c\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@1d\"}]}]\n14:[\"$\",\"li\",\"2. Start recording\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"2. Start recording\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Click Start Recording. Your browser will open its native share picker where you choose a screen, window, or browser tab to capture. In Chrome, check 'Share tab audio' if you want system sound from a tab. After a 3-second countdown, recording begins.\"}]]}]\n15:[\"$\",\"li\",\"3. Record, pause, and stop\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"3. Record, pause, and stop\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Click Pause to freeze the recording (the elapsed timer stops too) and Resume to pick it back up. When you're done, click Stop to finalize. There's no time limit beyond a 2-hour safety cap, and nothing is uploaded as you record — everything lives in your browser's memory.\"}]]}]\n16:[\"$\",\"li\",\"4. Review and trim\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"4. Review and trim\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Play back your recording with the custom video player. Drag the two green handles on the timeline to cut the start or end. Use ← / → for 0.1s nudges, or hold Shift for 1-second steps. Home and End snap to the boundaries. Hit Reset trim anytime to restore the full range.\"}]]}]\n17:[\"$\",\"li\",\"5. Export your recording\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"5. Export your recording\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Choose WebM for an instant download (no transcode, no waiting), MP4 for universal H.264 playback, or GIF for a palette-optimised animation. Give the file a name and click Download. MP4 and GIF lazy-load a ~30 MB ffmpeg core on first use — cached afterwards, so follow-up exports are much faster.\"}]]}]\n18:[[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-tips\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-tips\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":[\"Tips from Building \",\"the Screen Recorder\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Pick the smallest capture region that still tells the story\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":[[\"path\",{\"d\":\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\",\"key\":\"1gvzjb\"}],[\"path\",{\"d\":\"M9 18h6\",\"key\":\"x1upvd\"}],[\"path\",{\"d\":\"M10 22h4\",\"key\":\"ceow96\"}]],\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Pick the smallest capture region that still tells the story\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Full-screen recordings are the largest, the slowest to upload, and the hardest to watch on a phone. Pick a specific window or tab when the whole screen isn't necessary.\"}]]}]]}],[\"$\",\"li\",\"Enable system audio for app demos, mic for narration\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":\"$18:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Enable system audio for app demos, mic for narration\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"App demos need the application's own sound (notifications, video output). Walk-throughs need your voice. The recorder lets you mix both — pick the right combination for your audience.\"}]]}]]}],[\"$\",\"li\",\"Trim before exporting\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":\"$18:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Trim before exporting\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"The first few seconds (mouse moving to start) and last few seconds (mouse moving to stop) almost always need trimming. The built-in trim removes them without re-encoding.\"}]]}]]}],[\"$\",\"li\",\"Export WebM for the web, MP4 for sharing\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":\"$18:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Export WebM for the web, MP4 for sharing\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"WebM is smaller and renders directly in browsers — best for embedding. MP4 is more compatible with messaging apps, social platforms, and older players.\"}]]}]]}]]}]]}],[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-mistakes\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-mistakes\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Common Mistakes to Avoid\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Recording at 4K when 1080p is plenty\",{\"className\