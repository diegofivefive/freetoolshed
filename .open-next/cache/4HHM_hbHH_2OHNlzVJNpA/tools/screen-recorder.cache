r\",\"Video Count\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Video Count\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Unlimited\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"25 total\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Unlimited\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2 pr-4 \",\"children\":\"Unlimited\"}],[\"$\",\"td\",\"5\",{\"className\":\"py-2  \",\"children\":\"Unlimited\"}]]}],[\"$\",\"tr\",\"Watermark\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Watermark\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"None\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"None\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"None\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2 pr-4 \",\"children\":\"None\"}],[\"$\",\"td\",\"5\",{\"className\":\"py-2  \",\"children\":\"None\"}]]}],[\"$\",\"tr\",\"Record Screen / Window / Tab\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Record Screen / Window / Tab\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Yes\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"5\",{\"className\":\"py-2  \",\"children\":\"Yes\"}]]}],[\"$\",\"tr\",\"Webcam Overlay\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Webcam Overlay\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Yes (corner / shape)\"}],\"$L3a\",\"$L3b\",\"$L3c\",\"$L3d\"]}],\"$L3e\",\"$L3f\",\"$L40\",\"$L41\",\"$L42\",\"$L43\",\"$L44\"]}]]}]}]]}]\n32:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Frequently Asked Questions\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-3\",\"children\":[[\"$\",\"details\",\"Is this screen recorder really free?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Is this screen recorder really free?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes, completely free. No hidden fees, no premium tiers, no watermarks, and no sign-up required. The tool is ad-supported, which is how it stays free for everyone. Ads only appear outside the recording workspace itself.\"}]]}],[\"$\",\"details\",\"Do I need to install anything?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Do I need to install anything?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"No. The entire recorder runs inside your browser using the MediaRecorder API, Web Audio API, and canvas compositing. There's nothing to download and nothing to uninstall. It works on any modern Chromium-based browser (Chrome, Edge, Brave, Opera) and Firefox.\"}]]}],[\"$\",\"details\",\"How long can I record?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"How long can I record?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Up to 2 hours per clip. The cap exists so the in-memory video buffer doesn't exhaust your browser's heap. For most use cases (tutorials, bug reports, walkthroughs) that's plenty of headroom. If you need multi-hour recordings, a desktop app is still the right tool.\"}]]}],[\"$\",\"details\",\"Does it record system audio?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Does it record system audio?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes, on Chrome-based browsers you can capture tab audio or entire desktop audio. In the browser's share dialog, check 'Share tab audio' or 'Share system audio'. Firefox has more limited system audio support — microphone capture works everywhere.\"}]]}],[\"$\",\"details\",\"Can I record with my webcam in the corner like Loom?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Can I record with my webcam in the corner like Loom?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. Enable the Webcam Overlay in Setup, pick a corner, choose Small/Medium/Large, and switch between a circle or square bubble. The overlay is composited into the recording via a canvas, so it's baked into the final video — it'll look exactly the same when you download it.\"}]]}],[\"$\",\"details\",\"Can I pause and resume a recording?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Can I pause and resume a recording?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. Click Pause to freeze the recording — the elapsed timer stops too, and resuming picks up exactly where you left off. Most browser-based recorders don't let you pause at all.\"}]]}],[\"$\",\"details\",\"How do I trim the start or end of my recording?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[\"$L45\",\"$L46\"]}],\"$L47\",\"$L48\",\"$L49\",\"$L4a\",\"$L4b\",\"$L4c\"]}]]}]\n35:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Recording at 4K when 1080p is plenty\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Most viewers watch screen recordings on a 1080p display. Recording at higher resolution just creates a heavier file with no visual benefit and longer trim/export times.\"}]]}]\n36:[\"$\",\"li\",\"Forgetting to disable notifications\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$30:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Forgetting to disable notifications\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"A Slack notification mid-demo is embarrassing and may leak private content. Enable Do Not Disturb before recording — every OS has a one-click toggle.\"}]]}]]}]\n37:[\"$\",\"li\",\"Exporting GIF for a 60-second recording\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$30:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Exporting GIF for a 60-second recording\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"GIF balloons in size past about 10 seconds and looks worse than equivalent video. Use MP4 or WebM for anything longer than a quick loop.\"}]]}]]}]\n38:[\"$\",\"li\",\"Closing the tab before saving\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$30:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Closing the tab before saving\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Recordings live in memory until you export. Closing the tab discards the recording — export first, close after.\"}]]}]]}]\n39:[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-takeaways\",\"className\":\"rounded-lg border border-brand/30 bg-brand/5 p-5\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-takeaways\",\"className\":\"text-lg font-semibold tracking-tight\",\"children\":\"Key Takeaways\"}],[\"$\",\"ul\",null,{\"className\":\"mt-3 space-y-2\",\"children\":[[\"$\",\"li\",\"The Screen Recorder captures screen, window, or tab with optional webcam picture-in-picture and microphone.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"circle\",{\"cx\":\"12\",\"cy\":\"12\",\"r\":\"10\",\"key\":\"1mglay\"}],[\"path\",{\"d\":\"m9 12 2 2 4-4\",\"key\":\"dzmm74\"}]],\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"The Screen Recorder captures screen, window, or tab with optional webcam picture-in-picture and microphone.\"}]]}],[\"$\",\"li\",\"Everything runs client-side via MediaRecorder; recordings stay in your browser until you export.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",nu