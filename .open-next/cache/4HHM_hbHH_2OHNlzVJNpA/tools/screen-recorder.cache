 \",\"children\":\"Free\"}],[\"$\",\"td\",\"5\",{\"className\":\"py-2  \",\"children\":\"$$299 one-time\"}]]}],[\"$\",\"tr\",\"Installation\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Installation\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"None (browser)\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Desktop or extension\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Desktop or extension\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2 pr-4 \",\"children\":\"Desktop app\"}],[\"$\",\"td\",\"5\",{\"className\":\"py-2  \",\"children\":\"Desktop app\"}]]}],[\"$\",\"tr\",\"Account Required\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Account Required\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"No\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2 pr-4 \",\"children\":\"No\"}],[\"$\",\"td\",\"5\",{\"className\":\"py-2  \",\"children\":\"No\"}]]}],[\"$\",\"tr\",\"Recording Length\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Recording Length\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"2 hours\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"5 minutes\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Unlimited\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2 pr-4 \",\"children\":\"Unlimited\"}],[\"$\",\"td\",\"5\",{\"className\":\"py-2  \",\"children\":\"Unlimited\"}]]}],[\"$\",\"tr\",\"Video Count\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"