],[\"$\",\"p\",null,{\"className\":\"mt-3 text-xs text-muted-foreground\",\"children\":[\"Built and maintained by\",\" \",[\"$\",\"$L4\",null,{\"href\":\"/about\",\"className\":\"font-medium text-foreground underline-offset-4 hover:underline\",\"rel\":\"author\",\"children\":\"James Nicolaus\"}],\"$undefined\"]}]]\n1d:[\"$\",\"section\",null,{\"aria-label\":\"Summary\",\"className\":\"mt-6 rounded-lg border border-brand/30 bg-brand/5 p-4\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm leading-relaxed text-foreground\",\"children\":\"Free Tool Shed's Screen Recorder captures your screen, a window, or a browser tab with optional webcam picture-in-picture and microphone audio — all client-side via the MediaRecorder API. Trim the recording in-browser and export to WebM, MP4, or animated GIF. No upload, no sign-up, no time limit beyond your machine's memory. A free alternative to Loom and Vidyard.\"}]}]\n1e:[\"$\",\"div\",null,{\"className\":\"mt-6 grid gap-4 sm:grid-cols-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"No Time Limits\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Loom's free plan caps you at 5 minutes per video. Here there are no caps, no watermarks, and no upload queue — record as long as your browser has memory.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Webcam Picture-in-Picture\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Drop your webcam into any corner as a circle or square bubble. The overlay is baked into the final video, ready to share.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Trim & Export\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Trim the start or end with draggable handles, then download as WebM (instant) or convert to MP4 / GIF in-browser. No uploads.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Your Video Stays Private\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"The recording is held in your browser tab's memory and never uploaded. Close the tab to wipe it — no servers, no accounts.\"}]]}]]}]\n1f:[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L2a\",null,{}]}]\n20:[\"$\",\"div\",null,{\"className\":\"my-8 flex justify-center\",\"children\":[\"$\",\"$L16\",null,{\"slot\":\"mid-content\"}]}]\n21:[\"$\",\"div\",null,{\"className\":\"mt-16 space-y-12\",\"children\":[[\"$\",\"$L2b\",null,{}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold\",\"children\":\"Free Screen Recorder Online — No Install, No Sign Up\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"You shouldn't have to create yet another account or install a 100 MB desktop app just to record a quick walkthrough. Free Tool Shed's Screen Recorder runs entirely in your browser — pick a quality preset, choose which audio to capture, optionally drop in a webcam overlay, and hit record. It works on Windows, macOS, Linux, Chromebooks, and even a locked-down work laptop where you can't install anything.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Unlike Loom (capped at 5 minutes and 25 videos on the free plan) or OBS Studio (powerful but a desktop install with a steep learning curve), this tool is built for the common case: record your screen, trim the ends, and download. Your video never leaves your browser — there are no servers, no accounts, and no upload queues. Export as WebM instantly, or convert to MP4 or GIF with an in-browser ffmpeg.wasm transcode. The whole thing is free, open, and ad-supported so it can stay that way.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Features\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid gap-x-8 gap-y-2 text-sm text-muted-foreground sm:grid-cols-2\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Record full screen, a single window, or a browser tab\"}],[\"$\",\"li\",null,{\"children\":\"720p, 1080p, or 1440p quality presets at 30 fps\"}],[\"$\",\"li\",null,{\"children\":\"VP9 / Opus encoding when your browser supports it\"}],[\"$\",\"li\",null,{\"children\":\"System audio capture (tab audio in Chrome)\"}],[\"$\",\"li\",null,{\"children\":\"Microphone capture for narration\"}],[\"$\",\"li\",null,{\"children\":\"Mix both audio sources in a single recording\"}],[\"$\",\"li\",null,{\"children\":\"Optional webcam picture-in-picture overlay\"}],[\"$\",\"li\",null,{\"children\":\"Choose any of four corners for the overlay\"}],[\"$\",\"li\",null,{\"children\":\"Small / Medium / Large webcam sizes\"}],[\"$\",\"li\",null,{\"children\":\"Circle or square webcam shape\"}],[\"$\",\"li\",null,{\"children\":\"Overlay is baked into the final video\"}],[\"$\",\"li\",null,{\"children\":\"3-second countdown before recording starts\"}],[\"$\",\"li\",null,{\"children\":\"Pause and resume without losing the clip\"}],[\"$\",\"li\",null,{\"children\":\"Up to 2 hours per recording\"}],[\"$\",\"li\",null,{\"children\":\"Live elapsed timer during recording\"}],[\"$\",\"li\",null,{\"children\":\"Draggable trim handles on the timeline\"}],[\"$\",\"li\",null,{\"children\":\"Keyboard nudges for frame-accurate trim boundaries\"}],[\"$\",\"li\",null,{\"children\":\"Non-destructive trim — reset anytime\"}],[\"$\",\"li\",null,{\"children\":\"Playback loops inside the trim window\"}],[\"$\",\"li\",null,{\"children\":\"WebM export with zero re-encode (instant)\"}],[\"$\",\"li\",null,{\"children\":\"MP4 export via in-browser H.264 / AAC transcode\"}],[\"$\",\"li\",null,{\"children\":\"GIF export with palette-optimised 12 fps output\"}],[\"$\",\"li\",null,{\"children\":\"Auto-generated filenames with date stamps\"}],[\"$\",\"li\",null,{\"children\":\"Cancel an export mid-transcode\"}],[\"$\",\"li\",null,{\"children\":\"Client-side only — your recording never leaves your browser\"}],[\"$\",\"li\",null,{\"children\":\"No account, no sign up, no watermarks\"}],[\"$\",\"li\",null,{\"children\":\"Preferences remembered across sessions\"}]]}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"How to Record Your Screen Online (5 Steps)\"}],[\"$\",\"ol\",null,{\"className\":\"mt-4 space-y-4\",\"children\":[[\"$\",\"li\",\"1. Set up your recording\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"1. Set up your recording\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Pick a quality preset (720p for small files, 1080p for the sweet spot, 1440p for crisp walkthroughs). Toggle system audio, your microphone, or both. Optionally enable the webcam overlay and pick a corner, size, and shape — it'll be baked into the final video.\"}]]}],\"$L2c\",\"$L2d\",\"$L2e\",\"$L2f\"]}]]}],\"$L30\",\"$L31\",\"$L32\"]}]\n22:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0s01892_~8u82.js\",\"async\":true,\"nonce\":\"$undefined\"}]\n23:[\"$\",\"$L33\",null,{\"children\":[\"$\",\"$28\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@34\"}]}]\n2c:[\"$\",\"li\",\"2. Start recording\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"2. Start recording\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Click Start Recording. Your browser will open its native share picker where you choose a screen, window, or browser tab to capture. In Chrome, check 'Share tab audio' if you want system sound from a tab. After a 3-second countdown, recording begins.\"}]]}]\n2d:[\"$\",\"li\",\"3. Record, pause, and stop\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"3. Record, pause, and stop\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Click Pause to freeze the recording (the elapsed timer stops too) and Resume to pick it back up. When you're done, click Stop to finalize. There's no time limit beyond a 2-hour safety cap, and nothing is uploaded as you record — everything lives in your browser's memory.\"}]]}]\n2e:[\"$\",\"li\",\"4. Review and trim\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"4. Review and trim\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Play back your recording with the custom video player. Drag the two green handles on the timeline to cut the start or end. Use ← / → for 0.1s nudges, or hold Shift for 1-second steps. Home and End snap to the boundaries. Hit Reset trim anytime to restore the full range.\"}]]}]\n2f:[\"$\",\"li\",\"5. Export your recording\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"5. Export your recording\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Choose WebM for an instant download (no transcode, no waiting), MP4 for universal H.264 playback, or GIF for a palette-optimised animation. Give the file a name and click Download. MP4 and GIF lazy-load a ~30 MB ffmpeg core on first use — cached afterwards, so follow-up exports are much faster.\"}]]}]\n30:[[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-tips\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-tips\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":[\"Tips from Building \",\"the Screen Recorder\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Pick the smallest capture region that still tells the story\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\",\"key\":\"1gvzjb\"}],[\"path\",{\"d\":\"M9 18h6\",\"key\":\"x1upvd\"}],[\"path\",{\"d\":\"M10 22h4\",\"key\":\"ceow96\"}]],\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Pick the smallest capture region that still tells the story\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Full-screen recordings are the largest, the slowest to upload, and the hardest to watch on a phone. Pick a specific window or tab when the whole screen isn't necessary.\"}]]}]]}],[\"$\",\"li\",\"Enable system audio for app demos, mic for narration\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$30:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Enable system audio for app demos, mic for narration\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"App demos need the application's own sound (notifications, video output). Walk-throughs need your voice. The recorder lets you mix both — pick the right combination for your audience.\"}]]}]]}],[\"$\",\"li\",\"Trim before exporting\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$30:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Trim before exporting\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"The first few seconds (mouse moving to start) and last few seconds (mouse moving to stop) almost always need trimming. The built-in trim removes them without re-encoding.\"}]]}]]}],[\"$\",\"li\",\"Export WebM for the web, MP4 for sharing\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$30:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Export WebM for the web, MP4 for sharing\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"WebM is smaller and renders directly in browsers — best for embedding. MP4 is more compatible with messaging apps, social platforms, and older players.\"}]]}]]}]]}]]}],[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-mistakes\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-mistakes\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Common Mistakes to Avoid\"}],[\"$\",\"