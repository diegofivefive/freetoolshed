":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Data Privacy\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Client-side only\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Cloud account\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Local only\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"Cloud (web)\"}]]}]\n40:[\"$\",\"tr\",\"File Size Limit\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"File Size Limit\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Browser memory\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Disk space\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Disk space\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"5 min (free web)\"}]]}]\n41:[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Can I undo my edits?\"}]\n42:[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. The editor keeps a 50-step undo/redo history. Ctrl+Z to undo, Ctrl+Y to redo. You can also use the toolbar buttons.\"}]\n43:[\"$\",\"details\",\"Does the noise reduction actually work?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Does the noise reduction actually work?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"For light background noise (hiss, hum, room tone), yes. It estimates the noise floor from quiet sections and attenuates below that threshold. Adjust strength from 0–1. For heavy noise, apply multiple passes. It's not as advanced as Audacity's spectral subtraction, but it handles common cases.\"}]]}]\n44:[\"$\",\"details\",\"Is there a file size limit?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Is there a file size limit?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"No hard limit — it depends on your browser's available memory. Files under 100 MB work smoothly. Very long recordings (1+ hour) may use significant memory.\"}]]}]\n26:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n45:I[27201,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\"],\"IconMark\"]\n29:[[\"$\",\"title\",\"0\",{\"children\":\"Free Audio Editor Online — No Sign Up | Free Tool Shed\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Trim, cut, and convert audio files online — no install, no sign-up. Works on any device with a browser. A free alternative to Adobe Audition. No sign up required.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"google-adsense-account\",\"content\":\"ca-pub-7700405385978151\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://freetoolshed.com/tools/audio-editor\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"Free Audio Editor Online — No Sign Up | Free Tool Shed\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"Trim, cut, and convert audio files online — no install, no sign-up. Works on any device with a browser. A free alternative to Adobe Audition. No sign up required.\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:url\",\"content\":\"https://freetoolshed.com/tools/audio-editor\"}],[\