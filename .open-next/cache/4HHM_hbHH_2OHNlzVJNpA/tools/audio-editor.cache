{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/tools/layout,_N_T_/tools/audio-editor/layout,_N_T_/tools/audio-editor/page,_N_T_/tools/audio-editor"},"segmentPaths":["/_tree","/_full","/tools/audio-editor/__PAGE__","/tools/audio-editor","/tools","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable h-full\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.09zddjkbdep5a.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.09~u27dqhyhd6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/123doanyjnwwq.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/04uuf1716ltqa.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0eyplc079uusk.js\"/><script src=\"/_next/static/chunks/0tszvp5wpnn-t.js\" async=\"\"></script><script src=\"/_next/static/chunks/0bss4aof7q0cj.js\" async=\"\"></script><script src=\"/_next/static/chunks/0hi511ipeys_s.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-13rn3bqw7ype6.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zif8_3mgcc0x.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zv.me6xdrdsz.js\" async=\"\"></script><script src=\"/_next/static/chunks/0ag6f0zogt0qg.js\" async=\"\"></script><script src=\"/_next/static/chunks/04p0ygcx_g620.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0_pa1c_tsbiw0.js\" async=\"\"></script><script src=\"/_next/static/chunks/10nuyoal1pib2.js\" async=\"\"></script><script src=\"/_next/static/chunks/11~hh-yuwxxvh.js\" async=\"\"></script><script src=\"/_next/static/chunks/04v8-.addjpun.js\" async=\"\"></script><link rel=\"preconnect\" href=\"https://www.highperformanceformat.com\" crossorigin=\"anonymous\"/><link rel=\"dns-prefetch\" href=\"https://www.highperformanceformat.com\"/><link rel=\"preconnect\" href=\"https://pl29142630.profitablecpmratenetwork.com\" crossorigin=\"anonymous\"/><link rel=\"dns-prefetch\" href=\"https://pl29142630.profitablecpmratenetwork.com\"/><meta name=\"next-size-adjust\" content=\"\"/><title>Free Audio Editor Online — No Sign Up | Free Tool Shed</title><meta name=\"description\" content=\"Trim, cut, and convert audio files online — no install, no sign-up. Works on any device with a browser. A free alternative to Adobe Audition. No sign up required.\"/><meta name=\"google-adsense-account\" content=\"ca-pub-7700405385978151\"/><link rel=\"canonical\" href=\"https://freetoolshed.com/tools/audio-editor\"/><meta property=\"og:title\" content=\"Free Audio Editor Online — No Sign Up | Free Tool Shed\"/><meta property=\"og:description\" content=\"Trim, cut, and convert audio files online — no install, no sign-up. Works on any device with a browser. A free alternative to Adobe Audition. No sign up required.\"/><meta property=\"og:url\" content=\"https://freetoolshed.com/tools/audio-editor\"/><meta property=\"og:site_name\" content=\"Free Tool Shed\"/><meta property=\"og:image\" content=\"https://freetoolshed.com/screenshots/audio-editor.png\"/><meta property=\"og:image:width\" content=\"1440\"/><meta property=\"og:image:height\" content=\"900\"/><meta property=\"og:image:alt\" content=\"Audio Editor workspace screenshot\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Free Audio Editor Online — No Sign Up | Free Tool Shed\"/><meta name=\"twitter:description\" content=\"Trim, cut, and convert audio files online — no install, no sign-up. Works on any device with a browser. A free alternative to Adobe Audition. No sign up required.\"/><meta name=\"twitter:image\" content=\"https://freetoolshed.com/screenshots/audio-editor.png\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/favicon.ico\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\",\"logo\":\"https://freetoolshed.com/og-image.png\",\"description\":\"Free, browser-based tools that replace paid software. No sign up, no downloads, no servers — every tool runs client-side.\",\"founder\":{\"@type\":\"Person\",\"name\":\"James Nicolaus\",\"url\":\"https://freetoolshed.com/about\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\",\"publisher\":{\"@type\":\"Organization\",\"name\":\"Free Tool Shed\"}}</script><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"flex min-h-full flex-col antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><script>((a,b,c,d,e,f,g,h)=>{let i=document.documentElement,j=[\"light\",\"dark\"];function k(b){var c;(Array.isArray(a)?a:[a]).forEach(a=>{let c=\"class\"===a,d=c&&f?e.map(a=>f[a]||a):e;c?(i.classList.remove(...d),i.classList.add(f&&f[b]?f[b]:b)):i.setAttribute(a,b)}),c=b,h&&j.includes(c)&&(i.style.colorScheme=c)}if(d)k(d);else try{let a=localStorage.getItem(b)||c,d=g&&\"system\"===a?window.matchMedia(\"(prefers-color-scheme: dark)\").matches?\"dark\":\"light\":a;k(d)}catch(a){}})(\"class\",\"theme\",\"system\",null,[\"light\",\"dark\"],null,true,true)</script><nav class=\"sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60\"><div class=\"mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8\"><a class=\"flex items-center gap-2 font-heading text-lg font-semibold\" href=\"/\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-wrench size-5 text-brand\" aria-hidden=\"true\"><path d=\"M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z\"></path></svg><span>Free Tool Shed</span></a><div class=\"flex items-center gap-1\"><a class=\"rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground\" href=\"/about\">About</a><a class=\"rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground\" href=\"/contact\">Contact</a><button type=\"button\" tabindex=\"0\" data-slot=\"button\" aria-label=\"Toggle theme\" class=\"group/button inline-flex shrink-0 items-center justify-center rounded-lg border border-transparent bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 active:translate-y-px disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 [&amp;_svg]:pointer-events-none [&amp;_svg]:shrink-0 [&amp;_svg:not([class*=&#x27;size-&#x27;])]:size-4 hover:bg-muted hover:text-foreground aria-expanded:bg-muted aria-expanded:text-foreground dark:hover:bg-muted/50 size-8\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sun size-4 scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><path d=\"M12 2v2\"></path><path d=\"M12 20v2\"></path><path d=\"m4.93 4.93 1.41 1.41\"></path><path d=\"m17.66 17.66 1.41 1.41\"></path><path d=\"M2 12h2\"></path><path d=\"M20 12h2\"></path><path d=\"m6.34 17.66-1.41 1.41\"></path><path d=\"m19.07 4.93-1.41 1.41\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-moon absolute size-4 scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0\" aria-hidden=\"true\"><path d=\"M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401\"></path></svg></button></div></div></nav><div class=\"flex flex-1 flex-col\"><div class=\"mx-auto w-full max-w-7xl flex-1 px-4 py-6 sm:px-6 lg:px-8\"><div class=\"flex gap-6\"><main class=\"min-w-0 flex-1\"><div class=\"mb-4 hidden justify-center lg:flex\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:728px;height:90px;max-width:100%\" data-ad-slot=\"leaderboard\"></div></div><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"Free Audio Editor\",\"description\":\"Trim, cut, and convert audio files online — no install, no sign-up. Works on any device with a browser.\",\"url\":\"https://freetoolshed.com/tools/audio-editor\",\"applicationCategory\":\"UtilitiesApplication\",\"operatingSystem\":\"Web\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"HowTo\",\"name\":\"How to Trim Audio Online\",\"description\":\"Import an audio file, select a region on the waveform, apply edits or effects, and export.\",\"url\":\"https://freetoolshed.com/tools/audio-editor\",\"step\":[{\"@type\":\"HowToStep\",\"position\":1,\"name\":\"1. Import your audio file\",\"text\":\"Drag and drop an audio file onto the editor, or click to browse. Supported formats include MP3, WAV, OGG, AAC, FLAC, and WebM. Your file is decoded locally in your browser — nothing is uploaded.\"},{\"@type\":\"HowToStep\",\"position\":2,\"name\":\"2. Navigate the waveform\",\"text\":\"Use the visual waveform to see your audio. Hold Ctrl (or Cmd on Mac) and scroll to zoom in and out — the view zooms toward your cursor for fast navigation. Scroll without a modifier to pan left and right. Click anywhere to position the playhead, then press Space to play.\"},{\"@type\":\"HowToStep\",\"position\":3,\"name\":\"3. Select a region\",\"text\":\"Click and drag on the waveform to highlight a region. The selection is shown in green. Use selection-only playback to preview exactly what you've selected before making edits.\"},{\"@type\":\"HowToStep\",\"position\":4,\"name\":\"4. Edit and apply effects\",\"text\":\"Use the toolbar buttons to trim, delete, or silence the selection. Apply effects like fade in, fade out, normalize, reverse, amplify, or noise reduction from the effects bar below the waveform.\"},{\"@type\":\"HowToStep\",\"position\":5,\"name\":\"5. Export your edited audio\",\"text\":\"Choose your export format (WAV for lossless, MP3 or OGG for compressed) and bitrate, then click Download. The file is encoded in your browser and saved directly to your device.\"}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Why use this instead of Audacity?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Audacity is more powerful for advanced work, but it requires a desktop install. This tool is for quick jobs — trim an MP3, cut a clip, convert a format — right in your browser. No download, works on any device, takes under a minute.\"}},{\"@type\":\"Question\",\"name\":\"How do I trim an MP3 online?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Drop your MP3 onto the editor, click and drag on the waveform to select the section you want, click Crop (or press T), then Download. Takes about 30 seconds.\"}},{\"@type\":\"Question\",\"name\":\"Can I convert WAV to MP3 online?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Import any WAV file, choose MP3 from the export dropdown, select your bitrate (128–320 kbps), and click Download. The conversion happens in your browser — nothing is uploaded.\"}},{\"@type\":\"Question\",\"name\":\"Is this audio editor really free?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, completely free. No hidden fees, no premium tiers, and no sign-up required. The tool is ad-supported so it can remain free for everyone.\"}},{\"@type\":\"Question\",\"name\":\"Do I need to install anything?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. It runs entirely in your browser. No 100 MB download, no plugins, no extensions. Open the page and start editing.\"}},{\"@type\":\"Question\",\"name\":\"What audio formats are supported?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Import: MP3, WAV, OGG, AAC, FLAC, and WebM. Export: WAV (lossless), MP3, or OGG with configurable bitrate.\"}},{\"@type\":\"Question\",\"name\":\"Is my audio data private?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. All processing happens locally in your browser using the Web Audio API. Your files are never uploaded to any server.\"}},{\"@type\":\"Question\",\"name\":\"Does it support effects like fade in and fade out?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Apply fade in, fade out, normalize volume, reverse audio, amplify, and noise reduction — all processed locally in your browser.\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://freetoolshed.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Audio Editor\"}]}</script><nav aria-label=\"Breadcrumb\" class=\"mb-4\"><ol class=\"flex items-center gap-1 text-sm text-muted-foreground\"><li class=\"flex items-center gap-1\"><a class=\"transition-colors hover:text-foreground\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right size-3.5 shrink-0\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg><span class=\"text-foreground\">Audio Editor</span></li></ol></nav><h1 class=\"text-3xl font-bold tracking-tight\">Trim Audio Online — Free, No Install</h1><p class=\"mt-2 text-lg text-muted-foreground\">Need to trim an MP3, cut a WAV, or convert audio formats? Do it right here — no downloading Audacity, no Adobe subscription, no sign-up. Just drop your file and edit.</p><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Person\",\"name\":\"James Nicolaus\",\"jobTitle\":\"Builder & Maintainer, Free Tool Shed\",\"description\":\"James Nicolaus builds and maintains every tool on Free Tool Shed. Each tool is designed, tested in real browsers across desktop and mobile, and shipped only after handling the messy edge cases — large files, slow connections, unusual inputs — that paid alternatives often hide behind sign-up walls.\",\"url\":\"https://freetoolshed.com/about\",\"worksFor\":{\"@type\":\"Organization\",\"name\":\"Free Tool Shed\",\"url\":\"https://freetoolshed.com\"}}</script><p class=\"mt-3 text-xs text-muted-foreground\">Built and maintained by<!-- --> <a class=\"font-medium text-foreground underline-offset-4 hover:underline\" rel=\"author\" href=\"/about\">James Nicolaus</a></p><section aria-label=\"Summary\" class=\"mt-6 rounded-lg border border-brand/30 bg-brand/5 p-4\"><p class=\"text-sm leading-relaxed text-foreground\">Free Tool Shed&#x27;s Audio Editor lets you cut, trim, fade, normalize, and merge audio in a visual waveform editor — running entirely in your browser via the Web Audio API. Supports MP3, WAV, M4A, OGG, and FLAC input; exports to WAV, MP3, or OGG. No upload, no sign-up, no install — a free alternative to Adobe Audition and Audacity Cloud.</p></section><div class=\"mt-6 grid gap-4 sm:grid-cols-2\"><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">No Install, Any Device</h2><p class=\"mt-1 text-sm text-muted-foreground\">Runs entirely in your browser. Works on Windows, Mac, Linux, and Chromebooks — no 100 MB download for a 30-second trim.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">Trim, Cut &amp; Export in Seconds</h2><p class=\"mt-1 text-sm text-muted-foreground\">Drop an MP3 or WAV, drag to select the part you want, hit trim, and download. Most edits take under a minute.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">Convert MP3, WAV, OGG &amp; More</h2><p class=\"mt-1 text-sm text-muted-foreground\">Import MP3, WAV, OGG, AAC, FLAC, or WebM. Export as WAV (lossless), MP3, or OGG with configurable bitrate.</p></div><div class=\"rounded-lg border border-border bg-card p-4\"><h2 class=\"text-sm font-semibold\">Your Files Stay Private</h2><p class=\"mt-1 text-sm text-muted-foreground\">All processing happens locally using the Web Audio API. Nothing is uploaded — your audio never leaves your device.</p></div></div><div class=\"mt-8\"><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--></div><div class=\"my-8 flex justify-center\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:728px;height:90px;max-width:100%\" data-ad-slot=\"mid-content\"></div></div><div class=\"mt-16 space-y-12\"><div data-orientation=\"horizontal\" role=\"separator\" aria-orientation=\"horizontal\" data-slot=\"separator\" class=\"shrink-0 bg-border data-horizontal:h-px data-horizontal:w-full data-vertical:w-px data-vertical:self-stretch\"></div><section><h2 class=\"text-2xl font-semibold\">Trim Audio Online — No Install Required</h2><p class=\"mt-3 max-w-3xl text-muted-foreground\">You shouldn&#x27;t need to download a 100 MB desktop app just to trim an MP3 or cut a section from a WAV file. Free Tool Shed&#x27;s Audio Editor lets you trim audio online, convert between formats, and apply effects — all in your browser. No installation, no account, no subscription. It works on any device: Windows, Mac, Linux, Chromebooks, even a locked-down work computer.</p><p class=\"mt-3 max-w-3xl text-muted-foreground\">Unlike Adobe Audition ($22.99/month) or Audacity (desktop-only), this tool is built for quick edits: drop a file, make your cut, download the result. Most tasks take under a minute. Need more? Apply fade in/out, normalize volume, reduce noise, reverse audio, or convert WAV to MP3 — all processed locally. Your files never leave your device.</p></section><section><h2 class=\"text-xl font-semibold\">Features</h2><ul class=\"mt-4 grid gap-x-8 gap-y-2 text-sm text-muted-foreground sm:grid-cols-2\"><li>Visual waveform display with per-pixel peak rendering</li><li>Click-and-drag region selection on the waveform</li><li>Trim (crop) audio to selection</li><li>Delete selected region and join remaining parts</li><li>Silence selected region</li><li>Fade in and fade out effects</li><li>Normalize volume to peak amplitude</li><li>Reverse audio (entire track or selection)</li><li>Amplify with configurable gain factor</li><li>Noise reduction with adjustable strength</li><li>50-step undo/redo history</li><li>Export as WAV (lossless), MP3, or OGG</li><li>Configurable bitrate for compressed formats</li><li>Ctrl+scroll to zoom toward cursor, scroll to pan</li><li>Keyboard shortcuts (Space, Delete, T, Ctrl+Z/Y)</li><li>Time grid overlay with automatic scaling</li><li>Real-time playhead animation during playback</li><li>Selection-only playback preview</li><li>Mute toggle and gain control</li><li>Drag-and-drop file import</li><li>Supports MP3, WAV, OGG, AAC, FLAC, and WebM input</li><li>Export preferences saved across sessions</li><li>Client-side only — audio never leaves your browser</li></ul></section><section><h2 class=\"text-xl font-semibold\">How to Trim Audio Online (5 Steps)</h2><ol class=\"mt-4 space-y-4\"><li><p class=\"font-medium\">1. Import your audio file</p><p class=\"mt-1 text-sm text-muted-foreground\">Drag and drop an audio file onto the editor, or click to browse. Supported formats include MP3, WAV, OGG, AAC, FLAC, and WebM. Your file is decoded locally in your browser — nothing is uploaded.</p></li><li><p class=\"font-medium\">2. Navigate the waveform</p><p class=\"mt-1 text-sm text-muted-foreground\">Use the visual waveform to see your audio. Hold Ctrl (or Cmd on Mac) and scroll to zoom in and out — the view zooms toward your cursor for fast navigation. Scroll without a modifier to pan left and right. Click anywhere to position the playhead, then press Space to play.</p></li><li><p class=\"font-medium\">3. Select a region</p><p class=\"mt-1 text-sm text-muted-foreground\">Click and drag on the waveform to highlight a region. The selection is shown in green. Use selection-only playback to preview exactly what you&#x27;ve selected before making edits.</p></li><li><p class=\"font-medium\">4. Edit and apply effects</p><p class=\"mt-1 text-sm text-muted-foreground\">Use the toolbar buttons to trim, delete, or silence the selection. Apply effects like fade in, fade out, normalize, reverse, amplify, or noise reduction from the effects bar below the waveform.</p></li><li><p class=\"font-medium\">5. Export your edited audio</p><p class=\"mt-1 text-sm text-muted-foreground\">Choose your export format (WAV for lossless, MP3 or OGG for compressed) and bitrate, then click Download. The file is encoded in your browser and saved directly to your device.</p></li></ol></section><section aria-labelledby=\"tool-insights-tips\"><h2 id=\"tool-insights-tips\" class=\"text-2xl font-semibold tracking-tight\">Tips from Building <!-- -->the Audio Editor</h2><p class=\"mt-3 max-w-3xl text-muted-foreground\">Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.</p><ul class=\"mt-4 grid max-w-3xl gap-3\"><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Match sample rate to the source</h3><p class=\"mt-1 text-sm text-muted-foreground\">Resampling audio (44.1 kHz → 48 kHz, for instance) introduces interpolation artifacts. Export at the same sample rate as your source unless you specifically need to change it.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Normalize before, not after, hard edits</h3><p class=\"mt-1 text-sm text-muted-foreground\">Normalizing first gives you a consistent peak level to cut against. Doing it after a hard cut can re-amplify clipping that the cut would have removed.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Use short fades to hide hard cuts</h3><p class=\"mt-1 text-sm text-muted-foreground\">Even a 20–50 ms fade in/out smooths the click that abrupt edits create. The tool&#x27;s fade controls are deliberately small-default for exactly this case.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><div><h3 class=\"text-sm font-semibold\">Keep an unmodified original</h3><p class=\"mt-1 text-sm text-muted-foreground\">Edits are destructive in any waveform editor. Export a copy of the trimmed/cleaned version under a new filename rather than overwriting the source.</p></div></li></ul></section><section aria-labelledby=\"tool-insights-mistakes\"><h2 id=\"tool-insights-mistakes\" class=\"text-2xl font-semibold tracking-tight\">Common Mistakes to Avoid</h2><ul class=\"mt-4 grid max-w-3xl gap-3\"><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Exporting MP3 when WAV is needed</h3><p class=\"mt-1 text-sm text-muted-foreground\">MP3 is lossy — every re-export loses fidelity. For master files or anything you&#x27;ll edit again, export WAV and convert to MP3 only for delivery.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Ignoring clipping in the waveform</h3><p class=\"mt-1 text-sm text-muted-foreground\">Flat tops at the peak of a waveform mean the audio is clipped — the data above the ceiling is gone. Lower the gain before trimming if you see this; you can&#x27;t recover clipped audio.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Merging files at different sample rates</h3><p class=\"mt-1 text-sm text-muted-foreground\">Mixing a 48 kHz file with a 44.1 kHz file without resampling causes pitch and timing drift. Convert one to match the other before merging.</p></div></li><li class=\"flex gap-3 rounded-lg border border-border bg-card p-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg><div><h3 class=\"text-sm font-semibold\">Not previewing the cut region</h3><p class=\"mt-1 text-sm text-muted-foreground\">The waveform shows where the cut happens; preview it before exporting. A cut that looks right at the waveform level can still cut a syllable in half — your ears catch what the eyes miss.</p></div></li></ul></section><section aria-labelledby=\"tool-insights-takeaways\" class=\"rounded-lg border border-brand/30 bg-brand/5 p-5\"><h2 id=\"tool-insights-takeaways\" class=\"text-lg font-semibold tracking-tight\">Key Takeaways</h2><ul class=\"mt-3 space-y-2\"><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">The Audio Editor cuts, trims, fades, normalizes, and merges audio in a visual waveform editor.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">All processing runs locally via the Web Audio API; files never leave the browser.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">Supports MP3, WAV, M4A, OGG, and FLAC input; exports to WAV, MP3, or OGG.</span></li><li class=\"flex items-start gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-sm text-foreground\">It is a free alternative to Adobe Audition and Audacity Cloud for routine audio cleanup and trimming.</span></li></ul></section><section><h2 class=\"text-xl font-semibold\">Free Adobe Audition Alternative</h2><div class=\"mt-4 overflow-x-auto\"><table class=\"w-full min-w-[600px] border-collapse text-sm\"><thead><tr class=\"border-b border-border text-left\"><th class=\"py-2 pr-4 font-semibold\">Feature</th><th class=\"py-2 pr-4 font-semibold\">Free Tool Shed</th><th class=\"py-2 pr-4 font-semibold\">Adobe Audition</th><th class=\"py-2 pr-4 font-semibold\">Audacity</th><th class=\"py-2 font-semibold\">TwistedWave</th></tr></thead><tbody class=\"text-muted-foreground\"><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Price</td><td class=\"py-2 pr-4 font-medium text-foreground\">Free forever</td><td class=\"py-2 pr-4 \">$22.99/mo</td><td class=\"py-2 pr-4 \">Free</td><td class=\"py-2  \">$79.90 (Mac)</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Installation</td><td class=\"py-2 pr-4 font-medium text-foreground\">None (browser)</td><td class=\"py-2 pr-4 \">Desktop app</td><td class=\"py-2 pr-4 \">Desktop app</td><td class=\"py-2  \">Desktop/Web</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Account Required</td><td class=\"py-2 pr-4 font-medium text-foreground\">No</td><td class=\"py-2 pr-4 \">Yes (Adobe ID)</td><td class=\"py-2 pr-4 \">No</td><td class=\"py-2  \">Yes (web)</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Waveform Editor</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2  \">Yes</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Trim / Cut / Delete</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2  \">Yes</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Fade In / Fade Out</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2  \">Yes</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Normalize</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2  \">Yes</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Reverse Audio</td><td class=\"py-2 pr-4 font-medium text-foreground\">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2 pr-4 \">Yes</td><td class=\"py-2  \">Yes</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Noise Reduction</td><td class=\"py-2 pr-4 font-medium text-foreground\">Basic</td><td class=\"py-2 pr-4 \">Advanced (AI)</td><td class=\"py-2 pr-4 \">Advanced</td><td class=\"py-2  \">Basic</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Multi-track</td><td class=\"py-2 pr-4 font-medium text-foreground\">Single track</td><td class=\"py-2 pr-4 \">Unlimited</td><td class=\"py-2 pr-4 \">Unlimited</td><td class=\"py-2  \">Single track</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">WAV Export</td><td class=\"py-2 pr-4 font-medium text-foreground\">Free</td><td class=\"py-2 pr-4 \">Included</td><td class=\"py-2 pr-4 \">Free</td><td class=\"py-2  \">Free (limited)</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">MP3 / OGG Export</td><td class=\"py-2 pr-4 font-medium text-foreground\">Free</td><td class=\"py-2 pr-4 \">Included</td><td class=\"py-2 pr-4 \">Free (with plugin)</td><td class=\"py-2  \">Paid</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Undo / Redo</td><td class=\"py-2 pr-4 font-medium text-foreground\">50 steps</td><td class=\"py-2 pr-4 \">Unlimited</td><td class=\"py-2 pr-4 \">Unlimited</td><td class=\"py-2  \">Unlimited</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">Data Privacy</td><td class=\"py-2 pr-4 font-medium text-foreground\">Client-side only</td><td class=\"py-2 pr-4 \">Cloud account</td><td class=\"py-2 pr-4 \">Local only</td><td class=\"py-2  \">Cloud (web)</td></tr><tr class=\"border-b border-border/50\"><td class=\"py-2 pr-4 \">File Size Limit</td><td class=\"py-2 pr-4 font-medium text-foreground\">Browser memory</td><td class=\"py-2 pr-4 \">Disk space</td><td class=\"py-2 pr-4 \">Disk space</td><td class=\"py-2  \">5 min (free web)</td></tr></tbody></table></div></section><section><h2 class=\"text-xl font-semibold\">Frequently Asked Questions</h2><div class=\"mt-4 space-y-3\"><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Why use this instead of Audacity?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Audacity is more powerful — multi-track, VST plugins, spectral editing. But it requires a desktop install. This tool is for quick jobs: trim an MP3, cut a clip, convert a format. Open a URL, drop your file, done in under a minute. No download, works on Chromebooks and locked-down machines, nothing to uninstall afterward.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Is this audio editor really free?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Yes, completely free. No hidden fees, no premium tiers, and no sign-up required. The tool is ad-supported so it can remain free for everyone.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Do I need to install anything?</summary><p class=\"mt-2 text-sm text-muted-foreground\">No. It runs entirely in your browser. No 100 MB download, no plugins, no extensions. Open the page and start editing — that&#x27;s the whole point.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">How do I trim an MP3 online?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Drop your MP3 file onto the editor (or click to browse). Click and drag on the waveform to select the section you want to keep, then click the Crop button or press T. Hit Download to save the trimmed file. The whole process takes about 30 seconds.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Can I convert WAV to MP3?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Yes. Import any WAV file, then choose MP3 from the export format dropdown and select your bitrate (128–320 kbps). Click Download. The conversion happens entirely in your browser.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">What audio formats are supported?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Import: MP3, WAV, OGG, AAC, FLAC, and WebM. Export: WAV (lossless), MP3, or OGG with configurable bitrate.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Is my audio data private?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Yes. All processing happens locally in your browser using the Web Audio API. Your files are never uploaded to any server. We can&#x27;t see them and neither can anyone else.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Can I undo my edits?</summary><p class=\"mt-2 text-sm text-muted-foreground\">Yes. The editor keeps a 50-step undo/redo history. Ctrl+Z to undo, Ctrl+Y to redo. You can also use the toolbar buttons.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Does the noise reduction actually work?</summary><p class=\"mt-2 text-sm text-muted-foreground\">For light background noise (hiss, hum, room tone), yes. It estimates the noise floor from quiet sections and attenuates below that threshold. Adjust strength from 0–1. For heavy noise, apply multiple passes. It&#x27;s not as advanced as Audacity&#x27;s spectral subtraction, but it handles common cases.</p></details><details class=\"group rounded-lg border border-border px-4 py-3\"><summary class=\"cursor-pointer font-medium\">Is there a file size limit?</summary><p class=\"mt-2 text-sm text-muted-foreground\">No hard limit — it depends on your browser&#x27;s available memory. Files under 100 MB work smoothly. Very long recordings (1+ hour) may use significant memory.</p></details></div></section></div><!--$--><!--/$--></main><aside class=\"hidden w-[300px] shrink-0 lg:block\"><div class=\"sticky top-20\"><div class=\"flex items-center justify-center overflow-hidden rounded \" style=\"width:300px;height:250px;max-width:100%\" data-ad-slot=\"sidebar\"></div><div id=\"tool-guide-portal\"></div></div></aside></div></div></div><footer class=\"border-t border-border bg-muted/40\"><div class=\"mx-auto flex max-w-7xl flex-col items-center gap-4 px-4 py-8 sm:flex-row sm:justify-between sm:px-6 lg:px-8\"><p class=\"text-sm text-muted-foreground\">© <!-- -->2026<!-- --> Free Tool Shed. All rights reserved.</p><nav class=\"flex gap-4 text-sm text-muted-foreground\"><a class=\"transition-colors hover:text-foreground\" href=\"/about\">About</a><a class=\"transition-colors hover:text-foreground\" href=\"/contact\">Contact</a><a class=\"transition-colors hover:text-foreground\" href=\"/privacy\">Privacy</a><a class=\"transition-colors hover:text-foreground\" href=\"/terms\">Terms</a></nav></div></footer><script src=\"/_next/static/chunks/0eyplc079uusk.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[83661,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\