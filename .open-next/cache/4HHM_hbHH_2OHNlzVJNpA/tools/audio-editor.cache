r\",\"Noise Reduction\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Noise Reduction\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Basic\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Advanced (AI)\"}],\"$L39\",\"$L3a\"]}],\"$L3b\",\"$L3c\",\"$L3d\",\"$L3e\",\"$L3f\",\"$L40\"]}]]}]}]]}]\n31:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Frequently Asked Questions\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-3\",\"children\":[[\"$\",\"details\",\"Why use this instead of Audacity?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Why use this instead of Audacity?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Audacity is more powerful — multi-track, VST plugins, spectral editing. But it requires a desktop install. This tool is for quick jobs: trim an MP3, cut a clip, convert a format. Open a URL, drop your file, done in under a minute. No download, works on Chromebooks and locked-down machines, nothing to uninstall afterward.\"}]]}],[\"$\",\"details\",\"Is this audio editor really free?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Is this audio editor really free?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes, completely free. No hidden fees, no premium tiers, and no sign-up required. The tool is ad-supported so it can remain free for everyone.\"}]]}],[\"$\",\"details\",\"Do I need to install anything?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Do I need to install anything?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"No. It runs entirely in your browser. No 100 MB download, no plugins, no extensions. Open the page and start editing — that's the whole point.\"}]]}],[\"$\",\"details\",\"How do I trim an MP3 online?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"How do I trim an MP3 online?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Drop your MP3 file onto the editor (or click to browse). Click and drag on the waveform to select the section you want to keep, then click the Crop button or press T. Hit Download to save the trimmed file. The whole process takes about 30 seconds.\"}]]}],[\"$\",\"details\",\"Can I convert WAV to MP3?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Can I convert WAV to MP3?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. Import any WAV file, then choose MP3 from the export format dropdown and select your bitrate (128–320 kbps). Click Download. The conversion happens entirely in your browser.\"}]]}],[\"$\",\"details\",\"What audio formats are supported?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"What audio formats are supported?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Import: MP3, WAV, OGG, AAC, FLAC, and WebM. Export: WAV (lossless), MP3, or OGG with configurable bitrate.\"}]]}],[\"$\",\"details\",\"Is my audio data private?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Is my audio data private?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. All processing happens locally in your browser using the Web Audio API. Your files are never uploaded to any server. We can't see them and neither can anyone else.\"}]]}],[\"$\",\"details\",\"Can I undo my edits?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[\"$L41\",\"$L42\"]}],\"$L43\",\"$L44\"]}]]}]\n34:[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"MP3 is lossy — every re-export loses fidelity. For master files or anything you'll edit again, export WAV and convert to MP3 only for delivery.\"}]\n35:[\"$\",\"li\",\"Ignoring clipping in the waveform\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2f:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Ignoring clipping in the waveform\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Flat tops at the peak of a waveform mean the audio is clipped — the data above the ceiling is gone. Lower the gain before trimming if you see this; you can't recover clipped audio.\"}]]}]]}]\n36:[\"$\",\"li\",\"Merging files at different sample rates\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2f:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Merging files at different sample rates\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Mixing a 48 kHz file with a 44.1 kHz file without resampling causes pitch and timing drift. Convert one to match the other before merging.\"}]]}]]}]\n37:[\"$\",\"li\",\"Not previewing the cut region\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2f:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Not previewing the cut region\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"The waveform shows where the cut happens; preview it before exporting. A cut that looks right at the waveform level can still cut a syllable in half — your ears catch what the eyes miss.\"}]]}]]}]\n38:[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-takeaways\",\"className\":\"rounded-lg border border-brand/30 bg-brand/5 p-5\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-takeaways\",\"className\":\"text-lg font-semibold tracking-tight\",\"children\":\"Key Takeaways\"}],[\"$\",\"ul\",null,{\"className\":\"mt-3 space-y-2\",\"children\":[[\"$\",\"li\",\"The Audio Editor cuts, trims, fades, normalizes, and merges audio in a visual waveform editor.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"circle\",{\"cx\":\"12\",\"cy\":\"12\",\"r\":\"10\",\"key\":\"1mglay\"}],[\"path\",{\"d\":\"m9 12 2 2 4-4\",\"key\":\"dzmm74\"}]],\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"The Audio Editor cuts, trims, fades, normalizes, and merges audio in a visual waveform editor.\"}]]}],[\"$\",\"li\",\"All processing runs locally via the Web Audio API; files never leave the browser.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$38:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"All processing runs locally via the Web Audio API; files never leave the browser.\"}]]}],[\"$\",\"li\",\"Supports MP3, WAV, M4A, OGG, and FLAC input; exports to WAV, MP3, or OGG.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$38:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"Supports MP3, WAV, M4A, OGG, and FLAC input; exports to WAV, MP3, or OGG.\"}]]}],[\"$\",\"li\",\"It is a free alternative to Adobe Audition and Audacity Cloud for routine audio cleanup and trimming.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$38:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"It is a free alternative to Adobe Audition and Audacity Cloud for routine audio cleanup and trimming.\"}]]}]]}]]}]\n39:[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Advanced\"}]\n3a:[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"Basic\"}]\n3b:[\"$\",\"tr\",\"Multi-track\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"c