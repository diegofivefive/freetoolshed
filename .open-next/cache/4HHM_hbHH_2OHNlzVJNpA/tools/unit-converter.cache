-foreground\",\"children\":\"Press Ctrl+K to type natural language like \\\"5 miles to km\\\". Tab through fields, swap units with a keystroke, and batch-convert lists of values.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Instant Formula Display\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Every conversion shows the underlying math with syntax-highlighted formulas and animated variable substitution — perfect for students and engineers.\"}]]}]]}]\n1e:[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L29\",null,{}]}]\n1f:[\"$\",\"div\",null,{\"className\":\"my-8 flex justify-center\",\"children\":[\"$\",\"$L16\",null,{\"slot\":\"mid-content\"}]}]\n20:[\"$\",\"div\",null,{\"className\":\"mt-16 space-y-12\",\"children\":[[\"$\",\"$L2a\",null,{}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Free Unit Converter Online\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Free Tool Shed's Unit Converter is a comprehensive conversion tool covering 800+ units across 23 categories — from everyday measurements like length and temperature to specialized engineering units like viscosity, thermal conductivity, and torque. Unlike basic converters, it features animated scale visualizations, real-time formula display, batch conversion, and a keyboard-first command palette.\"}]]}],[[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-tips\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-tips\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":[\"Tips from Building \",\"the Unit Converter\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Use NIST-sourced factors for engineering work\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\",\"key\":\"1gvzjb\"}],[\"path\",{\"d\":\"M9 18h6\",\"key\":\"x1upvd\"}],[\"path\",{\"d\":\"M10 22h4\",\"key\":\"ceow96\"}]],\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Use NIST-sourced factors for engineering work\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Every conversion factor in the tool comes from NIST reference data or published engineering tables. For lab reports or design calculations, this matters — internet-scraped factors often round at the third decimal and accumulate error across multi-step conversions.\"}]]}]]}],[\"$\",\"li\",\"Switch precision based on context\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$20:props:children:2:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Switch precision based on context\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"The tool defaults to 6 significant digits but supports up to 15. Use 4–6 for everyday work; use 12–15 only when you're carrying error through a long calculation chain.\"}]]}]]}],[\"$\",\"li\",\"Batch convert when comparing a range\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$20:props:children:2:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Batch convert when comparing a range\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"When you need the same conversion across many values (10, 20, 50, 100 psi → bar), batch mode runs them all at once instead of you retyping the source value.\"}]]}]]}],[\"$\",\"li\",\"Read the formula bar — it shows the relationship\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$20:props:children:2:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Read the formula bar — it shows the relationship\"}],\"$L2b\"]}]]}]]}]]}],\"$L2c\",\"$L2d\"]]}]\n21:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0xbglb6k6reej.js\",\"async\":true,\"nonce\":\"$undefined\"}]\n22:[\"$\",\"$L2e\",null,{\"children\":[\"$\",\"$27\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@2f\"}]}]\n2b:[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"The formula display isn't decoration. It shows the actual math (e.g., bar = psi × 0.0689476) so you can verify the conversion is what you expect, or use it in a spreadsheet later.\"}]\n2c:[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-mistakes\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-mistakes\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Common Mistakes to Avoid\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Mixing absolute and gauge pressure\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\",\"key\":\"wmoenq\"}],[\"path\",{\"d\":\"M12 9v4\",\"key\":\"juzpu7\"}],[\"path\",{\"d\":\"M12 17h.01\",\"key\":\"p32p05\"}]],\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Mixing absolute and gauge pressure\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"psi and psia/psig are not interchangeable. Gauge pressure is relative to atmospheric (~14.7 psi). A conversion from \\\"psi\\\" to \\\"bar\\\" gives different answers depending on which the source meant — verify before converting.\"}]]}]]}],[\"$\",\"li\",\"Confusing kg with kgf\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2c:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Confusing kg with kgf\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Kilogram is mass; kilogram-force is a weight (mass × g). Engineering calcs often mix them up, producing answers off by ~9.81×. Pick mass units for mass and force units for force.\"}]]}]]}],[\"$\",\"li\",\"Using the wrong temperature scale offset\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2c:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Using the wrong temperature scale offset\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Celsius/Fahrenheit conversions are offsets, not ratios. 0°C ≠ 0°F. The tool handles this correctly — but if you're scripting your own conversion, the offset trips most people up.\"}]]}]]}],[\"$\",\"li\",\"Ignoring significant figures from the source\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2c:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Ignoring significant figures from the source\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Converting \\\"3 ft\\\" to \\\"914.4 mm\\\" implies 4-significant-figure precision the source didn't have. Match the output's significant figures to the input's, or your conversion overstates precision.\"}]]}]]}]]}]]}]\n2d:[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-takeaways\",\"className\":\"rounded-lg border border-brand/30 bg-brand/5 p-5\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-takeaways\",\"className\":\"text-lg font-semibold tracking-tight\",\"children\":\"Key Takeaways\"}],[\"$\",\"ul\",null,{\"className\":\"mt-3 space-y-2\",\"children\":[[\"$\",\"li\",\"The Unit Converter han