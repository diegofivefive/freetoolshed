{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/tools/layout,_N_T_/tools/unit-converter/layout,_N_T_/tools/unit-converter/page,_N_T_/tools/unit-converter"},"segmentPaths":["/_tree","/_full","/tools/unit-converter/__PAGE__","/tools/unit-converter","/tools","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable h-full\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.09zddjkbdep5a.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.09~u27dqhyhd6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/123doanyjnwwq.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/04uuf1716ltqa.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0eyplc079uusk.js\"/><script src=\"/_next/static/chunks/0tszvp5wpnn-t.js\" async=\"\"></script><script src=\"/_next/static/chunks/0bss4aof7q0cj.js\" async=\"\"></script><script src=\"/_next/static/chunks/0hi511ipeys_s.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-13rn3bqw7ype6.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zif8_3mgcc0x.js\" async=\"\"></script><script src=\"/_next/static/chunks/0zv.me6xdrdsz.js\" async=\"\"></script><script src=\"/_next/static/chunks/0ag6f0zogt0qg.js\" async=\"\"></script><script src=\"/_next/static/chunks/04p0ygcx_g620.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0_pa1c_tsbiw0.js\" async=\"\"></script><script src=\"/_next/static/chunks/10nuyoal1pib2.js\" async=