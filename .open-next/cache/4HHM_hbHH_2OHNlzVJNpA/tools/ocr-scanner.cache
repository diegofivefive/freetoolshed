\"/_next/static/chunks/10nuyoal1pib2.js\",\"/_next/static/chunks/11~hh-yuwxxvh.js\",\"/_next/static/chunks/15fv-g-ryqf4b.js\"],\"Separator\"]\n19:I[97367,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\"],\"OutletBoundary\"]\n1a:\"$Sreact.suspense\"\n2:T643,{\"@context\":\"https://schema.org\",\"@type\":\"HowTo\",\"name\":\"How to Extract Text from an Image or PDF\",\"description\":\"Run OCR on images or scanned PDFs in the browser, then export the text as TXT, DOCX, or a searchable PDF.\",\"url\":\"https://freetoolshed.com/tools/ocr-scanner\",\"step\":[{\"@type\":\"HowToStep\",\"position\":1,\"name\":\"1. Upload your file\",\"text\":\"Drag and drop an image or scanned PDF onto the upload area, or click to browse. You can add multiple files at once — images and PDFs can be mixed. Each PDF page is automatically rendered as an image for OCR processing.\"},{\"@type\":\"HowToStep\",\"position\":2,\"name\":\"2. Choose your language\",\"text\":\"Select the OCR language from the dropdown in the toolbar. The default is English, but you can switch to any of the 15+ supported languages including French, German, Spanish, Chinese, Japanese, Arabic, and Hindi. The OCR engine reinitializes automatically when you change languages.\"},{\"@type\":\"HowToStep\",\"position\":3,\"name\":\"3. Review and edit the text\",\"text\":\"Once processing completes, the extracted text appears in the right panel. The text is fully editable — fix any OCR errors, remove headers or footers, or reformat the content. Word and character counts update as you type.\"},{\"@type\":\"HowToStep\",\"position\":4,\"name\":\"4. Export the result\",\"text\":\"Choose your export format: Plain Text (.txt) for simple text, Word Document (.docx) for formatted output with page separators, or Searchable PDF to create a PDF with your original scan plus an invisible text layer for search and selection. Click Download or use Copy Text for the clipboard.\"}]}3:T895,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Is this OCR tool really free?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, completely free. No hidden fees, no premium tiers, and no sign-up required. The tool is ad-supported so it can remain free for everyone.\"}},{\"@type\":\"Question\",\"name\":\"How do I extract text from an image?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Drop your image (PNG, JPG, TIFF, BMP, or WebP) onto the editor. OCR runs automatically in your browser and displays the extracted text in seconds. You can then copy it or export as .txt, .docx, or searchable PDF.\"}},{\"@type\":\"Question\",\"name\":\"Can I extract text from a scanned PDF?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Drop a scanned PDF and each page is rendered and processed with OCR. Multi-page PDFs are fully supported with sequential page processing.\"}},{\"@type\":\"Question\",\"name\":\"What languages are supported?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Over 15 languages including English, Spanish, French, German, Italian, Portuguese, Dutch, Polish, Russian, Japanese, Korean, Chinese (Simplified and Traditional), Arabic, and Hindi.\"}},{\"@type\":\"Question\",\"name\":\"Is my data private?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. All OCR processing happens locally in your browser using WebAssembly. Your images and PDFs are never uploaded to any server.\"}},{\"@type\":\"Question\",\"name\":\"What export formats are available?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Export extracted text as plain text (.txt), Word document (.docx), or searchable PDF with an invisible text layer over the original scan.\"}},{\"@type\":\"Question\",\"name\":\"Do I need to install anything?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. The OCR engine runs entirely in your browser via WebAssembly. No desktop app, no plugins, no extensions. Open the page and start scanning.\"}},{\"@type\":\"Question\",\"name\":\"How accurate is the OCR?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Accuracy depends on image quality. Clean, high-resolution scans (300+ DPI) typically achieve 95%+ accuracy. The tool shows a confidence score for each processed page so you can verify results.\"}}]}0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"SoftwareApplication\\\",\\\"name\\\":\\\"Free OCR Scanner\\\",\\\"description\\\":\\\"Extract text from images and scanned PDFs using OCR. Supports 15+ languages with instant export to .txt, .docx, and searchable PDF.\\\",\\\"url\\\":\\\"https://freetoolshed.com/tools/ocr-scanner\\\",\\\"applicationCategory\\\":\\\"UtilitiesApplication\\\",\\\"operatingSystem\\\":\\\"Web\\\",\\\"offers\\\":{\\\"@type\\\":\\\"Offer\\\",\\\"price\\\":\\\"0\\\",\\\"priceCurrency\\\":\\\"USD\\\"}}\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$2\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$3\"}}],\"$L4\",\"$L5\",\"$L6\",\"$L7\",\"$L8\",\"$L9\",\"$La\",\"$Lb\",\"$Lc\"],[\"$Ld\"],\"$Le\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"4HHM_hbHH_2OHNlzVJNpA\"}\n4:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://freetoolshed.com/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"OCR Scanner\\\"}]}\"}}],[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"mb-4\",\"children\":[\"$\",\"ol\",null,{\"className\":\"flex items-center gap-1 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",\"0\",{\"className\":\"flex items-center gap-1\",\"children\":[false,[\"$\",\"$Lf\",null,{\"href\":\"/\",\"className\":\"transition-colors hover:text-foreground\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"1\",{\"className\":\"flex items-center gap-1\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":[[\"path\",{\"d\":\"m9 18 6-6-6-6\",\"key\":\"mthhwq\"}]],\"className\":\"lucide-chevron-right size-3.5 shrink-0\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground\",\"children\":\"OCR Scanner\"}]]}]]}]}]]\n5:[\"$\",\"h1\",null,{\"className\":\"text-3xl font-bold tracking-tight\",\"children\":\"Free OCR Scanner — Image & PDF to Text\"}]\n6:[\"$\",\"p\",null,{\"className\":\"mt-2 text-lg text-muted-foreground\",\"children\":\"Extract text from images and scanned PDFs instantly — a free alternative to Adobe Acrobat OCR and ABBYY FineReader. No sign-up required.\"}]\n7:[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"Person\\\",\\\"name\\\":\\\"James Nicolaus\\\",\\\"jobTitle\\\":\\\"Builder & Maintainer, Free Tool Shed\\\",\\\"description\\\":\\\"James Nicolaus builds and maintains every tool on Free Tool Shed. Each tool is designed, tested in real browsers across desktop and mobile, and shipped only after handling the messy edge cases — large files, slow connections, unusual inputs — that paid alternatives often hide behind sign-up walls.\\\",\\\"url\\\":\\\"https://freetoolshed.com/about\\\",\\\"worksFor\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"Free Tool Shed\\\",\\\"url\\\":\\\"https://freetoolshed.com\\\"}}\"}}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-xs text-muted-foreground\",\"children\":[\"Built and maintained by\",\" \",[\"$\",\"$Lf\",null,{\"href\":\"/about\",\"className\":\"font-medium text-foreground underline-offset-4 hover:underline\",\"rel\":\"author\",\"children\":\"James Nicolaus\"}],\"$undefined\"]}]]\n8:[\"$\",\"section\",null,{\"aria-label\":\"Summary\",\"className\":\"mt-6 rounded-lg border border-brand/30 bg-brand/5 p-4\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm leading-relaxed text-foreground\",\"children\":\"Free Tool Shed's OCR Scanner extracts text from images and scanned PDFs locally in your browser using Tesseract — no upload, no sign-up. Supports 15+ languages, multi-page PDFs, and exports to plain text, .docx, or a searchable PDF that preserves the original page layout. A free alternative to Adobe Acrobat OCR and ABBYY FineReader.\"}]}]\n9:[\"$\",\"div\",null,{\"className\":\"mt-6 grid gap-4 sm:grid-cols-2\",\"children\":[[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Instant Text Extraction\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Drop an image or scanned PDF, get editable text in seconds. Powered by tesseract.js OCR running entirely in your browser.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"15+ Languages Supported\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"English, Spanish, French, German, Chinese, Japanese, Arabic, and more. Switch languages with one click.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Multiple Export Formats\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Copy text, download as .txt or .docx, or create a searchable PDF with an invisible text layer over your original scan.\"}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"100% Private, No Upload\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"All OCR processing happens in your browser using WebAssembly. Your files never leave your device.\"}]]}]]}]\na:[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L11\",null,{}]}]\nb:[\"$\",\"div\",null,{\"className\":\"my-8 flex justify-center\",\"children\":[\"$\",\"$L12\",null,{\"slot\":\"mid-content\"}]}]\nc:[\"$\",\"div\",null,{\"className\":\"mt-16 space-y-12\",\"children\":[[\"$\",\"$L13\",null,{}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold\",\"children\":\"Free OCR — Extract Text from Images & Scanned PDFs\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Scanned documents, photos of receipts, screenshots with text — they all contain information you can't copy-paste. Until now, extracting that text meant paying for Adobe Acrobat ($22.99/month) or ABBYY FineReader ($199 one-time). Free Tool Shed's OCR Scanner does the same thing for free, right in your browser. Drop a file, get editable text in seconds. No account, no install, no upload to a server.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"The tool uses tesseract.js — the same Tesseract OCR engine that powers Google's document scanning — compiled to WebAssembly so it runs entirely on your machine. Your files never leave your device. It supports 15+ languages, handles multi-page PDFs, and exports to plain text, Word documents, or searchable PDFs with an invisible text layer over your original scan.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Features\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid gap-x-8 gap-y-2 text-sm text-muted-foreground sm:grid-cols-2\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Drag-and-drop image upload (PNG, JPG, TIFF, BMP, WebP)\"}],[\"$\",\"li\",null,{\"children\":\"Scanned PDF support — each page rendered and OCR'd\"}],[\"$\",\"li\",null,{\"children\":\"15+ OCR languages (English, French, German, Spanish, and more)\"}],[\"$\",\"li\",null,{\"children\":\"Batch processing — add multiple files at once\"}],[\"$\",\"li\",null,{\"children\":\"Real-time progress tracking per page\"}],[\"$\",\"li\",null,{\"children\":\"Confidence score for each recognized page\"}],[\"$\",\"li\",null,{\"children\":\"Editable text output — fix errors before exporting\"}],[\"$\",\"li\",null,{\"children\":\"Word and character count in real time\"}],[\"$\",\"li\",null,{\"children\":\"Export as plain text (.txt)\"}],[\"$\",\"li\",null,{\"children\":\"Export as Word document (.docx) with page separators\"}],[\"$\",\"li\",null,{\"children\":\"Export as searchable PDF with invisible text overlay\"}],[\"$\",\"li\",null,{\"children\":\"Copy extracted text to clipboard\"}],[\"$\",\"li\",null,{\"children\":\"Re-OCR all pages with a different language\"}],[\"$\",\"li\",null,{\"children\":\"File thumbnails with per-page status indicators\"}],[\"$\",\"li\",null,{\"children\":\"Language and export format preferences saved across sessions\"}],[\"$\",\"li\",null,{\"children\":\"Max 50 MB per file, up to 50 PDF pages\"}],[\"$\",\"li\",null,{\"children\":\"100% client-side — files never leave your browser\"}],[\"$\",\"li\",null,{\"children\":\"Powered by tesseract.js WebAssembly engine\"}]]}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"How to Extract Text from an Image or PDF (4 Steps)\"}],[\"$\",\"ol\",null,{\"className\":\"mt-4 space-y-4\",\"children\":[[\"$\",\"li\",\"1. Upload your file\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"1. Upload your file\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Drag and drop an image or scanned PDF onto the upload area, or click to browse. You can add multiple files at once — images and PDFs can be mixed. Each PDF page is automatically rendered as an image for OCR processing.\"}]]}],[\"$\",\"li\",\"2. Choose your language\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"2. Choose your language\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Select the OCR language from the dropdown in the toolbar. The default is English, but you can switch to any of the 15+ supported languages including French, German, Spanish, Chinese, Japanese, Arabic, and Hindi. The OCR engine reinitializes automatically when you change languages.\"}]]}],\"$L14\",\"$L15\"]}]]}],\"$L16\",\"$L17\",\"$L18\"]}]\nd:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/15fv-g-ryqf4b.js\",\"async\":true}]\ne:[\"$\",\"$L19\",null,{\"children\":[\"$\",\"$1a\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@1b\"}]}]\n14:[\"$\",\"li\",\"3. Review and edit the text\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"3. Review and edit the text\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Once processing completes, the extracted text appears in the right panel. The text is fully editable — fix any OCR errors, remove headers or footers, or reformat the content. Word and character counts update as you type.\"}]]}]\n15:[\"$\",\"li\",\"4. Export the result\",{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-medium\",\"children\":\"4. Export the result\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Choose your export format: Plain Text (.txt) for simple text, Word Document (.docx) for formatted output with page separators, or Searchable PDF to create a PDF with your original scan plus an invisible text layer for search and selection. Click Download or use Copy Text for the clipboard.\"}]]}]\n16:[[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-tips\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-tips\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":[\"Tips from Building \",\"the OCR Scanner\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3 max-w-3xl text-muted-foreground\",\"children\":\"Notes from designing and testing this tool — what we kept in mind, the edge cases we worked around, and the small choices that make the difference between a tool that ships and one that breaks on real input.\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Higher resolution beats fancier post-processing\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":[[\"path\",{\"d\":\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\",\"key\":\"1gvzjb\"}],[\"path\",{\"d\":\"M9 18h6\",\"key\":\"x1upvd\"}],[\"path\",{\"d\":\"M10 22h4\",\"key\":\"ceow96\"}]],\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Higher resolution beats fancier post-processing\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"OCR accuracy scales directly with input resolution up to about 300 DPI. A clean 300-DPI scan outperforms a heavily-processed 150-DPI scan every time. Re-scan rather than upscale.\"}]]}]]}],[\"$\",\"li\",\"Pick the right language pack\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":\"$16:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Pick the right language pack\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Tesseract loads a separate model per language. The English model can't read German umlauts or Cyrillic characters. Select the language(s) actually present in the document before scanning.\"}]]}]]}],[\"$\",\"li\",\"Use searchable PDF for archives, .txt for editing\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":\"$16:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Use searchable PDF for archives, .txt for editing\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Searchable PDFs preserve the original page layout with a text layer underneath — great for archives. Plain .txt strips all formatting and is better when you'll re-flow the text in another editor.\"}]]}]]}],[\"$\",\"li\",\"Pre-crop pages before scanning\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":\"$16:0:props:children:2:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-lightbulb mt-0.5 size-5 shrink-0 text-brand\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Pre-crop pages before scanning\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"OCR runs on the whole image, including borders, page numbers, and printer marks. Cropping to just the body text speeds up processing and reduces false matches on edge artifacts.\"}]]}]]}]]}]]}],[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-mistakes\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-mistakes\",\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Common Mistakes to Avoid\"}],[\"$\",\"ul\",null,{\"className\":\"mt-4 grid max-w-3xl gap-3\",\"children\":[[\"$\",\"li\",\"Scanning at 96 DPI from a screenshot\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L10\",null,{\"iconNode\":[[\"path\",{\"d\":\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\",\"key\":\"wmoenq\"}],[\"path\",{\"d\":\"M12 9v4\",\"key\":\"juzpu7\"}],[\"path\",{\"d\":\"M12 17h.01\",\"key\":\"p32p05\"}]],\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],\"$L1c\"]}],\"$L1d\",\"$L1e\",\"$L1f\"]}]]}],\"$L20\"]\n17:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Free Adobe Acrobat OCR Alternative\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 overflow-x-auto\",\"children\":[\"$\",\"table\",null,{\"className\":\"w-full min-w-[600px] border-collapse text-sm\",\"children\":[[\"$\",\"thead\",null,{\"children\":[\"$\",\"tr\",null,{\"className\":\"border-b border-border text-left\",\"children\":[[\"$\",\"th\",null,{\"className\":\"py-2 pr-4 font-semibold\",\"children\":\"Feature\"}],[\"$\",\"th\",null,{\"className\":\"py-2 pr-4 font-semibold\",\"children\":\"Free Tool Shed\"}],[\"$\",\"th\",null,{\"className\":\"py-2 pr-4 font-semibold\",\"children\":\"Adobe Acrobat\"}],[\"$\",\"th\",null,{\"className\":\"py-2 pr-4 font-semibold\",\"children\":\"ABBYY FineReader\"}],[\"$\",\"th\",null,{\"className\":\"py-2 font-semibold\",\"children\":\"Google Drive OCR\"}]]}]}],[\"$\",\"tbody\",null,{\"className\":\"text-muted-foreground\",\"children\":[[\"$\",\"tr\