 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"Yes (Google)\"}]]}],[\"$\",\"tr\",\"Image OCR\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Image OCR\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Yes\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"Yes\"}]]}],[\"$\",\"tr\",\"PDF OCR\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"PDF OCR\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Yes\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"Yes (Google Docs)\"}]]}],[\"$\",\"tr\",\"Languages\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Languages\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"15+\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"20+\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"200+\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"200+\"}]]}],[\"$\",\"tr\",\"Batch Processing\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Batch Processing\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Yes\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"No\"}]]}],[\"$\",\"tr\",\"Searchable PDF Export\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Searchable PDF Export\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Yes\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"No\"}]]}],[\"$\",\"tr\",\"Word (.docx) Export\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Word (.docx) Export\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Yes\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],\"$L38\",\"$L39\"]}],\"$L3a\",\"$L3b\",\"$L3c\",\"$L3d\",\"$L3e\"]}]]}]}]]}]\n30:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Frequently Asked Questions\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 space-y-3\",\"children\":[[\"$\",\"details\",\"Is this OCR tool really free?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Is this OCR tool really free?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes, completely free. No hidden fees, no premium tiers, and no sign-up required. The tool is ad-supported so it can remain free for everyone.\"}]]}],[\"$\",\"details\",\"Do my files get uploaded to a server?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Do my files get uploaded to a server?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"No. All OCR processing runs locally in your browser using WebAssembly (tesseract.js). Your images and PDFs never leave your device. There is no server-side component — the page works even offline once loaded.\"}]]}],[\"$\",\"details\",\"How accurate is the OCR?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"How accurate is the OCR?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"For clean scans and printed text, expect 90–99% accuracy depending on font quality, resolution, and contrast. Handwritten text, heavily skewed images, or very low-resolution scans may produce lower accuracy. Higher-resolution input images (300 DPI+) give the best results.\"}]]}],[\"$\",\"details\",\"What languages are supported?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"What languages are supported?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"15+ languages: English, French, German, Spanish, Italian, Portuguese, Dutch, Polish, Russian, Japanese, Korean, Chinese (Simplified and Traditional), Arabic, and Hindi. Select the language from the toolbar dropdown before processing.\"}]]}],[\"$\",\"details\",\"Can I OCR a multi-page PDF?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Can I OCR a multi-page PDF?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. Drop a PDF file and each page is automatically rendered as an image and OCR'd individually. The tool supports up to 50 pages per PDF. All page text is combined with page separators in the output.\"}]]}],[\"$\",\"details\",\"What is a searchable PDF?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"What is a searchable PDF?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"A searchable PDF contains your original scanned image with an invisible text layer placed on top. This means the PDF looks exactly like the original scan, but you can select, search, and copy text from it. It's the standard output format of professional OCR software.\"}]]}],[\"$\",\"details\",\"How do I get the best OCR results?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"How do I get the best OCR results?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Use high-resolution scans (300 DPI or higher), ensure the text is not skewed or rotated, and use good contrast (dark text on light background). For photos, make sure the text is in focus and evenly lit. Select the correct language before processing.\"}]]}],\"$L3f\",\"$L40\",\"$L41\"]}]]}]\n33:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Scanning at 96 DPI from a screenshot\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Screenshots of text are usually 72–96 DPI, far below OCR's accuracy threshold. Capture at higher resolution or rescan the original document.\"}]]}]\n34:[\"$\",\"li\",\"Mixing multiple languages in one pass\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2e:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Mixing multiple languages in one pass\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Running an English-only model over a bilingual page drops the non-English text entirely. Either select both languages or process pages separately.\"}]]}]]}]\n35:[\"$\",\"li\",\"Trusting OCR on handwriting or stylized fonts\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2e:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Trusting OCR on handwriting or stylized fonts\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"Tesseract is trained for print fonts. Cursive handwriting, decorative scripts, and heavy stylization produce unreliable output. For handwriting, expect manual cleanup.\"}]]}]]}]\n36:[\"$\",\"li\",\"Skipping page rotation\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$2e:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Skipping page rotation\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"A landscape page scanned in portrait orientation will OCR as gibberish. Rotate before scanning, or use a scanner setting that auto-orients.\"}]]}]]}]\n37:[\"$\",\"section\",null,{\"aria-labelledby\":\"tool-insights-takeaways\",\"className\":\"rounded-lg border border-brand/30 bg-brand/5 p-5\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"tool-insights-takeaways\",\"className\":\"text-lg font-semibold tracking-tight\",\"children\":\"Key Takeaways\"}],[\"$\",\"ul\",null,{\"className\":\"mt-3 space-y-2\",\"children\":[[\"$\",\"li\",\"The OCR Scanner runs Tesseract locally in your browser — images and PDFs never upload.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"circle\",{\"cx\":\"12\",\"cy\":\"12\",\"r\":\"10\",\"key\":\"1mglay\"}],[\"path\",{\"d\":\"m9 12 2 2 4-4\",\"key\":\"dzmm74\"}]],\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"The OCR Scanner runs Tesseract locally in your browser — images and PDFs never upload.\"}]]}],[\"$\",\"li\",\"It supports 15+ languages, multi-page PDFs, and exports to .txt, .docx, or a searchable PDF.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$37:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"It supports 15+ languages, multi-page PDFs, and exports to .txt, .docx, or a searchable PDF.\"}]]}],[\"$\",\"li\",\"Accuracy depends heavily on input quality: 300 DPI clean scans, correct language pack, correct orientation.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$37:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"Accuracy depends heavily on input quality: 300 DPI clean scans, correct language pack, correct orientation.\"}]]}],[\"$\",\"li\",\"It is a free alternative to Adobe Acrobat OCR and ABBYY FineReader for routine document scanning.\",{\"className\":\"flex items-start gap-2\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$37:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-circle-check mt-0.5 size-4 shrink-0 text-brand\"}],[\"$\",\"span\",null,{\"className\":\"text-sm text-foreground\",\"children\":\"It is a free alternative to Adobe Acrobat OCR and ABBYY FineReader for routine document scanning.\"}]]}]]}]]}]\n38:[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}]\n39:[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"Yes\"}]\n3a:[\"$\",\"tr\",\"Editable Output\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Editable Output\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Yes\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Limited\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"Yes (in Docs)\"}]]}]\n3b:[\"$\",\"tr\",\"Handwriting Recognition\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Handwriting Recognition\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Basic\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Advanced\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Advanced\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"Basic\"}]]}]\n3c:[\"$\",\"tr\",\"Table Recognition\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Table Recognition\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"No\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Advanced\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"Basic\"}]]}]\n3d:[\"$\",\"tr\",\"Data Privacy\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Data Privacy\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Client-side only\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Cloud upload\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Local\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"Cloud upload\"}]]}]\n3e:[\"$\",\"tr\",\"Offline Support\",{\"className\":\"border-b border-border/50\",\"children\":[[\"$\",\"td\",\"0\",{\"className\":\"py-2 pr-4 \",\"children\":\"Offline Support\"}],[\"$\",\"td\",\"1\",{\"className\":\"py-2 pr-4 font-medium text-foreground\",\"children\":\"Yes (after load)\"}],[\"$\",\"td\",\"2\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"3\",{\"className\":\"py-2 pr-4 \",\"children\":\"Yes\"}],[\"$\",\"td\",\"4\",{\"className\":\"py-2  \",\"children\":\"No\"}]]}]\n3f:[\"$\",\"details\",\"Can I edit the extracted text?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium\",\"children\":\"Can I edit the extracted text?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. The text output panel is fully editable. Fix any OCR errors, remove unwanted headers or footers, or reformat the content before exporting. Word and character counts update in real time as you type.\"}]]}]\n40:[\"$\",\"details\",\"Why use this instead of Adobe Acrobat?\",{\"className\":\"group rounded-lg b