04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\"],\"OutletBoundary\"]\n20:\"$Sreact.suspense\"\n2:T47a,{\"@context\":\"https://schema.org\",\"@type\":\"HowTo\",\"name\":\"How to Create a Professional Invoice\",\"description\":\"Create a print-ready PDF invoice with line items, tax, and template customization, then download or save it locally.\",\"url\":\"https://freetoolshed.com/tools/invoice-generator\",\"step\":[{\"@type\":\"HowToStep\",\"position\":1,\"name\":\"Enter your business details\",\"text\":\"Add your company name, address, email, and optionally upload your logo.\"},{\"@type\":\"HowToStep\",\"position\":2,\"name\":\"Add your client information\",\"text\":\"Fill in the client name, email, and billing address.\"},{\"@type\":\"HowToStep\",\"position\":3,\"name\":\"Add line items\",\"text\":\"Enter each product or service with a description, quantity, unit type, and unit price. Enable per-item taxes if needed.\"},{\"@type\":\"HowToStep\",\"position\":4,\"name\":\"Choose a template and customize\",\"text\":\"Pick from Modern, Classic, or Compact templates. Set your brand accent color, date format, and invoice status.\"},{\"@type\":\"HowToStep\",\"position\":5,\"name\":\"Download or save your invoice\",\"text\":\"Download a print-ready PDF, save to your invoice history for later, or export as JSON for backup.\"}]}3:T914,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Is this invoice generator really free?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, completely free. No hidden fees, no premium tiers, and no sign-up required. The tool is ad-supported so it can remain free for everyone.\"}},{\"@type\":\"Question\",\"name\":\"Do I need to create an account?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. You can start creating invoices immediately without signing up or providing any personal information.\"}},{\"@type\":\"Question\",\"name\":\"Is my data private and secure?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Your invoice data never leaves your browser. All processing happens client-side on your device, so your business information stays completely private.\"}},{\"@type\":\"Question\",\"name\":\"What invoice templates are available?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Three professional templates are included: Modern (clean and minimal), Classic (traditional business style), and Compact (dense layout for invoices with many line items).\"}},{\"@type\":\"Question\",\"name\":\"Can I add my company logo?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Upload your company logo in PNG, JPEG, or SVG format and it will appear on your invoice and PDF export.\"}},{\"@type\":\"Question\",\"name\":\"What currencies are supported?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"20 major currencies are supported including USD, EUR, GBP, CAD, AUD, JPY, CHF, INR, and more. Currency symbols and decimal formatting are handled automatically.\"}},{\"@type\":\"Question\",\"name\":\"Can I save my invoices?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Your current draft auto-saves as you type. You can also save invoices to your history for later access, duplicate them, or export all invoices as JSON for backup.\"}},{\"@type\":\"Question\",\"name\":\"Can I track invoice status?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Mark each invoice as Draft, Sent, Paid, or Overdue. The status appears as a watermark on the PDF and in your invoice history.\"}},{\"@type\":\"Question\",\"name\":\"How do I print my invoice?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Click the Print button to open your browser's print dialog, or download the PDF and print from your PDF viewer. Both options produce professional, print-ready output.\"}}]}0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"scri