2 text-sm text-muted-foreground\",\"children\":\"No. You can start creating invoices immediately without signing up or providing any personal information.\"}]]}],[\"$\",\"details\",\"Is my data private and secure?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Is my data private and secure?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Your invoice data never leaves your browser. All processing happens client-side on your device, so your business information stays completely private.\"}]]}],[\"$\",\"details\",\"What invoice templates are available?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"What invoice templates are available?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Three professional templates are included: Modern (clean and minimal), Classic (traditional business style), and Compact (dense layout for invoices with many line items).\"}]]}],[\"$\",\"details\",\"Can I add my company logo?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Can I add my company logo?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. Upload your company logo in PNG, JPEG, or SVG format and it will appear on your invoice and PDF export.\"}]]}],[\"$\",\"details\",\"What currencies are supported?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"What currencies are supported?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"20 major currencies are supported including USD, EUR, GBP, CAD, AUD, JPY, CHF, INR, and more. Currency symbols and decimal formatting are handled automatically.\"}]]}],[\"$\",\"details\",\"Can I save my invoices?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Can I save my invoices?\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":\"Yes. Your current draft auto-saves as you type. You can also save invoices to your history for later access, duplicate them, or export all invoices as JSON for backup.\"}]]}],[\"$\",\"details\",\"Can I track invoice status?\",{\"className\":\"group rounded-lg border border-border px-4 py-3\",\"children\":[[\"$\",\"summary\",null,{\"className\":\"cursor-pointer font-medium marker:text-brand\",\"children\":\"Can I track invoice status?\"}],\"$L48\"]}],\"$L49\"]}]]}]\n39:[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Forgetting payment terms\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-muted-foreground\",\"children\":\"An invoice without explicit terms (Net 15, Net 30, etc.) defaults to vague expectations. Pick a term so the client knows when payment is due and you can mark it Overdue accurately.\"}]]}]\n3a:[\"$\",\"li\",\"Using the wrong date format for the client's country\",{\"className\":\"flex gap-3 rounded-lg border border-border bg-card p-4\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$34:1:props:children:1:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-triangle-alert mt-0.5 size-5 shrink-0 text-pink-500\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-sm font-semibold\",\"children\":\"Using the wrong date format for the client's country\"