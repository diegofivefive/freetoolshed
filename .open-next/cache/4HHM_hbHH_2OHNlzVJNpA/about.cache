https://schema.org\\\",\\\"@type\\\":\\\"AboutPage\\\",\\\"name\\\":\\\"About Free Tool Shed\\\",\\\"url\\\":\\\"https://freetoolshed.com/about\\\",\\\"mainEntity\\\":{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"Person\\\",\\\"name\\\":\\\"James Nicolaus\\\",\\\"jobTitle\\\":\\\"Builder & Maintainer, Free Tool Shed\\\",\\\"description\\\":\\\"James Nicolaus builds and maintains every tool on Free Tool Shed. Each tool is designed, tested in real browsers across desktop and mobile, and shipped only after handling the messy edge cases — large files, slow connections, unusual inputs — that paid alternatives often hide behind sign-up walls.\\\",\\\"url\\\":\\\"https://freetoolshed.com/about\\\",\\\"worksFor\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"Free Tool Shed\\\",\\\"url\\\":\\\"https://freetoolshed.com\\\"}}}\"}}],[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://freetoolshed.com/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"About\\\"}]}\"}}],[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"mb-4\",\"children\":[\"$\",\"ol\",null,{\"className\":\"flex items-center gap-1 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",\"0\",{\"className\":\"flex items-center gap-1\",\"children\":[false,[\"$\",\"$L4\",null,{\"href\":\"/\",\"className\":\"transition-colors hover:text-foreground\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"1\",{\"className\":\"flex items-center gap-1\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"m9 18 6-6-6-6\",\"key\":\"mthhwq\"}]],\"className\":\"lucide-chevron-right size-3.5 shrink-0\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground\",\"children\":\"About\"}]]}]]}]}]],[\"$\",\"h1\",null,{\"className\":\"text-3xl font-bold tracking-tight\",\"children\":\"About Free Tool Shed\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-lg text-muted-foreground\",\"children\":\"Free Tool Shed is a growing collection of free, browser-based tools that replace paid software. No sign-up, no downloads, no email harvesting — just open a tool and use it.\"}],[\"$\",\"$L15\",null,{\"className\":\"my-8\"}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"Why this site exists\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-muted-foreground\",\"children\":\"Most everyday digital tasks — generating an invoice, building a resume, merging audio chapters, converting a video, running OCR on a scan — are gated behind subscriptions, mandatory accounts, or seven-day free trials that quietly auto-renew. The tools themselves are not expensive to build. The paywall exists because the alternatives were inconvenient, not because the work behind the tool justified $19, $30, or $49 a month.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-muted-foreground\",\"children\":\"Free Tool Shed exists to make that paywall optional. Every tool on this site does the same job as a paid SaaS equivalent, lives at a permanent URL, and stays free forever. Ads keep the lights on. Your data stays on your device.\"}]]}],\"$L16\",\"$L17\",\"$L18\",\"$L19\",\"$L1a\",\"$L1b\",\"$L1c\",\"$L1d\"]}],[\"$L1e\"],\"$L1f\"]}]\n20:[]\nf:\"$W20\"\n10:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L21\",null,{\"children\":\"$L22\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L23\",null,{\"children\":[\"$\",\"$24\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L25\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n12:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/123doanyjnwwq.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n13:[\"$\",\"link\",\"1\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/04uuf1716ltqa.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n28:I[97367,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\"],\"OutletBoundary\"]\n16:[\"$\",\"$L15\",null,{\"className\":\"my-8\"}]\n17:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-2xl font-semibold tracking-tight\",\"children\":\"How the tools work\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 text-muted-foreground\",\"children\":\"Every tool on Free Tool Shed is a standalone web application that runs entirely in your browser. When you create an invoice, build a resume, merge an audiobook, or run OCR on a document, the processing happens on your machine using modern web technologies — WebAssembly for the heavy tools (ffmpeg.wasm, Tesseract.js), the Web Audio API, the Canvas API, and the browser's built-in PDF and media stack.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 text-muted-foreground\",\"children\":\"Nothing is uploaded. There are no servers that hold your files. Your work auto-saves to your browser's local storage so you can come back later, and when you export, the finished file goes straight to your device's download folder.\"}],[\"$\",\"div\",null,{\"className\":\"mt-6 grid gap-4 sm:grid-cols-2\",\"children\":[[\"$\",\"div\",null,{\"data-slot\":\"card\",\"data-size\":\"default\",\"className\":\"group/card flex-col overflow-hidden rounded-xl bg-card text-sm text-card-foreground ring-1 ring-foreground/10 has-data-[slot=card-footer]:pb-0 has-[>img:first-child]:pt-0 data-[size=sm]:gap-3 data-[size=sm]:py-3 data-[size=sm]:has-data-[slot=card-footer]:pb-0 *:[img: