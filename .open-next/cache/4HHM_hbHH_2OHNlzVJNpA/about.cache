t, lives at a permanent URL, and stays free forever. Ads keep the lights on. Your data stays on your device.\\\"}]]}],\\\"$L16\\\",\\\"$L17\\\",\\\"$L18\\\",\\\"$L19\\\",\\\"$L1a\\\",\\\"$L1b\\\",\\\"$L1c\\\",\\\"$L1d\\\"]}],[\\\"$L1e\\\"],\\\"$L1f\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"20:[]\\nf:\\\"$W20\\\"\\n10:[\\\"$\\\",\\\"$1\\\",\\\"h\\\",{\\\"children\\\":[null,[\\\"$\\\",\\\"$L21\\\",null,{\\\"children\\\":\\\"$L22\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"hidden\\\":true,\\\"children\\\":[\\\"$\\\",\\\"$L23\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"$24\\\",null,{\\\"name\\\":\\\"Next.Metadata\\\",\\\"children\\\":\\\"$L25\\\"}]}]}],[\\\"$\\\",\\\"meta\\\",null,{\\\"name\\\":\\\"next-size-adjust\\\",\\\"content\\\":\\\"\\\"}]]}]\\n12:[\\\"$\\\",\\\"link\\\",\\\"0\\\",{\\\"rel\\\":\\\"stylesheet\\\",\\\"href\\\":\\\"/_next/static/chunks/123doanyjnwwq.css\\\",\\\"precedence\\\":\\\"next\\\",\\\"crossOrigin\\\":\\\"$undefined\\\",\\\"nonce\\\":\\\"$undefined\\\"}]\\n13:[\\\"$\\\",\\\"link\\\",\\\"1\\\",{\\\"rel\\\":\\\"stylesheet\\\",\\\"href\\\":\\\"/_next/static/chunks/04uuf1716ltqa.css\\\",\\\"precedence\\\":\\\"next\\\",\\\"crossOrigin\\\":\\\"$undefined\\\",\\\"nonce\\\":\\\"$undefined\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"28:I[97367,[\\\"/_next/static/chunks/0zif8_3mgcc0x.js\\\",\\\"/_next/static/chunks/0zv.me6xdrdsz.js\\\",\\\"/_next/static/chunks/0ag6f0zogt0qg.js\\\",\\\"/_next/static/chunks/04p0ygcx_g620.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\",\\\"/_next/static/chunks/0_pa1c_tsbiw0.js\\\",\\\"/_next/static/chunks/10nuyoal1pib2.js\\\"],\\\"OutletBoundary\\\"]\\n16:[\\\"$\\\",\\\"$L15\\\",null,{\\\"className\\\":\\\"my-8\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"17:[\\\"$\\\",\\\"section\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-2xl font-semibold tracking-tight\\\",\\\"children\\\":\\\"How the tools work\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"mt-4 text-muted-foreground\\\",\\\"children\\\":\\\"Every tool on Free Tool Shed is a standalone web application that runs entirely in your browser. When you create an invoice, build a resume, merge an audiobook, or run OCR on a document, the processing happens on your machine using modern web technologies — WebAssembly for the heavy tools (ffmpeg.wasm, Tesseract.js), the Web Audio API, the Canvas API, and the browser's built-in PDF and media stack.\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"mt-3 text-muted-foreground\\\",\\\"children\\\":\\\"Nothing is uploaded. There are no servers that hold your files. Your work auto-saves to your browser's local storage so you can come back later, and when you export, the finished file goes straight to your device's download folder.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-6 grid gap-4 sm:grid-cols-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"data-slot\\\":\\\"card\\\",\\\"data-size\\\":\\\"default\\\",\\\"className\\\":\\\"group/card flex-col overflow-hidden rounded-xl bg-card text-sm text-card-foreground ring-1 ring-foreground/10 has-data-[slot=card-footer]:pb-0 has-[\\u003eimg:first-child]:pt-0 data-[size=sm]:gap-3 data-[size=sm]:py-3 data-[size=sm]:has-data-[slot=card-footer]:pb-0 *:[img:first-child]:rounded-t-xl *:[img:last-child]:rounded-b-xl flex gap-3 p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L5\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"iconNode\\\":[[\\\"line\\\",{\\\"x1\\\":\\\"12\\\",\\\"x2\\\":\\\"12\\\",\\\"y1\\\":\\\"2\\\",\\\"y2\\\":\\\"22\\\",\\\"key\\\":\\\"7eqyqh\\\"}],[\\\"path\\\",{\\\"d\\\":\\\"M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6\\\",\\\"key\\\":\\\"1b0p4s\\\"}]],\\\"className\\\":\\\"lucide-dollar-sign mt-0.5 size-5 shrink-0 text-brand\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-semibold\\\",\\\"children\\\":\\\"Free, forever\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"mt-1 text-sm text-muted-foreground\\\",\\\"children\\\":\\\"No subscriptions, no freemium tiers, no \\\\\\\"free trial\\\\\\\" that expires. Ad-supported so the tools stay free for everyone.\\\"}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"data-slot\\\":\\\"card\\\",\\\"data-size\\\":\\\"default\\\",\\\"className\\\":\\\"group/card flex-col overflow-hidden rounded-xl bg-card text-sm text-card-foreground ring-1 ring-foreground/10 has-data-[slot=card-footer]:pb-0 has-[\\u003eimg:first-child]:pt-0 data-[size=sm]:gap-3 data-[size=sm]:py-3 data-[size=sm]:has-data-[slot=card-footer]:pb-0 *:[img:first-child]:rounded-t-xl *:[img:last-child]:rounded-b-xl flex gap-3 p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L5\\\",null,{\\\"ref\\\":\\\"$undefined\\\",\\\"iconNode\\\":[[\\\"path\\\",{\\\"d\\\":\\\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\\\",\\\"key\\\":\\\"oel41y\\\"}]],\\\"className\\\":\\\"lucide-shield mt-0.5 size-5 shrink-0 text-brand\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-sm font-semibold\\\",\\\"children\\\":\\\"Private by design\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"mt-1 text-sm text-muted-foreground\\\",\\\"children\\\":\\\"Everything runs in your browser. Your files, data, and documents never leave your device — we can't see them, and neither can anyone else.\\\"}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"data-slot\\\":\\\"card\\\",\\\"data-size\\\":\\\"default\\\",\\\"className\\\":\\\"group/card flex-col overflow-hidden rounded-xl bg-card text-sm text-card-foreground ring-1 ring-foreground/10 has-data-[slot=card-footer]:pb-0 has-[\\u003eimg:first-child]:pt-0 data-[size=sm]:gap-3 data-[size=sm]:py-3 data-[size=sm]:has-data-[slot=card-footer]:pb-0 *:[img:first-child]:rounded-t-xl *:[img:last-child]:rounded-b-xl flex gap-3 p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L5\\\"