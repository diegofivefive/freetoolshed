readcrumb\",\"className\":\"mb-4\",\"children\":[\"$\",\"ol\",null,{\"className\":\"flex items-center gap-1 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",\"0\",{\"className\":\"flex items-center gap-1\",\"children\":[false,[\"$\",\"$L4\",null,{\"href\":\"/\",\"className\":\"transition-colors hover:text-foreground\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"1\",{\"className\":\"flex items-center gap-1\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"m9 18 6-6-6-6\",\"key\":\"mthhwq\"}]],\"className\":\"lucide-chevron-right size-3.5 shrink-0\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground\",\"children\":\"Privacy Policy\"}]]}]]}]}]],[\"$\",\"h1\",null,{\"className\":\"text-3xl font-bold tracking-tight\",\"children\":\"Privacy Policy\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":[\"Last updated: \",\"May 14, 2026\"]}],[\"$\",\"div\",null,{\"className\":\"mt-8 space-y-8 text-muted-foreground\",\"children\":[[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"The short version\"}],[\"$\",\"p\",null,{\"children\":\"Free Tool Shed processes your files entirely in your browser using WebAssembly and JavaScript. We do not upload, store, copy, or read your documents, images, audio, or video. There is no account system, so we have no email address, name, or password on file for you.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3\",\"children\":\"The longer policy below explains exactly what happens with the small amount of data that does exist — browser storage on your own device, and advertising cookies from third parties.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"What we don't collect\"}],[\"$\",\"p\",null,{\"children\":\"We do not collect your name, email, phone number, address, payment information, IP address, or precise location. We do not have a sign-up form, so we have nothing to forget if you ask us to delete your data — there is nothing in our possession to delete.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3\",\"children\":\"We do not run server-side analytics, fingerprinting, or session replay. We do not sell or share user data with brokers, because we have no user data to sell.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"What stays on your device\"}],[\"$\",\"p\",null,{\"children\":[\"Several tools save your in-progress work to your browser's\",[\"$\",\"code\",null,{\"className\":\"mx-1 rounded bg-muted px-1.5 py-0.5 font-mono text-sm\",\"children\":\"localStorage\"}],\"so you can pick up where you left off. This includes draft invoices, resume content, pay stubs, recently-used unit conversions, and similar working files. This data never leaves your device — it lives in your browser's private storage area, scoped to freetoolshed.com.\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3\",\"children\":\"You can wipe this data at any time by clearing site data for freetoolshed.com in your browser settings. Doing so deletes drafts and any saved tool history. If you want a portable backup before clearing, most tools include a JSON export option.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"Advertising\"}],[\"$\",\"p\",null,{\"children\":\"Free Tool Shed is supported by display advertising through Google AdSense. AdSense and its partners may use cookies and similar technologies to serve and measure ads — including, potentially, personalized ads based on your prior visits to this and other sites. We do not provide AdSense with any information about you beyond what their script collects automatically.\"}],\"$L15\"]}],\"$L16\",\"$L17\",\"$L18\",\"$L19\",\"$L1a\"]}]]