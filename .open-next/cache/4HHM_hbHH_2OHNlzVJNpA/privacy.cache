cy\\\"}]}\"}}],[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"mb-4\",\"children\":[\"$\",\"ol\",null,{\"className\":\"flex items-center gap-1 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",\"0\",{\"className\":\"flex items-center gap-1\",\"children\":[false,[\"$\",\"$L4\",null,{\"href\":\"/\",\"className\":\"transition-colors hover:text-foreground\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"1\",{\"className\":\"flex items-center gap-1\",\"children\":[[\"$\",\"$L5\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"m9 18 6-6-6-6\",\"key\":\"mthhwq\"}]],\"className\":\"lucide-chevron-right size-3.5 shrink-0\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground\",\"children\":\"Privacy Policy\"}]]}]]}]}]],[\"$\",\"h1\",null,{\"className\":\"text-3xl font-bold tracking-tight\",\"children\":\"Privacy Policy\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground\",\"children\":[\"Last updated: \",\"May 14, 2026\"]}],[\"$\",\"div\",null,{\"className\":\"mt-8 space-y-8 text-muted-foreground\",\"children\":[[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"The short version\"}],[\"$\",\"p\",null,{\"children\":\"Free Tool Shed processes your files entirely in your browser using WebAssembly and JavaScript. We do not upload, store, copy, or read your documents, images, audio, or video. There is no account system, so we have no email address, name, or password on file for you.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3\",\"children\":\"The longer policy below explains exactly what happens with the small amount of data that does exist — browser storage on your own device, and advertising cookies from third parties.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"What we don't collect\"}],[\"$\",\"p\",null,{\"children\":\"We do not collect your name, email, phone number, address, payment information, IP address, or precise location. We do not have a sign-up form, so we have nothing to forget if you ask us to delete your data — there is nothing in our possession to delete.\"}],[\"$\",\"p\",null,{\"className\":\"mt-3\",\"children\":\"We do not run server-side analytics, fingerprinting, or session replay. We do not sell or share user data with brokers, because we have no user data to sell.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"What stays on your device\"}],[\"$\",\"p\",null,{\"children\":[\"Several tools save your in-progress work to your browser's\",[\"$\",\"code\",null,{\"className\":\"mx-1 rounded bg-muted px-1.5 py-0.5 font-mono text-sm\",\"children\":\"localStorage\"}],\"so you can pick up where you left off. This includes draft invoices, resume content, pay stubs, recently-used unit conversions, and similar working files. This data never leaves your device — it lives in your browser's private storage area, scoped to freetoolshed.com.\"]}],[\"$\",\"p\",null,{\"className\":\"mt-3\",\"children\":\"You can wipe this data at any time by clearing site data for freetoolshed.com in your browser settings. Doing so deletes drafts and any saved tool history. If you want a portable backup before clearing, most tools include a JSON export option.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"Advertising\"}],[\"$\",\"p\",null,{\"children\":\"Free Tool Shed is supported by display advertising through Google AdSense. AdSense and its partners may use cookies and similar technologies to serve and measure ads — including, potentially, personalized ads based on your prior visits to this and other sites. We do not provide AdSense with any information about you beyond what their script collects automatically.\"}],\"$L15\"]}],\"$L16\",\"$L17\",\"$L18\",\"$L19\",\"$L1a\"]}]]}],null,\"$L1b\"]}]\n1c:[]\nf:\"$W1c\"\n10:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1d\",null,{\"children\":\"$L1e\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1f\",null,{\"children\":[\"$\",\"$20\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L21\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n12:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/123doanyjnwwq.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n13:[\"$\",\"link\",\"1\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/04uuf1716ltqa.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n22:I[97367,[\"/_next/static/chunks/0zif8_3mgcc0x.js\",\"/_next/static/chunks/0zv.me6xdrdsz.js\",\"/_next/static/chunks/0ag6f0zogt0qg.js\",\"/_next/static/chunks/04p0ygcx_g620.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_pa1c_tsbiw0.js\",\"/_next/static/chunks/10nuyoal1pib2.js\"],\"OutletBoundary\"]\n15:[\"$\",\"p\",null,{\"className\":\"mt-3\",\"children\":[\"You can opt out of personalized advertising at\",\" \",[\"$\",\"a\",null,{\"href\":\"https://adssettings.google.com/\",\"className\":\"text-brand underline underline-offset-4\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"children\":\"Google Ad Settings\"}],\" \",\"or via the\",\" \",[\"$\",\"a\",null,{\"href\":\"https://www.aboutads.info/choices/\",\"className\":\"text-brand underline underline-offset-4\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"children\":\"Digital Advertising Alliance\"}],\". Blocking advertising scripts does not affect tool functionality on this site.\"]}]\n16:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"Cookies\"}],[\"$\",\"p\",null,{\"children\":\"The only cookies set by Free Tool Shed directly are functional — remembering your theme preference (dark/light mode) and similar UI state. Third-party cookies may be set by the advertising scripts described above. You can block or clear cookies in your browser settings at any time without affecting tool functionality.\"}]]}]\n17:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"Children\"}],[\"$\",\"p\",null,{\"children\":\"Free Tool Shed is a general-audience site. We do not knowingly collect personal information from anyone, including children under 13. The tools themselves can be used by any age group; nothing about the experience is targeted at children.\"}]]}]\n18:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"Your rights (GDPR, CCPA, and similar)\"}],[\"$\",\"p\",null,{\"children\":\"Because we hold no personal data about you on our servers, most requests under privacy laws like the GDPR (EU) or CCPA (California) are already satisfied by default — there is nothing to access, correct, or delete on our side. If you want us to clarify this in writing for a regulator or a data-protection officer at your organization, email us and we'll respond.\"}]]}]\n19:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"Changes to this policy\"}],[\"$\",\"p\",null,{\"children\":\"If we change how Free Tool Shed handles data — for example, adding anonymous analytics or an optional account system — we will update this page and change the \\\"Last updated\\\" date at the top. Material changes will be flagged on the homepage for at least a week before they take effect.\"}]]}]\n1a:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-2 text-xl font-semibold text-foreground\",\"children\":\"Contact\"}],[\"$\",\"p\",null,{\"children\":[\"